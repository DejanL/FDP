@prefix : <https://dejanl.github.io/FDP/FDP.ttl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://dejanl.github.io/FDP/FDP.ttl> .

<https://dejanl.github.io/FDP/FDP.ttl> rdf:type owl:Ontology ;
    owl:versionIRI <https://dejanl.github.io/FDP/FDP-1.0.3.ttl> ;
    dcterms:contributor "Dejan Lavbič" ,
                        "Marko Poženel" ;
    dcterms:creator "Dejan Lavbič" ,
                    "Marko Poženel" ;
    dcterms:description "Ontologija načrtovalskih vzorcev v programskem inženirstvu."@sl ,
                        "Ontology of design patterns in software engineering."@en ;
    foaf:maker :DejanLavbic .

#################################################################
#    Annotation properties
#################################################################

dcterms:contributor rdf:type owl:AnnotationProperty ;
    dcterms:description "The guidelines for using names of persons or organizations as creators apply to contributors."@en ,
                        "Smernice za uporabo imen oseb ali organizacij kot ustvarjalcev veljajo za soavtorje."@sl ;
    rdfs:comment "An entity responsible for making contributions to the resource."@en ,
                 "Subjekt, odgovoren za prispevanje k viru."@sl ;
    rdfs:label "Contributor"@en ,
               "Soavtor"@sl .

dcterms:creator rdf:type owl:AnnotationProperty ;
    dcterms:description "Recommended practice is to identify the creator with a URI.  If this is not possible or feasible, a literal value that identifies the creator may be provided."@en ,
                        "Priporočena praksa je, da se ustvarjalca identificira z URI. Če to ni mogoče ali izvedljivo, se lahko navede dobesedna vrednost, ki identificira ustvarjalca."@sl ;
    rdfs:comment "An entity responsible for making the resource."@en ,
                 "Subjekt, odgovoren za izdelavo vira."@sl ;
    rdfs:label "Creator"@en ,
               "Ustvarjalec"@sl .

dcterms:description rdf:type owl:AnnotationProperty ;
    dcterms:description "Description may include but is not limited to: an abstract, a table of contents, a graphical representation, or a free-text account of the resource."@en ,
                        "Opis lahko vključuje, vendar ni omejen na: povzetek, kazalo vsebine, grafični prikaz ali opis vira v prostem besedilu." ;
    rdfs:comment "An account of the resource."@en ,
                 "Popis vira.";
    rdfs:label "Description"@en ,
               "Opis"@sl.

:intent rdf:type owl:AnnotationProperty ;
    rdfs:label "intent"@en ,
               "namen"@sl ;
    rdfs:domain :DesignPattern ;
    rdfs:subPropertyOf rdfs:comment .

rdfs:label rdf:type owl:AnnotationProperty ;
    rdfs:comment "A human-readable name for a resource."@en ,
                 "Človeško berljivo ime vira."@sl ;
    rdfs:label "label"@en ,
               "oznaka"@sl .

rdfs:comment rdf:type owl:AnnotationProperty ;
    rdfs:comment "A human-readable description of a resource."@en ,
                 "Človeško berljiv opis vira."@sl ;
    rdfs:label "comment"@en ,
               "opis"@sl .

rdfs:seeAlso rdf:type owl:AnnotationProperty ;
    rdfs:label "see also"@en ,
               "glej tudi"@sl ;
    rdfs:comment "A reference to a related resource that is not part of the current resource."@en ,
                 "Sklic na sorodni vir, ki ni del trenutnega vira."@sl .

skos:prefLabel rdf:type owl:AnnotationProperty ;
    rdfs:label "preferred label"@en ;
    skos:definition "The preferred lexical label for a resource, in a given language."@en ;
    rdfs:comment "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@en .

:participantType rdf:type owl:AnnotationProperty ;
    rdfs:domain :Participant ;
    rdfs:range [ rdf:type rdfs:Datatype ;
        owl:oneOf ( "Class" "Object" "Interface" )
    ] ;
    rdfs:comment "Type of participant in the design pattern. Allowed values: Class, Object, Interface."@en ,
                 "Vrsta udeleženca v načrtovalskem vzorcu. Dovoljene vrednosti: Class, Object, Interface."@sl ;
    rdfs:label "type of participant"@en ,
               "vrsta udeleženca"@sl .

:relationshipType rdf:type owl:AnnotationProperty ;
    rdfs:domain :Participant ;
    rdfs:range [ rdf:type rdfs:Datatype ;
        owl:oneOf ( "dependency"  "implementation"  "association"  "aggregation"  "extension"  "composition" )
    ] ;
    rdfs:label "type of relationship"@en ,
               "vrsta razmerja"@sl ;
    rdfs:comment "Type of relationship between participants in a design pattern."@en ,
                 "Vrsta razmerja med udeleženci v načrtovalskem vzorcu."@sl .

:relationshipSymbol rdf:type owl:AnnotationProperty ;
    rdfs:domain :Participant ;
    rdfs:range [ rdf:type rdfs:Datatype ;
        owl:oneOf ( "..>" "..|>" "-->" "--o" "--|>" "--*" )
    ] ;
    rdfs:label "relationship symbol"@en ,
               "simbol razmerja"@sl ;
    rdfs:comment "Symbol representing the type of relationship between participants in a design pattern."@en ,
                 "Simbol, ki predstavlja vrsto razmerja med udeleženci v načrtovalskem vzorcu."@sl .

#################################################################
#    Object Properties
#################################################################

:hasParticipant rdf:type owl:ObjectProperty ;
    owl:propertyChainAxiom (
        :hasStructure
        :hasStructureElement
    ) ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Participant ;
    rdfs:comment "Design pattern has a participant, which is an object that plays a specific role in the context of a design pattern."@en ,
                 "Načrtovalski vzorec ima udeleženca, ki je objekt, ki ima določeno vlogo v okviru načrtovalskega vzorca."@sl ;
    rdfs:label "has participant"@en ,
               "ima udeleženca"@sl .

:canBeDevelopedFrom rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    owl:inverseOf :canBeStartingPointFor ;
    rdfs:comment "Indicates that one design pattern can be developed from another design pattern. For example, Abstract Factory, Prototype, or Builder (more complicated) can be evolved from Factory Method (less complicated)."@en ,
                 "Označuje, da se lahko en načrtovalski vzorec razvije iz nekega drugega načrtovalskega vzorca. Na primer, načrtovalski vzorci Abstract Factory, Prototype ali Builder (bolj zapleteni) se lahko razvijejo iz vzorca Factory Method (manj zapleten)."@sl ;
    rdfs:label "can be developed from"@en ,
               "se lahko razvije iz"@sl .

:canBeImplementedAs rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:domain :DesignPattern ;
    rdfs:range :DesignPattern ;
    rdfs:comment "Indicates that one design pattern can be implemented as another design pattern."@en ,
                 "Označuje, da se lahko en načrtovalski vzorec implementira kot drug načrtovalski vzorec."@sl ;
    rdfs:label "can be implemented as"@en ,
               "lahko implementiramo kot"@sl .

:canBeSimplifiedTo rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:comment "Design pattern can be transformed or simplified to another design pattern."@en ,
                 "Načrtovalski vzorec lahko pretvorimo oz. poenostavimo v nek drug načrtovalski vzorec."@sl ;
    rdfs:label "can be simplified to"@en ,
               "lahko poenostavimo v"@sl .

:canBeStartingPointFor rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:comment "Indicates that one design pattern can be the basis for another design pattern. For example, Factory Method (less complicated) can evolve to more complicated design patterns Abstract Factory, Prototype, or Builder."@en ,
                 "Označuje, da je načrtovalski vzorec lahko osnova za nek drugi načrtovalski vzorec. Na primer, načrtovalski vzorec Factory Method lahko razvijemo v bolj zapletene vzorce Abstract Factory, Prototype ali Builder."@sl ;
    rdfs:label "Can be starting point for."@en ,
               "can be starting point for"@en ,
               "je lahko izhodišče za"@sl .

:canBeTreatedAsPowerful rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    owl:inverseOf :canBeTreatedAsSimplified ;
    rdfs:comment "Vzorec lahko obravnavamo kot zmogljivo različico nekega drugega vzorca. Na primer, načrtovalski vzorec Visitor lahko obravnavamo kot zmogljivo različico vzorca Command."@sl ,
                 "We can treat pattern as powerful version of some other pattern. For example, we can treat Visitor as a powerful version of the Command pattern."@en ;
    rdfs:label "can be treated as powerful version of"@en ,
               "lahko obravnavamo kot zmogljivo različico"@sl .

:canBeUsedWith rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:domain :DesignPattern ;
    rdfs:range :DesignPattern ;
    rdfs:comment "Vzorec lahko kombiniramo z drugim vzorcem. Na primer, kombiniramo lahko vzorca Builder z Bridge: razred director igra vlogo abstrakcije, medtem ko različni graditelji delujejo kot implementacije."@sl ,
                 "We can combine design pattern with some other pattern. For example, we can combine Builder with Bridge: the director class plays the role of the abstraction, while different builders act as implementations."@en ;
    rdfs:label "can be used in conjunction with"@en ,
               "can be used with"@en ,
               "lahko uporabimo skupaj z"@sl .

:canBenefitFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :DesignPattern ;
    rdfs:comment "Pattern can benefit from using other pattern. For example, designs that make heavy use of Composite and Decorator can often benefit from using Prototype."@en ,
                 "Vzorec lahko ima koristi od uporabe nekega drugega vzorca. Na primer, modeli, ki pogosto uporabljajo načrtovalski vzorec Composite in Decorator, lahko pogosto izkoristijo uporabo vzorca Prototype."@sl ;
    rdfs:label "can benefit from"@en ,
               "lahko ima koristi od"@sl .

:canServeAsAlternative rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:comment "Indicates that one design pattern can serve as an alternative to another design pattern."@en ,
                 "Označuje, da se lahko en načrtovalski vzorec uporabi kot alternativa drugemu načrtovalskemu vzorcu."@sl ;
    rdfs:label "can serve as alternative"@en ,
               "lahko služi kot alternativa"@sl .

:differsInAspectsFrom rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :isDifferentFrom ;
    rdfs:comment "Indicates that one design pattern differs in aspects from another design pattern."@en ,
                 "Označuje, da se en načrtovalski vzorec razlikuje v vidikih od drugega načrtovalskega vzorca."@sl ;
    rdfs:label "differs in aspects from"@en ,
               "se razlikuje v vidikih od"@sl .

:encapsulatesOperation rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern lets us encapsulate operations a between various objects. For example, Mediator pattern lets us encapsulate a complex web of relations between various objects inside a single mediator object."@en ,
                 "Načrtovalski vzorec omogoča inkapsulacijo operacij med objekti. Na primer, vzorec Mediator omogoča inkapsulacijo kompleksne mreže odnosov med različnimi objekti znotraj objekta Mediator."@sl ;
    rdfs:label "encapsulates operations"@en ,
               "inkapsulira operacije"@sl .

:hasAspect rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern is connected to an aspect, has an aspect, or uses an aspect."@en ,
                 "Načrtovalski vzorec je povezan z nekim vidikom, uporablja nek vidik."@sl ;
    rdfs:label "has an aspect"@en ,
               "je povezan z vidikom"@sl .

:hasCon rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasAspect ;
    rdfs:comment "Design pattern has a con / disadvantage."@en ,
                 "Načrtovalski vzorec ima slabost / pomanjkljivost."@sl ;
    rdfs:label "has con"@en ,
               "ima slabost"@sl .

:hasPro rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasAspect ;
    rdfs:comment "Design pattern has a pro / advantage."@en ,
                 "Načrtovalski vzorec ima prednost."@sl ;
    rdfs:label "has pro"@en ,
               "ima prednost"@sl .

:hasSimilarStructure rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :isSimilarTo ;
    rdfs:comment "Design pattern has a similar structure to another design pattern. For example, Decorator and Proxy have similar structures, but very different intents."@en ,
                 "Načrtovalski vzorec ima podobno strukturo kot nek drug načrtovalski vzorec. Na primer, vzorca Decorator in Proxy imata podobni strukturi, vendar zelo različna namena."@sl ;
    rdfs:label "has similar structure"@en ,
               "ima podobno strukturo"@sl .

:hasSourceCode rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :SourceCode ;
    rdfs:comment "Design pattern has source code. For example, there is a code example of a design pattern in a programming language."@en ,
                 "Načrtovalski vzorec ima izvorno kodo. Na primer, za načrtovalski vzorec je na voljo primer izvorne kode v nekem programskem jeziku."@sl ;
    rdfs:label "has source code"@en ,
               "ima izvorno kodo"@sl .

:isBasedOn rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasAspect ;
    rdfs:comment "Design pattern is based on certain aspect. For example, Template Method is based on inheritance: it lets us alter parts of an algorithm by extending those parts in subclasses."@en ,
                 "Načrtovalski vzorec temelji na določenem vidiku. Na primer, vzorec Template Method temelji na dedovanju: omogoča nam spreminjanje delov algoritma z razširitvijo teh delov v podrazredih."@sl ;
    rdfs:label "is based on"@en ,
               "temelji na"@sl .

:isDifferentFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :DesignPattern ;
    rdfs:comment "Indicates that one design pattern is different from another design pattern."@en ,
                 "Označuje, da je en načrtovalski vzorec drugačen od drugega načrtovalskega vzorca."@sl ;
    rdfs:label "is different from"@en ,
               "je drugačen od"@sl .

:isExtensionOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:domain :DesignPattern ;
    rdfs:range :DesignPattern ;
    rdfs:comment "Indicates that one design pattern is an extension of other design pattern. For example, State can be considered as an extension of Strategy."@en ,
                 "Označuje, da je en načrtovalski vzorec razširitev drugega načrtovalskega vzorca. Na primer, načrtovalski vzorec State lahko obravnavamo kot razširitev vzorca Strategija."@sl ;
    rdfs:label "is an extension of"@en ,
               "je razširitev"@sl .

:isFocusedOn rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design patterns is applied when there is focus on certain aspect. For example, Abstract Factory specializes in creating families of related objects."@en ,
                 "Načrtovalski vzorec se uporabi, kadar je poudarek na določenem vidiku. Na primer, vzorec Abstract Factory je specializiran za ustvarjanje družin povezanih objektov."@sl ;
    rdfs:label "is focused on / specializes in"@en ,
               "se osredotoča na / se uporablja, ko"@sl .

:isPatternGeneralization rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    owl:inverseOf :isPatternSpecialization ;
    rdfs:comment "Design pattern is a generalization of another design pattern."@en ,
                 "Načrtovalski vzorec je generalizacija drugega načrtovalskega vzorca."@sl ;
    rdfs:label "is generalization of"@en ,
               "je generalizacija"@sl .

:isNotBasedOn rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasAspect ;
    rdfs:comment "Design pattern is not based on some aspect. For example, Prototype pattern isn’t based on inheritance, so it doesn’t have its drawbacks."@en ,
                 "Načrtovalski vzorec ni osnovan na nekem aspektu. Na primer, vzorec Prototype ne temelji na dedovanju, zato nima njegovih pomanjkljivosti."@sl ;
    rdfs:label "is not based on"@en ,
               "ne temelji na"@sl .

:isSimilarTo rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:domain :DesignPattern ;
    rdfs:range :DesignPattern ;
    rdfs:comment "Design pattern is similar to some other design pattern. For example, Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests."@en ,
                 "Načrtovalski vzorec je podoben nekemu drugemu načrtovalskemu vzorcu. Na primer, vzorci Chain of Responsibility, Command, Mediator in Observer obravnavajo različne načine povezovanja pošiljateljev in prejemnikov zahtev."@sl ;
    rdfs:label "is similar to"@en ,
               "je podoben"@sl .

:isPatternSpecialization rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:comment "Design pattern is a specialization of another design pattern."@en ,
                 "Načrtovalski vzorec je specializacija drugega načrtovalskega vzorca."@sl ;
    rdfs:label "is specialization"@en ,
               "je specializacija"@sl .

:keepsOriginalInterface rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern keeps original interface of the service object. For example, with Proxy, the interface stays the same."@en ,
                 "Načrtovalski vzorec ohrani originalni vmesnik storitvenega objekta. Na primer, pri Proxyju vmesnik ostane enak."@sl ;
    rdfs:label "keeps original interface"@en ,
               "ohrani prvotni vmesnik"@sl .

:offersNewInterface rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern offers a new interface to service object(s). For example, Adapter provides a completely different interface for accessing an existing object."@en ,
                 "Načrtovalski vzorec ponudi nov vmesnik za enega ali skupino storitvenih objektov. Vzorec Adapter na primer ponuja popolnoma drugačen vmesnik za dostop do obstoječega servisnegba objekta."@sl ;
    rdfs:label "offers a new interface"@en ,
               "ponuja nov vmesnik"@sl .

:organizesCollaboration rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern organizes collaboration between components."@en ,
                 "Načrtovalski vzorec uskladi sodelovanje med komponentami."@sl ;
    rdfs:label "organizes collaboration between"@en ,
               "uskladi delovanje med"@sl .

:preserves rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern preserves or extends an aspect. For example, Decorator preserves the Component interface; it either stays the same or gets extended."@en ,
                 "Načrtovalski vzorec ohrani ali razširi nek aspekt sistema. Na primer, Decorator ohrani vmesnik Component; ta ostane enak ali pa se razširi. "@sl ;
    rdfs:label "ohrani ali razširi"@sl ,
               "preserves or extends"@en .

:solvesDifferentProblems rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :isDifferentFrom ;
    rdfs:comment "Design pattern solves different problem than some design other pattern. For example, Bridge, State, Strategy and Adapter have very similar structures, however, they all solve different problems."@en ,
                 "Načrtovalski vzorec rešuje drugačen problem kot nek drug načrtovalski vzorec. Na primer, Bridge, State, Strategy in Adapter imajo zelo podobne strukture, vendar vsi rešujejo različne probleme."@sl ;
    rdfs:label "rešuje drugačen problem"@en ,
               "solves different problem"@en .

:solvesIncompatibility rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern solves incompatibility issues related to some aspect."@en ,
                 "Načrtovalski vzorec rešuje težave z neskladnostjo, povezano z nekim aspektom."@sl ;
    rdfs:label "rešuje težave z neskladnostjo"@sl ,
               "solves incompatibility"@en .

:uses rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern uses/employs an aspect."@en ,
                 "Načrtovalski vzorec uporabi vidik."@sl ;
    rdfs:label "uporabi nek koncept"@sl ,
               "uses/employs a concept"@en .

:usesDynamicChain rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :uses ;
    rdfs:comment "Design pattern uses a dynamic chain of objects related to a specific aspect."@en ,
                 "Načrtovalski vzorec uporablja dinamično verigo objektov, povezanih z določenim vidikom."@sl ;
    rdfs:label "uporablja dinamično verigo objektov"@sl ,
               "uses dynamic chain of objects"@en .

:usesIndirectConnection rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :uses ;
    rdfs:comment "Design pattern uses indirect connection related to a specific aspect."@en ,
                 "Načrtovalski vzorec uporablja dinamično verigo objektov za posredno obravnavo določenega vidika."@sl ;
    rdfs:label "uporablja posredno povezavo"@sl ,
               "uses indirect connection"@en .

:usesSubscriptionModel rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :uses ;
    rdfs:comment "Design pattern uses subscription model related to a specific aspect."@en ,
                 "Načrtovalski vzorec uporablja naročniški model, povezan z določenim vidikom."@sl ;
    rdfs:label "uporablja naročniški model"@sl ,
               "uses subscription model"@en .

:usesUnidirectionalConnection rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :uses ;
    rdfs:comment "Design pattern uses unidirectional connection related to a specific aspect."@en ,
                 "Načrtovalski vzorec uporablja enosmerno povezavo povezano z določenim vidikom."@sl ;
    rdfs:label "uporablja enosmerno povezavo"@sl ,
               "uses unidirectional connection"@en .

:wrapsSingle rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Aspect ;
    rdfs:comment "Design pattern wraps single aspect."@en ,
                 "Načrtovalski vzorec ovije / zajema en sam vidik."@sl ;
    rdfs:label "ovije samo en objekt"@sl ,
               "wraps single"@en .

:narrower rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    skos:definition "Relates a concept to a concept that is more specific in meaning."@en ;
    rdfs:comment "Narrower concepts are typically rendered as children in a concept hierarchy (tree). Design pattern or aspect is narrower than another design pattern or aspect."@en ,
                 "Ožji koncepti so običajno upodobljeni kot podrejeni elementi v hierarhiji konceptov (drevesu). Načrtovalski vzorec ali vidik je ožje opredeljen od načrtovalskega vzorca ali vidika."@sl ;
    rdfs:label "has narrower"@en ,
               "je ožje opredeljen kot"@sl .

skos:related rdf:type owl:ObjectProperty ;
    rdfs:domain [
        rdf:type owl:Class ;
        owl:unionOf ( :Aspect :DesignPattern :Participant )
    ] ;
    rdfs:range [
        rdf:type owl:Class ;
        owl:unionOf ( :Aspect :DesignPattern :Participant )
    ] ;
    skos:definition "Relates a concept to a concept with which there is an associative semantic relationship."@en ;
    rdfs:comment "skos:related is disjoint with skos:broaderTransitive. Design pattern or aspect is related to another design pattern or aspect."@en ,
                 "skos:related je disjunkten s skos:broaderTransitive. Načrtovalski vzorec ali vidik je povezan z načrtovalskim vzorcem ali vidikom."@sl ;
    rdfs:label "has related"@en ,
               "je povezan z"@sl .

:canBeTreatedAsSimplified rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:label "can be treated as simplified"@en ,
               "can be a simpler alternative to"@en ,
               "je lahko preprostejša alternativa"@sl ;
    rdfs:comment "Pattern can be a simpler alternative to some other design pattern. For example, sometimes Prototype can be a simpler alternative to Memento."@en ,
                 "Vzorec je lahko preprostejša alternativa nekemu drugemu vzorcu. Na primer, včasih je vzorec Prototype lahko preprostejša alternativa vzorcu Memento."@sl .

:centralizesCommunication rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:label "centralizes communication"@en .

foaf:maker rdf:type owl:ObjectProperty ;
    rdfs:label "maker"@en ,
               "kreator"@sl ;
    rdfs:comment "An agent that made this thing."@en ,
                 "Agent, ki je to stvar ustvaril."@sl .

foaf:mbox rdf:type owl:ObjectProperty ;
    rdfs:label "personal mailbox"@en ,
               "osebni poštni predal"@sl ;
    rdfs:comment "A personal mailbox, ie. an Internet mailbox associated with exactly one owner, the first owner of this mailbox. This is a 'static inverse functional property', in that  there is (across time and change) at most one individual that ever has any particular value for foaf:mbox."@en ,
                 "Osebni poštni predal, tj. internetni poštni predal, povezan z natanko enim lastnikom, prvim lastnikom tega poštnega predala. To je »statična inverzna funkcionalna lastnost«, saj obstaja (skozi čas in spremembe) največ en posameznik, ki ima kdajkoli določeno vrednost za foaf:mbox."@sl .

foaf:name rdf:type owl:ObjectProperty ;
    rdfs:label "name"@en ,
               "ime"@sl ;
    rdfs:comment "A name for some thing."@en ,
                 "Ime za nekaj."@sl .

:dependsOn rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    :relationshipType "dependency" ;
    :relationshipSymbol "..>" ;
    rdfs:label "depends on"@en, "je odvisen od"@sl ;
    rdfs:comment "A weaker form of dependency."@en .

:implements rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    :relationshipType "implementation" ;
    :relationshipSymbol "..|>" ;
    rdfs:label "implements"@en, "implementira"@sl ;
    rdfs:comment "Realization of an interface by a class."@en .

:isAssociatedWith rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    :relationshipType "association" ;
    :relationshipSymbol "-->" ;
    rdfs:label "is associated with"@en ;
    rdfs:comment "The object uses another object."@en .

:isPartOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    :relationshipType "aggregation" ;
    :relationshipSymbol "--o" ;
    rdfs:label "is part of"@en ;
    rdfs:comment "The part can exist independently of the whole."@en .

:isSpecializationOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    :relationshipType "extension" ;
    :relationshipSymbol "--|>" ;
    rdfs:label "is specialization of"@en ;
    rdfs:comment "Specialization of a class in a hierarchy."@en .

:isWholePartOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf skos:related ;
    :relationshipType "composition" ;
    :relationshipSymbol "--*" ;
    rdfs:label "is whole part of"@en ;
    rdfs:comment "The part cannot exist without the whole."@en .

:hasStructureElement rdf:type owl:ObjectProperty ;
    rdfs:domain :Structure ;
    rdfs:range :Participant ;
    rdfs:label "has structure element"@en ,
               "ima strukturni element"@sl .

:hasStructure rdf:type owl:ObjectProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range :Structure ;
    rdfs:label "has structure"@en ,
               "ima strukturo"@sl .

#################################################################
#    Data properties
#################################################################

:language rdf:type owl:DatatypeProperty ;
    rdfs:domain :SourceCode ;
    rdfs:range xsd:string ;
    rdfs:comment "Programming language used for the source code."@en ,
                 "Programski jezik, ki se uporablja za izvorno kodo."@sl ;
    rdfs:label "programming language"@en ,
               "programski jezik"@sl .

:programcode rdf:type owl:DatatypeProperty ;
    rdfs:domain :SourceCode ;
    rdfs:range xsd:string ;
    rdfs:comment "Instructions written in a programming language that defines what a software program should do"@en ,
                 "Navodila v programskem jeziku, ki določajo, kaj naj programska oprema počne."@sl ;
    rdfs:label "izvorna koda programa"@sl ,
               "program source code"@en .

:diagram rdf:type owl:DatatypeProperty ;
    rdfs:domain :DesignPattern ;
    rdfs:range xsd:anyURI ;
    rdfs:label "diagram" ;
    rdfs:comment "Diagram načrtovalskega vzorca."@sl, "Design pattern diagram."@en .

