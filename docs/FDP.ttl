:Aspect rdf:type owl:Class ;
    rdfs:comment "Aspect is a viewpoint or perspective from which a system is analyzed."@en ,
                 "Vidik je pogled ali perspektiva, iz katere se analizira sistem."@sl ;
    rdfs:label "Aspect"@en ,
               "Vidik"@sl .

:BehavioralPattern rdf:type owl:Class ;
    rdfs:subClassOf :DesignPattern ;
    rdfs:comment "Behavioral pattern is a design pattern that focuses on how objects interact and communicate with each other to distribute responsibilities and define the flow of control in the system."@en ,
                 "Vedenjski vzorec je načrtovalski vzorec, ki se osredotoča na to, kako objekti medsebojno sodelujejo in komunicirajo, da porazdelijo odgovornosti in določijo potek nadzora v sistemu."@sl ;
    rdfs:label "Behavioral Pattern"@en ,
               "Vedenjski vzorec"@sl ;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/behavioral-patterns" .

:CreationalPattern rdf:type owl:Class ;
    rdfs:subClassOf :DesignPattern ;
    rdfs:comment "Creational pattern is a design pattern that focuses on how objects are created, helping to abstract and manage the instantiation process in a flexible and reusable way."@en ,
                 "Vzorec kreiranja je načrtovalski vzorec, ki se osredotoča na način ustvarjanja objektov ter pomaga abstraktno in prilagodljivo upravljati postopek njihovega instanciranja na večkrat uporaben način."@sl ;
    rdfs:label "Creational Pattern"@en ,
               "Vzorec kreiranja"@sl ;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/creational-patterns"^^xsd:anyURI .

:DesignPattern rdf:type owl:Class ;
    rdfs:comment "Design pattern is a general, reusable solution to a commonly occurring problem in the design of object-oriented systems."@en ,
                 "Načrtovalski vzorec je splošna, večkrat uporabna rešitev za pogosto ponavljajoč se problem pri načrtovanju objektno usmerjenih sistemov."@sl ;
    rdfs:label "Design Pattern"@en ,
               "Načrtovalski vzorec"@sl .

:OOConcept rdf:type owl:Class ;
    rdfs:subClassOf :Aspect ;
    rdfs:comment "Object Oriented concepts are fundamental principles of Object Oriented Programming (OOP) that define how objects interact with each other and how they are structured."@en ,
                 "Objektno usmerjeni koncepti so temeljna načela objektno usmerjenega programiranja (OOP), ki določajo, kako med seboj delujejo objekti in kako so strukturirani."@sl ;
    rdfs:label "Object Oriented concept"@en ,
               "Objektno usmerjen koncept"@sl .

:Principle rdf:type owl:Class ;
    rdfs:subClassOf :Aspect ;
    rdfs:comment "Načela so temeljne resnice ali trditve, ki služijo kot osnova za sistem prepričanj ali vedenja."@sl ,
                 "Principles are fundamental truths or propositions that serve as the foundation for a system of belief or behavior."@en ,
                 "Principles guide the design process and help maintain code quality, modularity, and scalability."@en ;
    rdfs:label "Načelo"@sl ,
               "Principle"@en .

:StructuralPattern rdf:type owl:Class ;
    rdfs:subClassOf :DesignPattern ;
    rdfs:comment "Structural pattern is a design pattern that focuses on how classes and objects are composed to form larger structures, ensuring that the system components are organized in a way that promotes flexibility, reusability, and maintainability."@en ,
                 "Strukturni vzorec je načrtovalski vzorec, ki se osredotoča na način sestavljanja razredov in objektov v večje strukture ter zagotavlja, da so sestavni deli sistema organizirani tako, da spodbujajo prilagodljivost, večkratno uporabo in enostavno vzdrževanje."@sl ;
    rdfs:label "Structural Pattern"@en ,
               "Strukturni vzorec"@sl ;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/structural-patterns"^^xsd:anyURI .

foaf:Person rdf:type owl:Class ;
    rdfs:comment "A human being as an entity with social relationships, personal information, and online presence."@en ,
                 "Človek kot entiteta s socialnimi odnosi, osebnimi podatki in spletno prisotnostjo."@sl ;
    rdfs:label "Oseba"@sl ,
               "Person"@en .

:SourceCode rdf:type owl:Class ;
    rdfs:comment "Izvorna koda implementacije načrtovalskega vzorca."@sl ,
                 "Source code of the design pattern implementation."@en ;
    rdfs:label "Izvorna koda"@sl ,
               "Source code"@en .

#################################################################
#    Individuals
#################################################################

:AdapterStructure rdf:type owl:NamedIndividual ,
                           :Structure ;
    :hasStructureElement :AdapterAdapter ,
                         :AdapterClient ,
                         :AdapterClientInterface ,
                         :AdapterService ;
    rdfs:label "Adapter pattern structure"@en ,
               "Struktura vzorca Adapter"@sl ;
    rdfs:comment "[Object Adapter] This implementation uses the object composition principle: the adapter implements the interface of one object and wraps the other one. It can be implemented in all popular programming languages. The client code doesn’t get coupled to the concrete adapter class as long as it works with the adapter via the client interface. Thanks to this, you can introduce new types of adapters into the program without breaking the existing client code. This can be useful when the interface of the service class gets changed or replaced: you can just create a new adapter class without changing the client code."@en .

:AdapterClient rdf:type owl:NamedIndividual ,
                        :ClientClass ;
    :isAssociatedWith :AdapterClientInterface ;
    rdfs:label "Client class of the Adapter pattern"@en ,
               "Razred Client vzorca Adapter"@sl ;
    rdfs:comment "The Client is a class that contains the existing business logic of the program."@en .

:AdapterClientInterface rdf:type owl:NamedIndividual ,
                                 :ClientInterface ;
    rdfs:label "Client interface of the Adapter pattern"@en ,
               "Vmesnik ClientInterface vzorca Adapter"@sl ;
    rdfs:comment "The Client Interface describes a protocol that other classes must follow to be able to collaborate with the client code."@en .

:AdapterService rdf:type owl:NamedIndividual ,
                         :ServiceClass ;
    rdfs:label "Service class of the Adapter pattern"@en ,
               "Razred Service vzorca Adapter"@sl ;
    rdfs:comment "The Service is some useful class (usually 3rd-party or legacy). The client can’t use this class directly because it has an incompatible interface."@en .

:AdapterAdapter rdf:type owl:NamedIndividual ,
                         :AdapterClass ;
    :implements :AdapterClientInterface ;
    :isAssociatedWith :AdapterService ;
    rdfs:label "Adapter class of the Adapter pattern"@en ,
               "Razred Adapter vzorca Adapter"@sl ;
    rdfs:comment "The Adapter is a class that’s able to work with both the client and the service: it implements the client interface, while wrapping the service object. The adapter receives calls from the client via the client interface and translates them into calls to the wrapped service object in a format it can understand."@en .

:BridgeStructure rdf:type owl:NamedIndividual ,
                          :Structure ;
    :hasStructureElement :BridgeAbstraction ,
                         :BridgeClient ,
                         :BridgeConcreteImplementation ,
                         :BridgeImplementation ,
                         :BridgeRefinedAbstraction ;
    rdfs:label "Bridge pattern structure"@en ,
               "Struktura vzorca Bridge"@sl ;
    rdfs:comment "Abstraction + Implementation. There is one hierarchy for an abstraction (Abstraction) and a separate hierarchy for its implementation (Implementor), which makes the two independent from each other."@en .

:BridgeClient rdf:type owl:NamedIndividual ,
                       :ClientClass ;
    :isAssociatedWith :BridgeAbstraction ;
    rdfs:label "Client class of the Bridge pattern"@en ,
               "Razred Client vzorca Bridge"@sl ;
    rdfs:comment "Usually, the Client is only interested in working with the abstraction. However, it’s the client’s job to link the abstraction object with one of the implementation objects."@en .

:BridgeAbstraction rdf:type owl:NamedIndividual ,
                            :AbstractionClass ;
    rdfs:label "Abstraction class of the Bridge pattern"@en ,
               "Razred Abstraction vzorca Bridge"@sl ;
    rdfs:comment "The Abstraction provides high-level control logic. It relies on the implementation object to do the actual low-level work."@en .

:BridgeImplementation rdf:type owl:NamedIndividual ,
                               :ImplementationInterface ;
    :isPartOf :BridgeAbstraction ;
    rdfs:label "Implementation interface of the Bridge pattern"@en ,
               "Vmesnik Implementation vzorca Bridge"@sl ;
    rdfs:comment "The Implementation declares the interface that’s common for all concrete implementations. An abstraction can only communicate with an implementation object via methods that are declared here. The abstraction may list the same methods as the implementation, but usually the abstraction declares some complex behaviors that rely on a wide variety of primitive operations declared by the implementation."@en .

:BridgeConcreteImplementation rdf:type owl:NamedIndividual ,
                                       :ConcreteImplementationClass ;
    :implements :BridgeImplementation ;
    rdfs:label "ConcreteImplementation class of the Bridge pattern"@en ,
               "Razred ConcreteImplementation vzorca Bridge"@sl ;
    rdfs:comment "Concrete Implementations contain platform-specific code. These classes implement the Implementation interface."@en .

:BridgeRefinedAbstraction rdf:type owl:NamedIndividual ,
                                   :RefinedAbstractionClass ;
    :isSpecializationOf :BridgeAbstraction ;
    rdfs:label "RefinedAbstraction class of the Bridge pattern"@en ,
               "Razred RefinedAbstraction vzorca Bridge"@sl ;
    rdfs:comment "Refined Abstractions provide variants of control logic. Like their parent, they work with different implementations via the general implementation interface. These classes extends the interface defined by Abstraction."@en .

:CompositeStructure rdf:type owl:NamedIndividual ,
                             :Structure ;
    :hasStructureElement :CompositeClient ,
                         :CompositeComponent ,
                         :CompositeContainer ,
                         :CompositeLeaf ;
    rdfs:label "Composite pattern structure"@en ,
               "Struktura vzorca Composite"@sl ;
    rdfs:comment "The Client class doesn't refer to the Leaf and Composite classes directly (separately). Instead, the Client refers to the common Component interface and can treat Leaf and Composite uniformly. The Composite class maintains a container of child Component objects (children) and forwards requests to these children."@en .

:CompositeComponent rdf:type owl:NamedIndividual ,
                             :ComponentInterface ;
    :isPartOf :CompositeContainer ;
    rdfs:label "Component interface of the Composite pattern"@en ,
               "Vmesnik Component vzorca Composite"@sl ;
    rdfs:comment "The Component interface describes operations that are common to both simple and complex elements of the tree."@en .

:CompositeLeaf rdf:type owl:NamedIndividual ,
                        :LeafClass ;
    :implements :CompositeComponent ;
    rdfs:label "Leaf class of the Composite pattern"@en ,
               "Razred Leaf vzorca Composite"@sl ;
    rdfs:comment "The Leaf is a basic element of a tree that doesn’t have sub-elements. Usually, leaf components end up doing most of the real work, since they don’t have anyone to delegate the work to."@en .

:CompositeContainer rdf:type owl:NamedIndividual ,
                             :ContainerClass ;
    :implements :CompositeComponent ;
    rdfs:label "Container class of the Composite pattern"@en ,
               "Razred Container vzorca Composite"@sl ;
    rdfs:comment "The Container (aka composite) is an element that has sub-elements: leaves or other containers. A container doesn’t know the concrete classes of its children. It works with all sub-elements only via the component interface. Upon receiving a request, a container delegates the work to its sub-elements, processes intermediate results and then returns the final result to the client."@en .

:CompositeClient rdf:type owl:NamedIndividual ,
                          :ClientClass ;
    :isAssociatedWith :CompositeComponent ;
    rdfs:label "Client class of the Composite pattern"@en ,
               "Razred Client vzorca Composite"@sl ;
    rdfs:comment "The Client works with all elements through the component interface. As a result, the client can work in the same way with both simple or complex elements of the tree."@en .

:DecoratorStructure rdf:type owl:NamedIndividual ,
                             :Structure ;
    :hasStructureElement :DecoratorBaseDecorator ,
                         :DecoratorClient ,
                         :DecoratorComponent ,
                         :DecoratorConcreteComponent ,
                         :DecoratorConcreteDecorator ;
    rdfs:label "Decorator pattern structure"@en ,
               "Struktura vzorca Decorator"@sl ;
    rdfs:comment "The BaseDecorator class maintains a reference (component) to the decorated object (ConcreteComponent) and forwards all requests to it (component.execute()). This makes Decorator transparent (invisible) to clients of Component. // a = new ConcreteComponent(); b = ConcreteDecorator(a); c = ConcreteDecoratorOther(b); c.execute();  // Decorator -> Decorator -> Component"@en .

:DecoratorComponent rdf:type owl:NamedIndividual ,
                             :ComponentInterface ;
    :isPartOf :DecoratorBaseDecorator ;
    rdfs:label "Component interface of the Decorator pattern"@en ,
               "Vmesnik Component vzorca Decorator"@sl ;
    rdfs:comment "The Component declares the common interface for both wrappers and wrapped objects."@en .

:DecoratorConcreteComponent rdf:type owl:NamedIndividual ,
                                     :ConcreteComponentClass ;
    :implements :DecoratorComponent ;
    rdfs:label "ConcreteComponent class of the Decorator pattern"@en ,
               "Razred ConcreteComponent vzorca Decorator"@sl ;
    rdfs:comment "Concrete Component is a class of objects being wrapped. It defines the basic behavior, which can be altered by decorators."@en .

:DecoratorBaseDecorator rdf:type owl:NamedIndividual ,
                                 :BaseDecoratorClass ;
    :implements :DecoratorComponent ;
    rdfs:label "BaseDecorator class of the Decorator pattern"@en ,
               "Razred BaseDecorator vzorca Decorator"@sl ;
    rdfs:comment "The Base Decorator class has a field for referencing a wrapped object. The field’s type should be declared as the component interface so it can contain both concrete components and decorators. The base decorator delegates all operations to the wrapped object."@en .

:DecoratorConcreteDecorator rdf:type owl:NamedIndividual ,
                                     :ConcreteDecoratorClass ;
    :isSpecializationOf :DecoratorBaseDecorator ;
    rdfs:label "ConcreteDecorator class of the Decorator pattern"@en ,
               "Razred ConcreteDecorator vzorca Decorator"@sl ;
    rdfs:comment "Concrete Decorators define extra behaviors that can be added to components dynamically. Concrete decorators override methods of the base decorator and execute their behavior either before or after calling the parent method."@en .

:DecoratorClient rdf:type owl:NamedIndividual ,
                          :ClientClass ;
    :isAssociatedWith :DecoratorComponent ;
    rdfs:label "Client class of the Decorator pattern"@en ,
               "Razred Client vzorca Decorator"@sl ;
    rdfs:comment "The Client can wrap components in multiple layers of decorators, as long as it works with all objects via the component interface. The Client object works through ConcreteDecorator objects to extend the functionality of a Component1 object."@en .

:FacadeStructure rdf:type owl:NamedIndividual ,
                          :Structure ;
    :hasStructureElement :FacadeAdditionalFacade ,
                         :FacadeClient ,
                         :FacadeFacade ,
                         :FacadeSubsystemClass ;
    rdfs:label "Facade pattern structure"@en ,
               "Struktura vzorca Facade"@sl ;
    rdfs:comment "The Client class doesn't access the subsystem classes directly. Instead, the Client works through a Facade class that implements a simple interface in terms of (by delegating to) the subsystem classes (SubsystemClass classes). The Client depends only on the Facade interface."@en .

:FacadeClient rdf:type owl:NamedIndividual ,
                       :ClientClass ;
    :isAssociatedWith :FacadeFacade ;
    rdfs:label "Client class of the Facade pattern"@en ,
               "Razred Client vzorca Facade"@sl ;
    rdfs:comment "The Client uses the facade instead of calling the subsystem objects directly."@en .

:FacadeFacade rdf:type owl:NamedIndividual ,
                       :FacadeClass ;
    :isAssociatedWith :FacadeAdditionalFacade ;
    :dependsOn :FacadeSubsystemClass ;
    rdfs:label "Facade class of the Facade pattern"@en ,
               "Razred Facade vzorca Facade"@sl ;
    rdfs:comment "The Facade provides convenient access to a particular part of the subsystem’s functionality. It knows where to direct the client’s request and how to operate all the moving parts."@en .

:FacadeAdditionalFacade rdf:type owl:NamedIndividual ,
                                 :AdditionalFacadeClass ;
    :dependsOn :FacadeSubsystemClass ;
    rdfs:label "AdditionalFacade class of the Facade pattern"@en ,
               "Razred AdditionalFacade vzorca Facade"@sl ;
    rdfs:comment "An Additional Facade class can be created to prevent polluting a single facade with unrelated features that might make it yet another complex structure. Additional facades can be used by both clients and other facades."@en .

:FacadeSubsystemClass rdf:type owl:NamedIndividual ,
                               :SubsystemClass ;
    rdfs:label "SubsystemClass class of the Facade pattern"@en ,
               "Razred SubsystemClass vzorca Facade"@sl ;
    rdfs:comment "The Complex Subsystem consists of dozens of various objects. To make them all do something meaningful, you have to dive deep into the subsystem’s implementation details, such as initializing objects in the correct order and supplying them with data in the proper format. Subsystem classes aren’t aware of the facade’s existence. They operate within the system and work with each other directly."@en .

:FlyweightStructure rdf:type owl:NamedIndividual ,
                             :Structure ;
    :hasStructureElement :FlyweightClient ,
                         :FlyweightContext ,
                         :FlyweightFlyweight ,
                         :FlyweightFlyweightFactory ;
    rdfs:label "Flyweight pattern structure"@en ,
               "Struktura vzorca Flyweight"@sl ;
    rdfs:comment "The Flyweight pattern is merely an optimization. Before applying it, make sure your program does have the RAM consumption problem related to having a massive number of similar objects in memory at the same time. Make sure that this problem can’t be solved in any other meaningful way. (4) Usually, the behavior of the original object remains in the flyweight class. In this case, whoever calls a flyweight’s method must also pass appropriate bits of the extrinsic state into the method’s parameters. On the other hand, the behavior can be moved to the context class, which would use the linked flyweight merely as a data object."@en .

:FlyweightFlyweight rdf:type owl:NamedIndividual ,
                             :FlyweightClass ;
    :isPartOf :FlyweightFlyweightFactory ;
    rdfs:label "Flyweight class of the Flyweight pattern"@en ,
               "Razred Flyweight vzorca Flyweight"@sl ;
    rdfs:comment "The Flyweight class contains the portion of the original object’s state that can be shared between multiple objects. The same flyweight object can be used in many different contexts. The state stored inside a flyweight is called intrinsic. The state passed to the flyweight’s methods is called extrinsic."@en .

:FlyweightContext rdf:type owl:NamedIndividual ,
                           :ContextClass ;
    :isAssociatedWith :FlyweightFlyweightFactory ,
                      :FlyweightFlyweight ;
    :isWholePartOf :FlyweightClient ;
    rdfs:label "Context class of the Flyweight pattern"@en ,
               "Razred Context vzorca Flyweight"@sl ;
    rdfs:comment "The Context class contains the extrinsic state, unique across all original objects. When a context is paired with one of the flyweight objects, it represents the full state of the original object."@en .

:FlyweightFlyweightFactory rdf:type owl:NamedIndividual ,
                                    :FlyweightFactoryClass ;
    rdfs:label "FlyweightFactory class of the Flyweight pattern"@en ,
               "Razred FlyweightFactory vzorca Flyweight"@sl ;
    rdfs:comment "The Flyweight Factory manages a pool of existing flyweights. With the factory, clients don’t create flyweights directly. Instead, they call the factory, passing it bits of the intrinsic state of the desired flyweight. The factory looks over previously created flyweights and either returns an existing one that matches search criteria or creates a new one if nothing is found."@en .

:FlyweightClient rdf:type owl:NamedIndividual ,
                          :ClientClass ;
    rdfs:label "Client class of the Flyweight pattern"@en ,
               "Razred Client vzorca Flyweight"@sl ;
    rdfs:comment "The Client calculates or stores the extrinsic state of flyweights. From the client’s perspective, a flyweight is a template object which can be configured at runtime by passing some contextual data into parameters of its methods."@en .

:ProxyStructure rdf:type owl:NamedIndividual ,
                         :Structure ;
    :hasStructureElement :ProxyClient ,
                         :ProxyProxy ,
                         :ProxyService ,
                         :ProxyServiceInterface ;
    rdfs:label "Proxy pattern structure"@en ,
               "Struktura vzorca Proxy"@sl ;
    rdfs:comment "The Proxy class implements the Service interface so that it can act as a substitute for Service objects."@en .

:ProxyServiceInterface rdf:type owl:NamedIndividual ,
                                :ServiceInterface ;
    rdfs:label "ServiceInterface interface of the Proxy pattern"@en ,
               "Vmesnik ServiceInterface vzorca Proxy"@sl ;
    rdfs:comment "The Service Interface declares the interface of the Service. The proxy must follow this interface to be able to disguise itself as a service object."@en .

:ProxyService rdf:type owl:NamedIndividual ,
                       :ServiceClass ;
    :implements :ProxyServiceInterface ;
    :isPartOf :ProxyProxy ;
    rdfs:label "Service class of the Proxy pattern"@en ,
               "Razred Service vzorca Proxy"@sl ;
    rdfs:comment "The Service is a class that provides some useful business logic."@en .

:ProxyProxy rdf:type owl:NamedIndividual ,
                     :ProxyClass ;
    :implements :ProxyServiceInterface ;
    rdfs:label "Proxy class of the Proxy pattern"@en ,
               "Razred Proxy vzorca Proxy"@sl ;
    rdfs:comment "The Proxy class has a reference field that points to a service object. After the proxy finishes its processing (e.g., lazy initialization, logging, access control, caching, etc.), it passes the request to the service object. Usually, proxies manage the full lifecycle of their service objects."@en .

:ProxyClient rdf:type owl:NamedIndividual ,
                      :ClientClass ;
    :isAssociatedWith :ProxyServiceInterface ;
    rdfs:label "Client class of the Proxy pattern"@en ,
               "Razred Client vzorca Proxy"@sl ;
    rdfs:comment "The Client should work with both services and proxies via the same interface. This way you can pass a proxy into any code that expects a service object."@en .

:FactoryMethodStructure rdf:type owl:NamedIndividual ,
                                 :Structure ;
    :hasStructureElement :FactoryMethodConcreteCreator ,
                         :FactoryMethodConcreteProduct ,
                         :FactoryMethodCreator ,
                         :FactoryMethodProduct ;
    rdfs:label "FactoryMethod pattern structure"@en ,
               "Struktura vzorca FactoryMethod"@sl ;
    rdfs:comment "The Creator class that requires a Product object does not instantiate the ConcreteProduct_i class directly. Instead, the Creator refers to a separate factory method (ti. createProduct()) to create a product object, which makes the Creator independent of the exact concrete class that is instantiated.  Subclasses of Creator (ti. ConcreteCreator_i) can redefine which class to instantiate. //  Product p = createProduct(); p.doStuff();"@en .

:FactoryMethodProduct rdf:type owl:NamedIndividual ,
                               :ProductInterface ;
    rdfs:label "Product class of the FactoryMethod pattern"@en ,
               "Razred Product vzorca FactoryMethod"@sl ;
    rdfs:comment "The Product declares the interface, which is common to all objects that can be produced by the creator and its subclasses."@en .

:FactoryMethodConcreteProduct rdf:type owl:NamedIndividual ,
                                       :ConcreteProductClass ;
    :implements :FactoryMethodProduct ;
    rdfs:label "ConcreteProduct class of the FactoryMethod pattern"@en ,
               "Razred ConcreteProduct vzorca FactoryMethod"@sl ;
    rdfs:comment "Concrete Products are different implementations of the product interface."@en .

:FactoryMethodCreator rdf:type owl:NamedIndividual ,
                               :CreatorClass ;
    :dependsOn :FactoryMethodProduct ;
    rdfs:label "Creator class of the FactoryMethod pattern"@en ,
               "Razred Creator vzorca FactoryMethod"@sl ;
    rdfs:comment "The Creator class declares the factory method that returns new product objects. It’s important that the return type of this method matches the product interface. You can declare the factory method as abstract to force all subclasses to implement their own versions of the method. As an alternative, the base factory method can return some default product type. Note, despite its name, product creation is not the primary responsibility of the creator. Usually, the creator class already has some core business logic related to products. The factory method helps to decouple this logic from the concrete product classes. Here is an analogy: a large software development company can have a training department for programmers. However, the primary function of the company as a whole is still writing code, not producing programmers."@en .

:FactoryMethodConcreteCreator rdf:type owl:NamedIndividual ,
                                       :ConcreteCreatorClass ;
    :isSpecializationOf :FactoryMethodCreator ;
    rdfs:label "ConcreteCreator class of the FactoryMethod pattern"@en ,
               "Razred ConcreteCreator vzorca FactoryMethod"@sl ;
    rdfs:comment "Concrete Creators override the base factory method so it returns a different type of product. Note that the factory method doesn’t have to create new instances all the time. It can also return existing objects from a cache, an object pool, or another source."@en .

:AbstractFactoryStructure rdf:type owl:NamedIndividual ,
                                   :Structure ;
    :hasStructureElement :AbstractFactoryAbstractFactory ,
                         :AbstractFactoryAbstractProduct ,
                         :AbstractFactoryClient ,
                         :AbstractFactoryConcreteFactory ,
                         :AbstractFactoryConcreteProduct ;
    rdfs:label "AbstractFactory pattern structure"@en ,
               "Struktura vzorca AbstractFactory"@sl ;
    rdfs:comment "The Client class that requires concrete product (ti. ConcreteProduct_i) objects does not instantiate the ConcreteProduct_i classes directly. Instead, the Client refers to the AbstractFactory interface for creating objects, which makes the Client independent of how the objects are created. The ConcreteFactory_i class implements the AbstractFactory interface by instantiating the ConcreteProduct_i classes. // ProductA pA = factory.createProductA();"@en .

:AbstractFactoryClient rdf:type owl:NamedIndividual ,
                                :ClientClass ;
    :isAssociatedWith :AbstractFactoryAbstractFactory ;
    rdfs:label "Client class of the AbstractFactory pattern"@en ,
               "Razred Client vzorca AbstractFactory"@sl ;
    rdfs:comment "Although concrete factories instantiate concrete products, signatures of their creation methods must return corresponding abstract products. This way the client code that uses a factory doesn’t get coupled to the specific variant of the product it gets from a factory. The Client can work with any concrete factory/product variant, as long as it communicates with their objects via abstract interfaces."@en .

:AbstractFactoryAbstractFactory rdf:type owl:NamedIndividual ,
                                         :AbstractFactoryInterface ;
    rdfs:label "AbstractFactory interface of the AbstractFactory pattern"@en ,
               "Vmesnik AbstractFactory vzorca AbstractFactory"@sl ;
    rdfs:comment "The Abstract Factory interface declares a set of methods for creating each of the abstract products."@en .

:AbstractFactoryConcreteFactory rdf:type owl:NamedIndividual ,
                                         :ConcreteFactoryClass ;
    :implements :AbstractFactoryAbstractFactory ;
    :dependsOn :AbstractFactoryConcreteProduct ;
    rdfs:label "ConcreteFactory class of the AbstractFactory pattern"@en ,
               "Razred ConcreteFactory vzorca AbstractFactory"@sl ;
    rdfs:comment "Concrete Factories implement creation methods of the abstract factory. Each concrete factory corresponds to a specific variant of products and creates only those product variants."@en .

:AbstractFactoryAbstractProduct rdf:type owl:NamedIndividual ,
                                         :AbstractProductInterface ;
    rdfs:label "AbstractProduct interface of the AbstractFactory pattern"@en ,
               "Vmesnik AbstractProduct vzorca AbstractFactory"@sl ;
    rdfs:comment "Abstract Products declare interfaces for a set of distinct but related products which make up a product family."@en .

:AbstractFactoryConcreteProduct rdf:type owl:NamedIndividual ,
                                         :ConcreteProductClass ;
    :implements :AbstractFactoryAbstractProduct ;
    rdfs:label "ConcreteProduct class of the AbstractFactory pattern"@en ,
               "Razred ConcreteProduct vzorca AbstractFactory"@sl ;
    rdfs:comment "Concrete Products are various implementations of abstract products, grouped by variants. Each abstract product (chair/sofa) must be implemented in all given variants (Victorian/Modern)."@en .

:BuilderStructure rdf:type owl:NamedIndividual ,
                           :Structure ;
    :hasStructureElement :BuilderBuilder ,
                         :BuilderClient ,
                         :BuilderConcreteBuilder ,
                         :BuilderDirector ,
                         :BuilderProduct ;
    rdfs:label "Builder pattern structure"@en ,
               "Struktura vzorca Builder"@sl ;
    rdfs:comment "The Director class doesn't create and assemble the product (Product_i) objects directly. Instead, the Director refers to the Builder interface for building (creating and assembling) the parts of a complex object, which makes the Director independent of which concrete classes are instantiated (which representation is created). // builder = new ConcreteBuilder1(); director = new Director(builder); director.make(); Product1 p = builder.getResults();"@en .

:BuilderBuilder rdf:type owl:NamedIndividual ,
                         :BuilderInterface ;
    rdfs:label "Builder interface of the Builder pattern"@en ,
               "Vmesnik Builder vzorca Builder"@sl ;
    rdfs:comment "The Builder interface declares product construction steps that are common to all types of builders."@en .

:BuilderConcreteBuilder rdf:type owl:NamedIndividual ,
                                 :ConcreteBuilderClass ;
    :implements :BuilderBuilder ;
    :isAssociatedWith :BuilderProduct ;
    rdfs:label "ConcreteBuilder class of the Builder pattern"@en ,
               "Razred ConcreteBuilder vzorca Builder"@sl ;
    rdfs:comment "Concrete Builders provide different implementations of the construction steps. Concrete builders may produce products that don’t follow the common interface."@en .

:BuilderProduct rdf:type owl:NamedIndividual ,
                         :ProductClass ;
    rdfs:label "Product class of the Builder pattern"@en ,
               "Razred Product vzorca Builder"@sl ;
    rdfs:comment "Products are resulting objects. Products constructed by different builders don’t have to belong to the same class hierarchy or interface."@en .

:BuilderDirector rdf:type owl:NamedIndividual ,
                          :DirectorClass ;
    :isAssociatedWith :BuilderBuilder ;
    rdfs:label "Director class of the Builder pattern"@en ,
               "Razred Director vzorca Builder"@sl ;
    rdfs:comment "The Director class defines the order in which to call construction steps, so you can create and reuse specific configurations of products."@en .

:BuilderClient rdf:type owl:NamedIndividual ,
                        :ClientClass ;
    :isAssociatedWith :BuilderDirector ;
    :dependsOn :BuilderConcreteBuilder ;
    rdfs:label "Client class of the Builder pattern"@en ,
               "Razred Client vzorca Builder"@sl ;
    rdfs:comment "The Client must associate one of the builder objects with the director. Usually, it’s done just once, via parameters of the director’s constructor. Then the director uses that builder object for all further construction. However, there’s an alternative approach for when the client passes the builder object to the production method of the director. In this case, you can use a different builder each time you produce something with the director."@en .

:PrototypeStructure rdf:type owl:NamedIndividual ,
                             :Structure ;
    :hasStructureElement :PrototypeClient ,
                         :PrototypeConcretePrototype ,
                         :PrototypePrototype ,
                         :PrototypeSubclassPrototype ;
    rdfs:label "Prototype pattern structure"@en ,
               "Struktura vzorca Prototype"@sl ;
    rdfs:comment "The Client class refers to the Prototype interface for cloning a Product. The ConcretePrototype class implements the Prototype interface by creating a copy of itself. The Client object calls clone() on a prototype:ConcretePrototype object, which creates and returns a copy of itself. // copy = existing.clone();"@en .

:PrototypeClient rdf:type owl:NamedIndividual ,
                          :ClientClass ;
    :isAssociatedWith :PrototypePrototype ;
    rdfs:label "Client class of the Prototype pattern"@en ,
               "Razred Client vzorca Prototype"@sl ;
    rdfs:comment "The Client can produce a copy of any object that follows the prototype interface."@en .

:PrototypePrototype rdf:type owl:NamedIndividual ,
                             :PrototypeInterface ;
    rdfs:label "Prototype interface of the Prototype pattern"@en ,
               "Vmesnik Prototype vzorca Prototype"@sl ;
    rdfs:comment "The Prototype interface declares the cloning methods. In most cases, it’s a single clone method."@en .

:PrototypeConcretePrototype rdf:type owl:NamedIndividual ,
                                     :ConcretePrototypeClass ;
    :implements :PrototypePrototype ;
    rdfs:label "ConcretePrototype class of the Prototype pattern"@en ,
               "Razred ConcretePrototype vzorca Prototype"@sl ;
    rdfs:comment "The Concrete Prototype class implements the cloning method. In addition to copying the original object’s data to the clone, this method may also handle some edge cases of the cloning process related to cloning linked objects, untangling recursive dependencies, etc."@en .

:PrototypeSubclassPrototype rdf:type owl:NamedIndividual ,
                                     :SubclassPrototypeClass ;
    :isSpecializationOf :PrototypeConcretePrototype ;
    rdfs:label "SubclassPrototype class of the Prototype pattern"@en ,
               "Razred SubclassPrototype vzorca Prototype"@sl ;
    rdfs:comment "The SubclassPrototype class overrides the cloning method, and takes care of the attributes of SubclassPrototype."@en .

:SingletonStructure rdf:type owl:NamedIndividual ,
                             :Structure ;
    :hasStructureElement :SingletonClient ,
                         :SingletonSingleton ;
    rdfs:label "Singleton pattern structure"@en ,
               "Struktura vzorca Singleton"@sl ;
    rdfs:comment "Singleton structure. Key Component of Singleton Design Pattern: 1) static member within the class, 2) private constructor, which serves as a barricade against external attempts to create instances of the Singleton class, 3) private constructor, which serves as a barricade against external attempts to create instances of the Singleton class. (source: www.geeksforgeeks.org)"@en .

:SingletonClient rdf:type owl:NamedIndividual ,
                          :ClientClass ;
    :isAssociatedWith :SingletonSingleton ;
    rdfs:label "Client class of the Singleton pattern"@en ,
               "Razred Client vzorca Singleton"@sl ;
    rdfs:comment "Client is ensured that only one instance of a class exists in our application. Useful when we want to provide a straightforward way for clients to access that instance from a specific location in your code."@en .

:SingletonSingleton rdf:type owl:NamedIndividual ,
                             :SingletonClass ;
    :isAssociatedWith :SingletonSingleton ;
    rdfs:label "Singleton class of the Singleton pattern"@en ,
               "Razred Singleton vzorca Singleton"@sl ;
    rdfs:comment "The Singleton class declares the static method getInstance that returns the same instance of its own class. The Singleton’s constructor should be hidden from the client code. Calling the getInstance method should be the only way of getting the Singleton object."@en .

:ChainOfResponsibilityStructure rdf:type owl:NamedIndividual ,
                                         :Structure ;
    :hasStructureElement :ChainOfResponsibilityBaseHandler ,
                         :ChainOfResponsibilityClient ,
                         :ChainOfResponsibilityConcreteHandler ,
                         :ChainOfResponsibilityHandler ;
    rdfs:label "ChainofResponsibility pattern structure"@en ,
               "Struktura vzorca ChainofResponsibility"@sl ;
    rdfs:comment "The Sender (ti. ConcreteHandler) class doesn't refer to a particular receiver class directly. Instead, Sender refers to the Handler interface for handling a request (handler.handle(request)), which makes the Sender independent of which receiver (ti. ConcreteHandler) handles the request."@en .

:ChainOfResponsibilityHandler rdf:type owl:NamedIndividual ,
                                       :HandlerInterface ;
    :isPartOf :ChainOfResponsibilityBaseHandler ;
    rdfs:label "Handler interface of the ChainofResponsibility pattern"@en ,
               "Vmesnik Handler vzorca ChainofResponsibility"@sl ;
    rdfs:comment "The Handler declares the interface, common for all concrete handlers. It usually contains just a single method for handling requests, but sometimes it may also have another method for setting the next handler on the chain."@en .

:ChainOfResponsibilityBaseHandler rdf:type owl:NamedIndividual ,
                                           :BaseHandlerClass ;
    :implements :ChainOfResponsibilityHandler ;
    rdfs:label "BaseHandler class of the ChainofResponsibility pattern"@en ,
               "Razred BaseHandler vzorca ChainofResponsibility"@sl ;
    rdfs:comment "The Base Handler is an optional class where you can put the boilerplate code that’s common to all handler classes. Usually, this class defines a field for storing a reference to the next handler. The clients can build a chain by passing a handler to the constructor or setter of the previous handler. The class may also implement the default handling behavior: it can pass execution to the next handler after checking for its existence."@en .

:ChainOfResponsibilityConcreteHandler rdf:type owl:NamedIndividual ,
                                               :ConcreteHandlerClass ;
    :isSpecializationOf :ChainOfResponsibilityBaseHandler ;
    rdfs:label "ConcreteHandler class of the ChainofResponsibility pattern"@en ,
               "Razred ConcreteHandler vzorca ChainofResponsibility"@sl ;
    rdfs:comment "Concrete Handlers contain the actual code for processing requests. Upon receiving a request, each handler must decide whether to process it and, additionally, whether to pass it along the chain. Handlers are usually self-contained and immutable, accepting all necessary data just once via the constructor."@en .

:ChainOfResponsibilityClient rdf:type owl:NamedIndividual ,
                                      :ClientClass ;
    :isAssociatedWith :ChainOfResponsibilityHandler ;
    rdfs:label "Client class of the ChainofResponsibility pattern"@en ,
               "Razred Client vzorca ChainofResponsibility"@sl ;
    rdfs:comment "The Client may compose chains just once or compose them dynamically, depending on the application’s logic. Note that a request can be sent to any handler in the chain—it doesn’t have to be the first one."@en .

:CommandStructure rdf:type owl:NamedIndividual ,
                           :Structure ;
    :hasStructureElement :CommandClient ,
                         :CommandCommand ,
                         :CommandConcreteCommand ,
                         :CommandInvoker ,
                         :CommandReceiver ;
    rdfs:label "Command pattern structure"@en ,
               "Struktura vzorca Command"@sl ;
    rdfs:comment "The Invoker class doesn't implement a request directly. Instead, Invoker refers to the Command interface to perform a request (command.execute()), which makes the Invoker independent of how the request is performed. The concrete comamnd (ti. ConcreteCommand_i) class implements the Command interface by performing an action on a receiver (receiver1.operation_i(a, b, c)). The Invoker object calls execute() on a ConcreteCommand_i object. ConcreteCommand_i calls operation_i(a, b, c) on a Receiver_i object, which performs the request. (source: Wikipedia) // copy = new CopyCommand(editor); button.setCommand(copy);"@en .

:CommandClient rdf:type owl:NamedIndividual ,
                        :ClientClass ;
    :isAssociatedWith :CommandInvoker ,
                      :CommandConcreteCommand ;
    :dependsOn :CommandReceiver ;
    rdfs:label "Client class of the Command pattern"@en ,
               "Razred Client vzorca Command"@sl ;
    rdfs:comment "The Client creates and configures concrete command objects. The client must pass all of the request parameters, including a receiver instance, into the command’s constructor. After that, the resulting command may be associated with one or multiple senders."@en .

:CommandInvoker rdf:type owl:NamedIndividual ,
                         :InvokerClass ;
    :isAssociatedWith :CommandCommand ;
    rdfs:label "Invoker class of the Command pattern"@en ,
               "Razred Invoker vzorca Command"@sl ;
    rdfs:comment "The Sender class (aka invoker) is responsible for initiating requests. This class must have a field for storing a reference to a command object. The sender triggers that command instead of sending the request directly to the receiver. Note that the sender isn’t responsible for creating the command object. Usually, it gets a pre-created command from the client via the constructor."@en .

:CommandCommand rdf:type owl:NamedIndividual ,
                         :CommandInterface ;
    rdfs:label "Command interface of the Command pattern"@en ,
               "Vmesnik Command vzorca Command"@sl ;
    rdfs:comment "The Command interface usually declares just a single method for executing the command."@en .

:CommandConcreteCommand rdf:type owl:NamedIndividual ,
                                 :ConcreteCommandClass ;
    :isAssociatedWith :CommandReceiver ;
    :implements :CommandCommand ;
    rdfs:label "ConcreteCommand class of the Command pattern"@en ,
               "Razred ConcreteCommand vzorca Command"@sl ;
    rdfs:comment "Concrete Commands implement various kinds of requests. A concrete command isn’t supposed to perform the work on its own, but rather to pass the call to one of the business logic objects. However, for the sake of simplifying the code, these classes can be merged. Parameters required to execute a method on a receiving object can be declared as fields in the concrete command. You can make command objects immutable by only allowing the initialization of these fields via the constructor."@en .

:CommandReceiver rdf:type owl:NamedIndividual ,
                          :ReceiverClass ;
    rdfs:label "Receiver class of the Command pattern"@en ,
               "Razred Receiver vzorca Command"@sl ;
    rdfs:comment "The Receiver class contains some business logic. Almost any object may act as a receiver. Most commands only handle the details of how a request is passed to the receiver, while the receiver itself does the actual work."@en .

:IteratorStructure rdf:type owl:NamedIndividual ,
                            :Structure ;
    :hasStructureElement :IteratorClient ,
                         :IteratorConcreteCollection ,
                         :IteratorConcreteIterator ,
                         :IteratorIterableCollection ,
                         :IteratorIterator ;
    rdfs:label "Iterator pattern structure"@en ,
               "Struktura vzorca Iterator"@sl ;
    rdfs:comment "The Client class refers (1) to the IterableCollection interface for creating an Iterator object (IterableCollection::createIterator()) and (2) to the Iterator interface for traversing an IterableCollection object (getNext(), hasMore()). The ConcreteIterator_i class implements the Iterator interface by accessing the ConcreteCollection_i class."@en .

:IteratorClient rdf:type owl:NamedIndividual ,
                         :ClientClass ;
    :isAssociatedWith :IteratorIterator ,
                      :IteratorIterableCollection ;
    rdfs:label "Client class of the Iterator pattern"@en ,
               "Razred Client vzorca Iterator"@sl ;
    rdfs:comment "The Client works with both collections and iterators via their interfaces. This way the client isn’t coupled to concrete classes, allowing you to use various collections and iterators with the same client code. Typically, clients don’t create iterators on their own, but instead get them from collections. Yet, in certain cases, the client can create one directly; for example, when the client defines its own special iterator."@en .

:IteratorIterator rdf:type owl:NamedIndividual ,
                           :IteratorInterface ;
    rdfs:label "Iterator interface of the Iterator pattern"@en ,
               "Vmesnik Iterator vzorca Iterator"@sl ;
    rdfs:comment "The Iterator interface declares the operations required for traversing a collection: fetching the next element, retrieving the current position, restarting iteration, etc."@en .

:IteratorConcreteIterator rdf:type owl:NamedIndividual ,
                                   :ConcreteIteratorClass ;
    :implements :IteratorIterator ;
    :isAssociatedWith :IteratorConcreteCollection ;
    rdfs:label "ConcreteIterator class of the Iterator pattern"@en ,
               "Razred ConcreteIterator vzorca Iterator"@sl ;
    rdfs:comment "Concrete Iterators implement specific algorithms for traversing a collection. The iterator object should track the traversal progress on its own. This allows several iterators to traverse the same collection independently of each other."@en .

:IteratorIterableCollection rdf:type owl:NamedIndividual ,
                                     :IterableCollectionInterface ;
    :dependsOn :IteratorIterator ;
    rdfs:label "IterableCollection interface of the Iterator pattern"@en ,
               "Vmesnik IterableCollection vzorca Iterator"@sl ;
    rdfs:comment "The Collection interface declares one or multiple methods for getting iterators compatible with the collection. Note that the return type of the methods must be declared as the iterator interface so that the concrete collections can return various kinds of iterators."@en .

:IteratorConcreteCollection rdf:type owl:NamedIndividual ,
                                     :ConcreteCollectionClass ;
    :implements :IteratorIterableCollection ;
    :isAssociatedWith :IteratorConcreteIterator ;
    rdfs:label "ConcreteCollection class of the Iterator pattern"@en ,
               "Razred ConcreteCollection vzorca Iterator"@sl ;
    rdfs:comment "Concrete Collections return new instances of a particular concrete iterator class each time the client requests one. You might be wondering, where’s the rest of the collection’s code? Don’t worry, it should be in the same class. It’s just that these details aren’t crucial to the actual pattern, so we’re omitting them."@en .

:MediatorStructure rdf:type owl:NamedIndividual ,
                            :Structure ;
    :hasStructureElement :MediatorComponent ,
                         :MediatorConcreteMediator ,
                         :MediatorMediator ;
    rdfs:label "Mediator pattern structure"@en ,
               "Struktura vzorca Mediator"@sl ;
    rdfs:comment "The Component (Component_i) classes do not refer to (and update) each other directly. Instead, they refer to the common Mediator interface for controlling and coordinating interaction (Mediator::notify(sender)). Components must not be aware of other components. If something important happens within or to a component, it must only notify the mediator. When the mediator receives the notification, it can easily identify the sender, which might be just enough to decide what component should be triggered in return. From a component’s perspective, it all looks like a total black box. The sender doesn’t know who’ll end up handling its request, and the receiver doesn’t know who sent the request in the first place. //  if (sender == componentA) reactOnA();"@en .

:MediatorMediator rdf:type owl:NamedIndividual ,
                           :MediatorInterface ;
    rdfs:label "Mediator interface of the Mediator pattern"@en ,
               "Vmesnik Mediator vzorca Mediator"@sl ;
    rdfs:comment "The Mediator interface declares methods of communication with components, which usually include just a single notification method. Components may pass any context as arguments of this method, including their own objects, but only in such a way that no coupling occurs between a receiving component and the sender’s class."@en .

:MediatorConcreteMediator rdf:type owl:NamedIndividual ,
                                   :ConcreteMediatorClass ;
    :implements :MediatorMediator ;
    rdfs:label "ConcreteMediator class of the Mediator pattern"@en ,
               "Razred ConcreteMediator vzorca Mediator"@sl ;
    rdfs:comment "Concrete Mediators encapsulate relations between various components. Concrete mediators often keep references to all components they manage and sometimes even manage their lifecycle."@en .

:MediatorComponent rdf:type owl:NamedIndividual ,
                            :ComponentClass ;
    :isAssociatedWith :MediatorMediator ;
    :isWholePartOf :MediatorConcreteMediator ;
    rdfs:label "Component class of the Mediator pattern"@en ,
               "Razred Component vzorca Mediator"@sl ;
    rdfs:comment "Components are various classes that contain some business logic. Each component has a reference to a mediator, declared with the type of the mediator interface. The component isn’t aware of the actual class of the mediator, so you can reuse the component in other programs by linking it to a different mediator."@en .

:MementoStructure rdf:type owl:NamedIndividual ,
                           :Structure ;
    :hasStructureElement :MementoCaretaker ,
                         :MementoConcreteMemento ,
                         :MementoConcreteOriginator ,
                         :MementoMemento ,
                         :MementoOriginator ;
    rdfs:label "Memento pattern structure"@en ,
               "Struktura vzorca Memento"@sl ;
    rdfs:comment "[Implementation based on an intermediate interface; with even strict encapsulation]. This implementation is useful when we don’t want to leave even the slightest chance of other classes accessing the state of the originator through the memento. This implementation allows having multiple types of originators and mementos. Each originator works with a corresponding memento class. Neither originators nor mementos expose their state to anyone."@en .

:MementoOriginator rdf:type owl:NamedIndividual ,
                            :OriginatorInterface ;
    :dependsOn :MementoMemento ;
    rdfs:label "Originator interface of the Memento pattern"@en ,
               "Vmesnik Originator vzorca Memento"@sl ;
    rdfs:comment "The Originator interface can produce snapshots of its own state, as well as restore its state from snapshots when needed."@en .

:MementoMemento rdf:type owl:NamedIndividual ,
                         :MementoInterface ;
    :isPartOf :MementoCaretaker ;
    rdfs:label "Memento interface of the Memento pattern"@en ,
               "Vmesnik Memento vzorca Memento"@sl ;
    rdfs:comment "The Memento is a value object that acts as a snapshot of the originator’s state. It’s a common practice to make the memento immutable and pass it the data only once, via the constructor."@en .

:MementoCaretaker rdf:type owl:NamedIndividual ,
                           :CaretakerClass ;
    rdfs:label "Caretaker class of the Memento pattern"@en ,
               "Razred Caretaker vzorca Memento"@sl ;
    rdfs:comment "The Caretaker knows not only “when” and “why” to capture the originator’s state, but also when the state should be restored. A caretaker can keep track of the originator’s history by storing a stack of mementos. When the originator has to travel back in history, the caretaker fetches the topmost memento from the stack and passes it to the originator’s restoration method. Caretakers are now explicitly restricted from changing the state stored in mementos. Moreover, the caretaker class becomes independent from the originator because the restoration method is now defined in the memento class."@en .

:MementoConcreteMemento rdf:type owl:NamedIndividual ,
                                 :ConcreteMementoClass ;
    :implements :MementoMemento ;
    :isAssociatedWith :MementoConcreteOriginator ;
    rdfs:label "ConcreteMemento class of the Memento pattern"@en ,
               "Razred ConcreteMemento vzorca Memento"@sl ;
    rdfs:comment "Each memento becomes linked to the originator that produced it. The originator passes itself to the memento’s constructor, along with the values of its state. Thanks to the close relationship between these classes, a memento can restore the state of its originator, given that the latter has defined the appropriate setters."@en .

:MementoConcreteOriginator rdf:type owl:NamedIndividual ,
                                    :ConcreteOriginatorClass ;
    :implements :MementoOriginator ;
    :isAssociatedWith :MementoConcreteMemento ;
    rdfs:label "ConcreteOriginator class of the Memento pattern"@en ,
               "Razred ConcreteOriginator vzorca Memento"@sl ;
    rdfs:comment "Implements Originator interface."@en .

:ObserverStructure rdf:type owl:NamedIndividual ,
                            :Structure ;
    :hasStructureElement :ObserverClient ,
                         :ObserverConcreteSubscriber ,
                         :ObserverPublisher ,
                         :ObserverSubscriber ;
    rdfs:label "Observer pattern structure"@en ,
               "Struktura vzorca Observer"@sl ;
    rdfs:comment "The Subject class (ie. Publisher) does not update the state of dependent objects directly. Instead, Subject (Publisher) refers to the Observer (ie. Subscriber) interface (Subscriber::update(context)) for updating state, which makes the Subject independent of how the state of dependent objects (ie. ConcreteSubscriber_i) is updated. (2) When a new event happens, the publisher goes over the subscription list and calls the notification method declared in the subscriber interface on each subscriber object. (5) Usually, subscribers need some contextual information to handle the update correctly. For this reason, publishers often pass some context data as arguments of the notification method. The publisher can pass itself as an argument, letting subscriber fetch any required data directly."@en .

:ObserverSubscriber rdf:type owl:NamedIndividual ,
                             :SubscriberInterface ;
    :isPartOf :ObserverPublisher ;
    rdfs:label "Subscriber interface of the Observer pattern"@en ,
               "Vmesnik Subscriber vzorca Observer"@sl ;
    rdfs:comment "The Subscriber interface declares the notification interface. In most cases, it consists of a single update method. The method may have several parameters that let the publisher pass some event details along with the update."@en .

:ObserverPublisher rdf:type owl:NamedIndividual ,
                            :PublisherClass ;
    rdfs:label "Publisher class of the Observer pattern"@en ,
               "Razred Publisher vzorca Observer"@sl ;
    rdfs:comment "The Publisher issues events of interest to other objects. These events occur when the publisher changes its state or executes some behaviors. Publishers contain a subscription infrastructure that lets new subscribers join and current subscribers leave the list."@en .

:ObserverConcreteSubscriber rdf:type owl:NamedIndividual ,
                                     :ConcreteSubscriberClass ;
    :implements :ObserverSubscriber ;
    rdfs:label "ConcreteSubscriber class of the Observer pattern"@en ,
               "Razred ConcreteSubscriber vzorca Observer"@sl ;
    rdfs:comment "Concrete Subscribers perform some actions in response to notifications issued by the publisher. All of these classes must implement the same interface so the publisher isn’t coupled to concrete classes."@en .

:ObserverClient rdf:type owl:NamedIndividual ,
                         :ClientClass ;
    :isAssociatedWith :ObserverPublisher ;
    :dependsOn :ObserverConcreteSubscriber ;
    rdfs:label "Client class of the Observer pattern"@en ,
               "Razred Client vzorca Observer"@sl ;
    rdfs:comment "The Client creates publisher and subscriber objects separately and then registers subscribers for publisher updates."@en .

:StateStructure rdf:type owl:NamedIndividual ,
                         :Structure ;
    :hasStructureElement :StateClient ,
                         :StateConcreteState ,
                         :StateContext ,
                         :StateState ;
    rdfs:label "State pattern structure"@en ,
               "Struktura vzorca State"@sl ;
    rdfs:comment "The Context class doesn't implement state-specific behavior directly. Instead, Context refers to the State interface for performing state-specific behavior (state.handle()), which makes Context independent of how state-specific behavior is implemented. The concrete state (ConcreteState_i) classes implement the State interface, that is, implement (encapsulate) the state-specific behavior for each state. (source: Wikipedia) (4) Both context and concrete states can set the next state of the context and perform the actual state transition by replacing the state object linked to the context."@en .

:StateState rdf:type owl:NamedIndividual ,
                     :StateInterface ;
    :isPartOf :StateContext ;
    rdfs:label "State interface of the State pattern"@en ,
               "Vmesnik State vzorca State"@sl ;
    rdfs:comment "The State interface declares the state-specific methods. These methods should make sense for all concrete states because you don’t want some of your states to have useless methods that will never be called."@en .

:StateConcreteState rdf:type owl:NamedIndividual ,
                             :ConcreteStateClass ;
    :implements :StateState ;
    :isAssociatedWith :StateContext ;
    rdfs:label "ConcreteState class of the State pattern"@en ,
               "Razred ConcreteState vzorca State"@sl ;
    rdfs:comment "Concrete States provide their own implementations for the state-specific methods. To avoid duplication of similar code across multiple states, you may provide intermediate abstract classes that encapsulate some common behavior. State objects may store a backreference to the context object. Through this reference, the state can fetch any required info from the context object, as well as initiate state transitions."@en .

:StateContext rdf:type owl:NamedIndividual ,
                       :ContextClass ;
    rdfs:label "Context class of the State pattern"@en ,
               "Razred Context vzorca State"@sl ;
    rdfs:comment "Context stores a reference to one of the concrete state objects and delegates to it all state-specific work. The context communicates with the state object via the state interface. The context exposes a setter for passing it a new state object."@en .

:StateClient rdf:type owl:NamedIndividual ,
                      :ClientClass ;
    :dependsOn :StateConcreteState ;
    :isAssociatedWith :StateContext ;
    rdfs:label "Client class of the State pattern"@en ,
               "Razred Client vzorca State"@sl ;
    rdfs:comment "// initialState = new ConcreteState(); context = new Context(initialState); context.toThis(); // Current state may have been changed by // context or the state object itself."@en .

:StrategyStructure rdf:type owl:NamedIndividual ,
                            :Structure ;
    :hasStructureElement :StrategyClient ,
                         :StrategyConcreteStrategy ,
                         :StrategyContext ,
                         :StrategyStrategy ;
    rdfs:label "Strategy pattern structure"@en ,
               "Struktura vzorca Strategy"@sl ;
    rdfs:comment "The Context class does not implement an algorithm directly. Instead, Context refers to the Strategy interface for performing an algorithm (strategy.execute(data)), which makes Context independent of how an algorithm is implemented. The concrete strategy (ConcreteStrategy_i) classes implement the Strategy interface, that is, implement (encapsulate) an algorithm. (source: Wikipedia) (4) The context calls the execution method on the linked strategy object each time it needs to run the algorithm. The context doesn’t know what type of strategy it works with or how the algorithm is executed."@en .

:StrategyStrategy rdf:type owl:NamedIndividual ,
                           :StrategyInterface ;
    :isPartOf :StrategyContext ;
    rdfs:label "Strategy interface of the Strategy pattern"@en ,
               "Vmesnik Strategy vzorca Strategy"@sl ;
    rdfs:comment "The Strategy interface is common to all concrete strategies. It declares a method the context uses to execute a strategy."@en .

:StrategyContext rdf:type owl:NamedIndividual ,
                          :ContextClass ;
    rdfs:label "Context class of the Strategy pattern"@en ,
               "Razred Context vzorca Strategy"@sl ;
    rdfs:comment "The Context maintains a reference to one of the concrete strategies and communicates with this object only via the strategy interface. strategy.execute();"@en .

:StrategyConcreteStrategy rdf:type owl:NamedIndividual ,
                                   :ConcreteStrategyClass ;
    :implements :StrategyStrategy ;
    rdfs:label "ConcreteStrategy class of the Strategy pattern"@en ,
               "Razred ConcreteStrategy vzorca Strategy"@sl ;
    rdfs:comment "Concrete Strategies implement different variations of an algorithm the context uses."@en .

:StrategyClient rdf:type owl:NamedIndividual ,
                         :ClientClass ;
    :isAssociatedWith :StrategyContext ;
    :dependsOn :StrategyStrategy ;
    rdfs:label "Client class of the Strategy pattern"@en ,
               "Razred Client vzorca Strategy"@sl ;
    rdfs:comment "The Client creates a specific strategy object and passes it to the context. The context exposes a setter which lets clients replace the strategy associated with the context at runtime. str = new SomeStrategy(); context.setStrategy(str); context.doSomething();"@en .

:TemplateMethodStructure rdf:type owl:NamedIndividual ,
                                  :Structure ;
    :hasStructureElement :TemplateMethodAbstractClass ,
                         :TemplateMethodConcreteClass ;
    rdfs:label "TemplateMethod pattern structure"@en ,
               "Struktura vzorca TemplateMethod"@sl ;
    rdfs:comment "Template Method pattern provides a skeleton. The AbstractClass defines a templateMethod() operation that defines the skeleton (template) of a behavior by 1) implementing the invariant parts of the behavior and 2) sending to self the messages step_1() ..., and step_i() , which, because they are implemented in concrete classes (ConcreteClass_i), allow that subclass to provide a variant implementation of those parts of the algorithm. (source: Wikipedia)"@en .

:TemplateMethodAbstractClass rdf:type owl:NamedIndividual ,
                                      :AbstractClass ;
    rdfs:label "AbstractClass class of the TemplateMethod pattern"@en ,
               "Razred AbstractClass vzorca TemplateMethod"@sl ;
    rdfs:comment "The Abstract Class declares methods that act as steps of an algorithm, as well as the actual template method which calls these methods in a specific order. The steps may either be declared abstract or have some default implementation."@en .

:TemplateMethodConcreteClass rdf:type owl:NamedIndividual ,
                                      :ConcreteClass ;
    :isSpecializationOf :TemplateMethodAbstractClass ;
    rdfs:label "ConcreteClass class of the TemplateMethod pattern"@en ,
               "Razred ConcreteClass vzorca TemplateMethod"@sl ;
    rdfs:comment "Concrete Classes can override all of the steps, but not the template method itself."@en .

:VisitorStructure rdf:type owl:NamedIndividual ,
                           :Structure ;
    :hasStructureElement :VisitorClient ,
                         :VisitorConcreteElement ,
                         :VisitorConcreteVisitor ,
                         :VisitorElement ,
                         :VisitorVisitor ;
    rdfs:label "Visitor pattern structure"@en ,
               "Struktura vzorca Visitor"@sl ;
    rdfs:comment "The Element (Element_i) class doesn't implement a new operation directly. Instead, Element_i implements a dispatching operation element.accept(visitor) that 'dispatches' (delegates) a request to the 'accepted visitor object' (visitor.visit(this: Element_i)). The Visitor (ConcreteVisitor_i) class implements the operation (concreteVisitor.visit(e: Element_i)). Element (Element_i) then implements element_i.accept(v: Visitor) by dispatching to visitor.visit(this: Element_i) The Visitor (ConcreteVisitor_i) class implements the operation (concreteVisitor.visit(e: Element_i))."@en .

:VisitorVisitor rdf:type owl:NamedIndividual ,
                         :VisitorInterface ;
    :dependsOn :VisitorConcreteElement ;
    rdfs:label "Visitor interface of the Visitor pattern"@en ,
               "Vmesnik Visitor vzorca Visitor"@sl ;
    rdfs:comment "The Visitor interface declares a set of visiting methods that can take concrete elements of an object structure as arguments. These methods may have the same names if the program is written in a language that supports overloading, but the type of their parameters must be different."@en .

:VisitorElement rdf:type owl:NamedIndividual ,
                         :ElementInterface ;
    :dependsOn :VisitorVisitor ;
    rdfs:label "Element class of the Visitor pattern"@en ,
               "Razred Element vzorca Visitor"@sl ;
    rdfs:comment "The Element interface declares a method for “accepting” visitors. This method should have one parameter declared with the type of the visitor interface."@en .

:VisitorConcreteVisitor rdf:type owl:NamedIndividual ,
                                 :ConcreteVisitorClass ;
    :implements :VisitorVisitor ;
    rdfs:label "ConcreteVisitor class of the Visitor pattern"@en ,
               "Razred ConcreteVisitor vzorca Visitor"@sl ;
    rdfs:comment "Each Concrete Visitor implements several versions of the same behaviors, tailored for different concrete element classes."@en .

:VisitorConcreteElement rdf:type owl:NamedIndividual ,
                                 :ConcreteElementClass ;
    :implements :VisitorElement ;
    rdfs:label "ConcreteElement class of the Visitor pattern"@en ,
               "Razred ConcreteElement vzorca Visitor"@sl ;
    rdfs:comment "Each Concrete Element must implement the acceptance method. The purpose of this method is to redirect the call to the proper visitor’s method corresponding to the current element class. Be aware that even if a base element class implements this method, all subclasses must still override this method in their own classes and call the appropriate method on the visitor object."@en .

:VisitorClient rdf:type owl:NamedIndividual ,
                        :ClientClass ;
    :dependsOn :VisitorConcreteVisitor ,
               :VisitorElement ;
    rdfs:label "Client class of the Visitor pattern"@en ,
               "Razred Client vzorca Visitor"@sl ;
    rdfs:comment "The Client usually represents a collection or some other complex object (for example, a Composite tree). Usually, clients aren’t aware of all the concrete element classes because they work with objects from that collection via some abstract interface. element.accept(new ConcreteVisitor());"@en .

:AbstractFactory rdf:type owl:NamedIndividual ,
                          :CreationalPattern ;
    :hasStructure :AbstractFactoryStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/jLLBZvim4BxpAqRf8OyAf29Lgj9jf3NjIZsrKc_LNXmmYHSoHeCXscpxtslp2WiapQ6z8EkRcU-RXyVCdJdSRtDDFDJmO3wAdZ_23qr5g0iIpjnnyaHYneaV84nvdiEB0x3bOR8ZLM0Kg5GH7FTI2uihYWJLs9lt3-p3by2Wd4WTQt2RcaZdTvyLbHOta8OLjYF-RA1OeGxEm2k-CqqTOch3t9W4QiVKCuVF8fOeG_d4OPVo4kKUY9z8HAe4YL0UH8uoKQKjFgXAda6GIXDl3ZnlppPb5-AwP-kkYqqJhT5rpVTjux-8HpxBofohW_YM2U9QAbmiRJ5VKGiopC883cBg58RWtPt9l8tPREhS6lcG1DVYEwd8pFH-iLn3UnwRMS_CR2PT_GgDenQDuBkc4qFKwdgUzv_L_Kbr_r-hytOlwdi_Qvl-YD3HmEjvTF3BZGHice3L14tzRQ5zuS44ElXQZ3yTuryJOjD2x9eGcnPY_d3zCbMA4syMhLegDnMnTZUZRHhTD2zIH_H-_TNJ1w_8hlcT6-fQIhVdsjsLKSV0BR9RFDbbLZRolSJAd8doRP-ypTJyH_LVSFLlPcMtivePLqF-oK_83ucq3sfY7ZZKd9wa7NJrt6kLWOhRbzJfxLF6uLFxg7h3zNK4HjN_eg4XkTlhYcYGtdezkxpwCwEtMXdtWX1G75UhSM_wMdy0"^^xsd:anyURI ;
    :canBeDevelopedFrom :FactoryMethod ;
    :canBeImplementedAs :Singleton ;
    :canBeUsedWith :Bridge ;
    :canServeAsAlternative :Facade ;
    :differsInAspectsFrom :Builder ;
    :hasPro :LooseCoupling ,
            :OpenClosedPrinciple ,
            :ProductsCompatibility ,
            :SingleResponsibilityPrinciple ;
    :isFocusedOn :FamiliesOfObjects ;
    :intent "Abstract Factory is a creational design pattern that lets you produce families of related objects without specifying their concrete classes."@en ;
    rdfs:comment "The abstract factory is a design pattern that provides a way to create families of related objects without imposing their concrete classes, by encapsulating a group of individual factories that have a common theme without specifying their concrete classes. A client creates a concrete implementation of the abstract factory and then uses the generic interface of the factory to create the concrete objects that are part of the family. The client does not know which concrete objects it receives from each of these internal factories, as it uses only the generic interfaces of their products."@en ,
                 "Abstraktna tovarna je načrtovalski vzorec, ki omogoča ustvarjanje družin povezanih objektov brez vsiljenja njihovih konkretnih razredov, tako da enkapsulira skupino posameznih tovarn, ki imajo skupno temo, ne da bi določil njihove konkretne razrede. Odjemalec ustvari konkretno implementacijo abstraktne tovarne in nato uporabi generični vmesnik tovarne za ustvarjanje konkretnih objektov, ki so del družine. Odjemalec ne ve, katere konkretne objekte prejme od vsake od teh notranjih tovarn, saj uporablja le generične vmesnike njihovih izdelkov."@sl ;
    rdfs:label "Abstract Factory"@en ,
               "Abstraktna tovarna"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/abstract-factory"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :AbstractFactory ;
    owl:annotatedProperty :canBeDevelopedFrom ;
    owl:annotatedTarget :FactoryMethod ;
    rdfs:comment "Factory Method is less complicated and more customizable via subclasses; while AbstractFactory is more flexible, but more complicated."@en ,
                 "Veliko načrtov programske kode lahko začnemo z vzorcem FactoryMethod (preprosto, prilagodljivost preko podrazredov) --> evolucija v vzorec Abstract Factory."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :AbstractFactory ;
    owl:annotatedProperty :canBeImplementedAs ;
    owl:annotatedTarget :Singleton ;
    rdfs:comment "Combining these two patterns would involve using AbstractFactory to create a singleton instance which means the same instance will be returned by Factory."@en ,
                 "Združevanje teh dveh vzorcev vključuje uporabo vzorca AbstractFactory za ustvarjanje enojnega primerka razreda Concrete Factory, kar pomeni, da bo Factory (Concrete Factory) vrnil isti primerek objekta."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :AbstractFactory ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Bridge ;
    rdfs:comment "Potencialno uporabno, ko je vzorec Bridge kot osnova; in ko lahko nekatere abstrakcije (razred Abstraction), definirane z vzorcem Bridge, delujejo samo s posebnimi implementacijami (vmesnik Implementation). V tem primeru lahko z vzorcem AbstractFactory zajamemo te relacije in skrijemo kompleksnost pred odjemalcem (class Client)."@sl ,
                 "This pairing is useful when some abstractions defined by Bridge can only work with specific implementations. In this case, Abstract Factory can encapsulate these relations and hide the complexity from the client code."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :AbstractFactory ;
    owl:annotatedProperty :canServeAsAlternative ;
    owl:annotatedTarget :Facade ;
    rdfs:comment "Abstract Factory can serve as an alternative to Facade when you only want to hide the way the subsystem objects are created from the client code. Sample: (AbstractFactory) Button button = factory.createButton(); (Facade) VideoConversionFacade converter = new VideoConversionFacade(); File mp4Video = converter.convertVideo('youtubevideo.ogg', 'mp4');."@en ,
                 "Vzorec AbstractFactory je lahko alternativa za vzorec Facade, ko želimo pred odjemalcem skriti način, kako so dejansko kreirani objekti podsistema. Primer: (AbstractFactory) Button button = factory.createButton(); (Facade) VideoConversionFacade converter = new VideoConversionFacade(); File mp4Video = converter.convertVideo('youtubevideo.ogg', 'mp4');."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :AbstractFactory ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Builder ;
    rdfs:comment "Abstract Factory returns the product immediately, whereas Builder lets you run some additional construction steps before fetching the product."@en ,
                 "Vzorec AbstractFactory takoj vrne končni objekt (vmesnika tipa Izdelek), medtem ko pri vzorcu tipa Builder lahko pri kreiranju objekta (Izdelka) izvedemo nekaj dodatnih korakov, preden vrnemo končni objekt (vmesnika tipa Izdelek)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :AbstractFactory ;
    owl:annotatedProperty :isFocusedOn ;
    owl:annotatedTarget :FamiliesOfObjects ;
    rdfs:comment "Abstract Factory specializes in creating families of related objects."@en ,
                 "Vzorec AbstractFactory se osredotoča na kreiranje družin med seboj povezanih objektov."@sl
] .

:Abstraction rdf:type owl:NamedIndividual ,
                      :OOConcept ;
    rdfs:label "Abstraction"@en ,
               "Abstrakcija"@sl .

:Adapter rdf:type owl:NamedIndividual ,
                  :StructuralPattern ;
    :hasStructure :AdapterStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLBBJiCm4BpxArPmQ2aaDoJ4en84a3XmAYTkMsVRcYJUQEEcQe5_nt6IjbJYSR7isPrPpzW3DO3R54j7SWKJ9qljba9ge5IL6LkYO04wnwg2TmKmHPtDXPSsJJXdWTN2E6fmbfIanOxF7-yk7XAFeWYlMd2QUwRwt5UrxEWVeZfWSy6rXsPiNR83lkdjP5gA4xILBv5roliPm3tDZ3NQl27CSwojMO3WHYZb6eo5kg3AcephndmIB1z1aXlFznki-ltrDGoJipNbEQzEO3nMJzQ7DqDDk_vzQClSWOthA8hyUWe5kGMdmnGTddX3_U3kJLf-VmWym72YIvYGr4RJNs9TMs37SRpNNhMLvvPLbQGDvlST-J2paclQO9TES1c9cIzSD3xqf_hxniio_lYvlENtHiB8LznOB3BJl4d6XMUYl9bcRFWnKtQE2-1PduftidTpk07DjYPvuKxraQL0rsK2C1e9-IzkHwC-oFYN6CYcuQD-0G00"^^xsd:anyURI ;
    :differsInAspectsFrom :Bridge ,
                          :Decorator ,
                          :Facade ,
                          :Proxy ,
                          :State ,
                          :Strategy ;
    :hasCon :CodeMoreComplicated ;
    :hasPro :OpenClosedPrinciple ,
            :SingleResponsibilityPrinciple ;
    :isBasedOn :Composition ;
    :offersNewInterface :ServiceObject ;
    :solvesIncompatibility :Interface ;
    :wrapsSingle :ServiceObject ;
    :intent "Adapter is a structural design pattern that allows objects with incompatible interfaces to collaborate."@en ;
    rdfs:comment "Adapter converts the interface of a class into another interface clients expect. It is a structural design pattern that allows objects with incompatible interfaces to collaborate. It is also called Wrapper, or Translator. An adapter can be used when the wrapper must respect a particular interface and must support polymorphic behavior."@en ,
                 "Adapter pretvori vmesnik razreda v drug vmesnik, ki ga pričakujejo odjemalci. Gre za strukturni vzorec načrtovanja, ki omogoča sodelovanje objektov z nezdružljivimi vmesniki. Adapter imenujemo tudi Ovojnica. Adapter se lahko uporabi, kadar mora ovojnica upoštevati določen vmesnik in mora podpirati polimorfno vedenje."@sl ;
    rdfs:label "Adapter"@en ,
               "Wrapper"@en ,
               "Adapter"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/adapter"^^xsd:anyURI ;
    skos:prefLabel "Adapter"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Facade ;
    rdfs:comment "Facade defines a new interface for existing objects, whereas Adapter tries to make the existing interface usable. Adapter usually wraps just one object, while Facade works with an entire subsystem of objects."@en ,
                 "Vzorec Facade definira nov vmesnik za obstoječe razrede, medtem ko vzorec Adapter poskuša povezati nezdružljive vmesnike. Vzorec Adapter se osredotoča samo na en razred (service class), medtem ko se vzorec Facade ukvarja s celotnim kompleksnim podsistemom razredov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Proxy ;
    rdfs:comment "S pomočjo vzorca Adapter lahko dostopamo do obstoječega objekta (tipa Service) preko drugačnega vmesnika. Pri vzorcu Proxy vmesnik ostane enak. Pri uporabi vzorca Decorator dostopamo do objekta (Wrapee) prek razširjenega vmesnika."@sl ,
                 "With Adapter you access an existing object via different interface. With Proxy, the interface stays the same. With Decorator you access the object via an enhanced interface."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :State ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Stanje omogoča objektu, da spremeni svoje obnašanje, ko se spremeni njegovo notranje stanje."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. State allows an object to alter its behavior when its internal state changes."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Vzorec strategija omogoča izbiro algoritma med izvajanjem."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. Strategy enables selecting an algorithm at runtime."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :Composition ;
    rdfs:comment "Adapter pattern is based on composition, which is delegating work to other objects."@en ,
                 "Vzorec Adapter temelji na kompoziciji, kar pomeni, da delegira delo drugim objektom."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :offersNewInterface ;
    owl:annotatedTarget :ServiceObject ;
    rdfs:comment "Adapter provides a completely different interface for accessing an existing object. With Adapter we can access an existing object via different interface."@en ,
                 "Vzorec Adapter ponuja popolnoma drugačen vmesnik za dostop do objektov obstoječega razreda. S pomočjo vzorca Adapter lahko dostopamo do obstoječega objekta (tipa Service) preko drugačnega vmesnika."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :solvesIncompatibility ;
    owl:annotatedTarget :Interface ;
    rdfs:comment "Adapter is commonly used with an existing app to make some otherwise-incompatible classes work together nicely."@en ,
                 "Vzorec Adapter običajno uporabimo v obstoječi aplikaciji za omogočanje delovanje sicer nezdružljivih vmesnikov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :wrapsSingle ;
    owl:annotatedTarget :ServiceObject ;
    rdfs:comment "Adapter usually wraps just one object. Adapter tries to make the existing interface usable."@en ,
                 "Vzorec Adapter se osredotoča samo na en razred (service class). Adapter se osredotoča samo na en razred (service class)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Bridge ;
    rdfs:comment "Bridge is usually designed up-front, letting you develop parts of an application independently of each other. On the other hand, Adapter is commonly used with an existing app to make some otherwise-incompatible classes work together nicely."@en ,
                 "Uporabo vzorca Bridge v programski kodi običajno predvidimo vnaprej, kar nam omogoča razvoj delov aplikacije neodvisno drug od drugega. Medtem ko vzorec Adapter običajno uporabimo v obstoječi aplikaciji za omogočanje delovanje sicer nezdružljivih vmesnikov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Bridge ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Bridge ločuje abstrakcijo od njene izvedbe, tako da se lahko neodvisno spreminjata."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. Bridge decouples an abstraction from its implementation so that the two can vary independently."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Adapter ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "Adapter provides a completely different interface for accessing an existing object. On the other hand, with the Decorator pattern the interface either stays the same or gets extended. In addition, Decorator supports recursive composition, which isn’t possible when you use Adapter."@en ,
                 "Vzorec Adapter ponuja popolnoma drugačen vmesnik za dostop do objektov obstoječega razreda. Po drugi strani pa vzorec Decorator ohrani vmesnik oz. ga razširi. Poleg tega vzorec Decorator podpira rekurzivno kompozicijo, česar uporaba vmesnika Adapter ne omogoča."@sl
] .

:AlternativeToInheritance rdf:type owl:NamedIndividual ,
                                   :Aspect ;
    rdfs:comment "You get an alternative to inheritance when dealing with configuration presets."@en ;
    rdfs:label "Alternative to inheritance"@en .

:BehaviorExtension rdf:type owl:NamedIndividual ,
                            :Aspect ;
    rdfs:label "Behavior extension"@en ;
    rdfs:comment "You can extend an object’s behavior without making a new subclass."@en .

:Bridge rdf:type owl:NamedIndividual ,
                 :StructuralPattern ;
    :hasStructure :BridgeStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dLHTQzim57tNhxXB7vomEP2MmkX2OF5QA6nbf7iQUr7j6qUr8XbPIMZN_FTU-IEMdUoJ46CVwPvxTUxH3LW0SoEI53_0lJMRs6uCie2n8XCgvuQl8PQyAE0d0tZWSPOQlL59fAKsi5i9YmxN9a5JOMUND_Ftrn6Xt1Yzgy07IP5ixxCgRV4lIECIImr_8cYfbOrQeCEN4mrFJrEUtKJqk_xFIbksgXXhk2fe2PLbf5G0dt0fb8Z58uTKygqIAp3ysM2Yjo0KRDTOA97fhPCrAiKSG2G5nTCBBvhtwHI6qRidb5BlHZ2RjPiNBW4cyF6XeEIn5LfLaVM2ZxlpZyTZUePXIC-ti4Jkcdet7BbpiU1GWbQnGOktwrpYcYhWZg2eQ_h58cEDq2q1_1F3TBh0s7ALIfpDod8hWmsQW1yAe4T9mEz8tRdQiYexL_lhztvEIjgeSAHfNqmI4iHLhw0ABmNs99wGn1tWl0JsBj-jicYMF7Q5zGvNfkrXP0PnYAXryZEkqQvqCXactF9H1pi_WLqSCAfbV-JQN6_ncTV-BBqO9dgdmfal1lE5qQ74fGrfHq-N4uuS37NkNhWS3I3SvE5Bb_TqJyd4ctpySfI0YeUlXczrfYtTAchEIgGhIN_RxHrNIL_K41H2WfA_8HRJE086bKiymyobZZFIF01evq0RK2u0pBrXGhUz1dkpnvyMNjItbOWpXMJ1IGKlgX2ZqC3aii8-avJtzeao9jhQAiE-R5v7mA1_NLXGNdHQ-CwV5LzdmisXJ9SRpADmZIxdht6oWLus8yZDmfPuxDaQIKqNmkf8rtuNwDLnTTMv1cBSUDIF_cFmUIUu-tLnJ7KumR7n3fHt7PBkrnUFyXK0"^^xsd:anyURI ;
    :canBeUsedWith :AbstractFactory ,
                   :Builder ;
    :differsInAspectsFrom :Adapter ,
                          :State ,
                          :Strategy ;
    :hasCon :CodeMoreComplicated ;
    :hasPro :HighLevelAbstraction ,
            :OpenClosedPrinciple ,
            :PlatformIndependent ,
            :SingleResponsibilityPrinciple ;
    :intent "Bridge is a structural design pattern that lets you split a large class or a set of closely related classes into two separate hierarchies—abstraction and implementation—which can be developed independently of each other."@en ;
    rdfs:comment "Bridge is a structural design pattern that lets us split a large class or a set of closely related classes into two separate hierarchies — abstraction and implementation — which can be developed independently of each other. It decouples an abstraction from its implementation allowing the two to vary independently. The bridge uses encapsulation, aggregation, and can use inheritance to separate responsibilities into different classes."@en ,
                 "Most je načrtovalski vzorec, ki omogoča razdelitev velikega razreda ali množice tesno povezanih razredov v dve ločeni hierarhiji – abstrakcijo in implementacijo – ki ju je mogoče razvijati neodvisno drugo od druge. Loči abstrakcijo od njene implementacije, kar omogoča, da se obe neodvisno spreminjata. Bridge uporablja enkapsulacijo, agregacijo in lahko uporablja dedovanje za ločitev odgovornosti v različne razrede."@sl ;
    rdfs:label "Bridge"@en ,
               "Most"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/bridge"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Bridge ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :AbstractFactory ;
    rdfs:comment "Potencialno uporabno, ko je vzorec Bridge kot osnova; in ko lahko nekatere abstrakcije (razred Abstraction), definirane z vzorcem Bridge, delujejo samo s posebnimi implementacijami (vmesnik Implementation). V tem primeru lahko z vzorcem AbstractFactory zajamemo te relacije in skrijemo kompleksnost pred odjemalcem (class Client)."@sl ,
                 "You can use Abstract Factory along with Bridge. This pairing is useful when some abstractions defined by Bridge can only work with specific implementations. In this case, Abstract Factory can encapsulate these relations and hide the complexity from the client code."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Bridge ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Builder ;
    rdfs:comment "Vzorec Builder lahko kombiniramo z vzorcem Bridge: razred 'Direktor' igra vlogo abstrakcije (razred Abstraction), medtem ko različni builderji (Concrete Builders) igrajo vlogo implementacije (vmesnik Implementation)."@sl ,
                 "You can combine Builder with Bridge: the director class plays the role of the abstraction, while different builders act as implementations."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Bridge ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Adapter ;
    rdfs:comment "Bridge is usually designed up-front, letting you develop parts of an application independently of each other. On the other hand, Adapter is commonly used with an existing app to make some otherwise-incompatible classes work together nicely."@en ,
                 "Uporabo vzorca Bridge v programski kodi običajno predvidimo vnaprej, kar nam omogoča razvoj delov aplikacije neodvisno drug od drugega. Medtem ko vzorec Adapter običajno uporabimo v obstoječi aplikaciji za omogočanje delovanje sicer nezdružljivih vmesnikov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Bridge ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Adapter ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Vzorec strategija omogoča izbiro algoritma med izvajanjem."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. Strategy enables selecting an algorithm at runtime."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Bridge ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :State ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Bridge ločuje abstrakcijo od njene izvedbe, tako da se lahko neodvisno spreminjata."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. Bridge decouples an abstraction from its implementation so that the two can vary independently."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Bridge ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Stanje omogoča objektu, da spremeni svoje obnašanje, ko se spremeni njegovo notranje stanje."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. State allows an object to alter its behavior when its internal state changes."@en
] .

:Builder rdf:type owl:NamedIndividual ,
                  :CreationalPattern ;
    :hasStructure :BuilderStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/nLLBQzj04BxhLmpkmROQ2Mee53Snr4u3lPNc5dfPIsDxuzMkMAriuZR_lRExMacMqnSKcaDOpUER-URbSJI6PSr5Zlezt1jTPwRM68sZgDfpMJBD2iW4gohu5W6iMRRVQbNBVAM4qd3SSODMhZG1UDchjtVBTnzN96LQgwCNhWLvHizzLAaC_W5evcHRpPv8j57Ih3h16Lu7ursCPh8Y5KeJ4PyntEA6IvxnHmPRmGwIxq2payPS7O1BE1HOIRvN1qj-vIYFO2Ku-TE3LU5zVGsJrTKJ2g6EKrWiEkDRhZ4p5DgPjr-MOm9hN-HvgBOL9WdzVzrQJXgRgPDcEoQts5YVgmgsnubvAd5gI_196jGRbY75XG1FBvT5-AIiUMktMFYaclWQApGJ3-tYt1iiFmm5ow7WOUB21_QVjSffUjxukE5hg9wTgMUzIYkPQJJuLNOa6goWQgM-efHsBSoy2_LF65d15iqN1pwPzk2VVvtixCLaP_ybsPbDTZ3pfJhWYJNJxIOvoTLH9ejs_gABGWUBhfj3TWEBMTIEVP88t9Y4T67YB_7Jkao_TmONw4EzppjDRT1qSJ4OdlC3ApcT1RlJUrMG0zEF72nlTtACAa5jmZRREmCt4CSIZt5yWUXgdFSCkbrrcjIjedssur-IzJhjTIL2cRjh5zc6DFxp-QZRuX6S69qxOnITHGw5Eg6yWZsjROwYVaIeMA6iZQsevQNvTcSQFeqVKMhx2E7QfDrinJ7VKFuk8DpSmBZYHIbmF7K3Ql-2ps06dyaLHONa_5DBFvmlgXuQa5uLNDgEWcl4eEbKcIRh4JdwlUar80pQMLr_YzZFj8DDASmTClkBj_mxl5vxHwwufA-r1BFZLHod7hu3_040"^^xsd:anyURI ;
    :canBeDevelopedFrom :FactoryMethod ;
    :canBeImplementedAs :Singleton ;
    :canBeUsedWith :Bridge ,
                   :Composite ;
    :hasCon :CodeMoreComplicated ;
    :hasPro :PromoteCodeReuse ;
    :isFocusedOn :ComplexObjects ;
    :intent "Builder is a creational design pattern that lets you construct complex objects step by step. The pattern allows you to produce different types and representations of an object using the same construction code."@en ;
    rdfs:comment "Builder is a creational design pattern that lets us construct complex objects step by step. The builder pattern separates the construction of a complex object from its representation. It allows us to produce different types and representations of an object using the same construction code. Builder separates the construction of a complex object from its representation, allowing the same construction process to create various representations."@en ,
                 "Graditelj je načrtovalski vzorec, ki nam omogoča konstruiramo zapletenih objektov korak za korakom. Ločuje konstrukcijo kompleksnega objekta od njegove predstavitve in nam omogoča ustvarjanje različnih vrst in predstavitev objekta z uporabo iste konstrukcijske kode."@sl ;
    rdfs:label "Builder"@en ,
               "Graditelj"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/builder"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Builder ;
    owl:annotatedProperty :canBeDevelopedFrom ;
    owl:annotatedTarget :FactoryMethod ;
    rdfs:comment "Factory Method is less complicated and more customizable via subclasses; while Builder is more flexible, but more complicated."@en ,
                 "Veliko načrtov programske kode lahko začnemo z vzorcem FactoryMethod (preprosto, prilagodljivost preko podrazredov) --> evolucija v vzorec Builder."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Builder ;
    owl:annotatedProperty :canBeImplementedAs ;
    owl:annotatedTarget :Singleton ;
    rdfs:comment "Can be used when construction of various representations of the product involves similar steps that differ only in the details, but only a single instance of a (concrete) builder object should be used."@en ,
                 "Lahko uporabimo, ko izdelava različnih vrst izdelkov vključuje podobne korake, ki se razlikujejo le v podrobnostih, uporabiti pa želimo le en primerek (konkretnega) objekta tipa Builder."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Builder ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Bridge ;
    rdfs:comment "Vzorec Builder lahko kombiniramo z vzorcem Bridge: razred 'Direktor' igra vlogo abstrakcije (razred Abstraction), medtem ko različni builderji (Concrete Builders) igrajo vlogo implementacije (vmesnik Implementation)."@sl ,
                 "You can combine Builder with Bridge: the director class plays the role of the abstraction, while different builders act as implementations."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Builder ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "Vzorec graditelj lahko uporabite pri ustvarjanju kompleksnih kompozitnih dreves, ker lahko nastavite njegove korake, da delujejo rekurzivno."@sl ,
                 "You can use builder when creating complex composite trees, because you can program its construction steps to work recursively."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Builder ;
    owl:annotatedProperty :isFocusedOn ;
    owl:annotatedTarget :ComplexObjects ;
    rdfs:comment "Builder focuses on constructing complex objects step by step."@en ,
                 "Vzorec Builder je namenjen gradnji kompleksnih objektov korak po koraku."@sl
] .

:CanBeInvasive rdf:type owl:NamedIndividual ,
                        :Aspect ;
    rdfs:label "Can be invasive"@en ;
    rdfs:comment "Visitors might lack the necessary access to the private fields and methods of the elements that they’re supposed to work with. The classes used in the tree structure must provide an accept() operation."@en .

:CanMaskBadDesign rdf:type owl:NamedIndividual ,
                           :Aspect ;
    rdfs:label "Can mask bad design"@en .

:CanViolateLSP rdf:type owl:NamedIndividual ,
                        :Aspect ;
    rdfs:label "Can violate Liskov Substitution Principle"@en ;
    rdfs:comment "We might violate the Liskov Substitution Principle by suppressing a default step implementation via a subclass."@en .

:ChainOfResponsibility rdf:type owl:NamedIndividual ,
                                :BehavioralPattern ;
    :hasStructure :ChainOfResponsibilityStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dLJBRjim4BphAxRDmJPRAKY20eNh6eXL1maA54NQKs-qj98OqwHAKdQTrFzUadf4Vg080WEsDBixd9rTUX0C82ue4o0pk4TTIg7PWd5cjf_WXr5LOYg540o2G2-PAAcYAqWurHgU0e05JPQvafL8OycbWat133fSgXHLZPrzk9bzdCSMfKh9JGqkkAqCTdrM8Gs-W3JnMAxeraAP5APEIgbQUd2FixHKD3zDUtOJsy_ybMgVsMf1Hb6XRGY52QnR0_Y26HCiOGyKSaxNWXMWwAF2LAx1shrUeHPiATVEsjWR-XPYpcozVQ2wVPvCO1Y_toBdSZE2wJG8xeH1bT44RTuj5Ib7LLUqBxQ4TJdJgMy-34Fx_Guqcc_unmoBSPi-ydZXNuOAVrUepSZrsegQKOrxv_G1pmt2KdQ4hplDMVRz-klyvvqpf9sRjKIAHA7TZ8P0D-uqS8TE9lUO62foZatBdQdxgIVhVG5054N-jzP_IYd0hbNR6t0fr_X8cr7wiOKXnyo4qywKlcbHLKRHtzCn6LPbsAix5Eh2jhHNKglvHKjcjzEjrbAkh0Ig7fWJvA_LGXeZL-wEr_fi7yK5V0P216u8QK-x7heEYylZoAoEN1r7uZfo4NN3lgn9de4h1voVD_RQr4DNKQJ--ZTg5SiBuyJskXoFZqT12CkiaA5RFtZZbLMS4pBommE_bYy-wy3e_vsNK76x7nmr2zHhSsVJaMkq1MsCaFeFWf1JxBjEsZy0"^^xsd:anyURI ;
    :canBeUsedWith :Command ,
                   :Composite ;
    :differsInAspectsFrom :Decorator ;
    :hasCon :CodeMoreComplicated ,
            :ImpactsEfficiency ;
    :hasPro :CodeChangeFlexibility ,
            :Decoupling ,
            :OpenClosedPrinciple ,
            :PromoteCodeReuse ,
            :SingleResponsibilityPrinciple ;
    :hasSimilarStructure :Decorator ;
    :isSimilarTo :Command ,
                 :Mediator ,
                 :Observer ;
    :uses :RecursiveComposition ;
    :usesDynamicChain :SendersReceivers ;
    skos:related :Command ,
                 :Mediator ,
                 :Observer ;
    :intent "Chain of Responsibility is a behavioral design pattern that lets you pass requests along a chain of handlers. Upon receiving a request, each handler decides either to process the request or to pass it to the next handler in the chain."@en ;
    rdfs:comment "Chain of Responsibility is a behavioral design pattern that lets us pass requests along a chain of handlers. Upon receiving a request, each handler decides either to process the request or to pass it to the next handler in the chain. Chain of Responsibility avoids coupling the sender of a request to its receiver by giving more than one object a chance to handle the request. Chain the receiving objects and pass the request along the chain until an object handles it. This pattern promotes the idea of loose coupling."@en ,
                 "Veriga odgovornosti je načrtovalski vzorec, ki nam omogoča posredovanje zahtev po verigi poslušalcev. Po prejemu zahteve se vsak poslušalec odloči, ali jo bo obdelal ali pa jo posredoval naslednjemu poslušalcu v verigi. Veriga odgovornosti se izogne ​​povezavi pošiljatelja zahteve s prejemnikom, tako da omogoči več kot enemu objektu (poslušalcu) možnost, da zahtevo obdela. Poveže poslušalce in zahtevo posredujte po verigi, dokler je ne obdela noben poslušalec. Ta vzorec predstavlja primer ohlapnega povezovanja."@sl ;
    rdfs:label "Chain of Responsibility"@en ,
               "Chain of Command"@en ,
               "Veriga odgovornosti"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/chain-of-responsibility"^^xsd:anyURI ;
    skos:prefLabel "Chain of Responsibility"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Handlers in Chain of Responsibility can be implemented as Commands. In this case, you can execute a lot of different operations over the same context object, represented by a request. However, there’s another approach, where the request itself is a Command object. In this case, you can execute the same operation in a series of different contexts linked into a chain."@en ,
                 "Upravljalce (angl. handlers) v ChainOfResponsibility lahko implementiramo kot ukaze (z vzorcem Command). V tem primeru lahko izvedemo veliko različnih operacij v okviru istega objekta, ki ga predstavlja zahteva. (Rečeno drugače, v objektu 'zahteva' definiramo več operacij; pri ChainOfResponsibility pa smo poslali eno zahtevo, kjer je vsak prejemnik naredil svoj del). Obstaja še en pristop, pri katerem je zahteva v ChainOfResponsibility objekt tipa Command. V tem primeru lahko izvedemo isto operacijo v nizu različnih kontekstov v verigi (poslanih dolzina-verige zahtev tipa command za vsako operacijo eno)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "Chain of Responsibility is often used in conjunction with Composite. In this case, when a leaf component gets a request, it may pass it through the chain of all of the parent components down to the root of the object tree."@en ,
                 "Vzorec ChainOfResponsibility lahko pogosto uporabljamo skupaj z vzorcem Composite. V tem primeru, ko list drevesa (class Leaf) dobi zahtevo, jo lahko posreduje navzgor po verigi starševskih komponent do korena drevesa."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "Med vzorcema Decorator in ChainOfResponsibility obstaja več bistvenih razlik. 1) Pri vzorcu ChainOfResponsibility lahko upravljalci izvajajo poljubne operacije neodvisno drug od drugega. Prav tako lahko kadar koli prekinejo nadaljnje posredovanje zahteve. 2) Po drugi strani pa lahko različni Decoratorji razširijo vedenje objekta, hkrati pa ohranijo skladnost s prvotnim vmesnikom. Poleg tega dekoraterji ne smejo prekiniti toka zahteve."@sl ,
                 "There are several crucial differences between ChainOfResponsibility pattern and Decorator pattern. The CoR handlers can execute arbitrary operations independently of each other. They can also stop passing the request further at any point. On the other hand, various Decorators can extend the object’s behavior while keeping it consistent with the base interface. In addition, decorators aren’t allowed to break the flow of the request."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "Chain of Responsibility and Decorator have very similar class structures. Both patterns rely on recursive composition to pass the execution through a series of objects. However, there are several crucial differences."@en ,
                 "Vzorca Decorator in ChainOfResponsibility imata zelo podobni strukturi razredov. Oba vzorca se zanašata na rekurzivno zgradbo, kjer se izvedba prenaša preko niza objektov. Vendar obstaja več bistvenih razlik."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Observer ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :uses ;
    owl:annotatedTarget :RecursiveComposition ;
    rdfs:comment "Chain of Responsibility and Decorator have very similar class structures. Both patterns rely on recursive composition to pass the execution through a series of objects."@en ,
                 "Vzorca ChainOfResponsibility in Decorator imata zelo podobni strukturi razredov. Oba vzorca se zanašata na rekurzivno zgradbo, kjer se izvedba prenaša preko niza objektov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :ChainOfResponsibility ;
    owl:annotatedProperty :usesDynamicChain ;
    owl:annotatedTarget :SendersReceivers ;
    rdfs:comment "Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. It consists of a source of command objects and a series of processing objects."@en ,
                 "Vzorec ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. Sestavljen je iz vira ukaznih objektov in niza procesnih objektov."@sl
] .

:CircularReferencesCodeComplicated rdf:type owl:NamedIndividual ,
                                            :Aspect ;
    rdfs:label "Circular references complicated code"@en ;
    rdfs:comment "Cloning complex objects that have circular references might be very tricky."@en .

:ClassSubsystem rdf:type owl:NamedIndividual ,
                         :Aspect ;
    rdfs:comment "A whole represented by several objects."@en ,
                 "Celota, predstavljena z več objekti."@sl ;
    rdfs:label "Group ob objects"@en ,
               "Skupina objektov"@sl .

:CloningObjectsWithoutCoupling rdf:type owl:NamedIndividual ,
                                        :Aspect ;
    rdfs:label "Cloning objects without coupling"@en ;
    rdfs:comment "Clone objects without coupling to their concrete classes."@en .

:CodeChangeFlexibility rdf:type owl:NamedIndividual ,
                                :Aspect ;
    owl:differentFrom :CodeMoreInflexibile ;
    rdfs:label "Code change flexibility"@en ;
    rdfs:comment "We can let clients override only certain parts of a large algorithm, making them less affected by changes that happen to other parts of the algorithm."@en ,
                 "The pattern allows you to add, remove, or modify objects without affecting the overall behavior of the system."@en ,
                 "We can control the service object without clients knowing about it."@en .

:CodeMoreComplicated rdf:type owl:NamedIndividual ,
                              :Aspect ;
    rdfs:label "Code more complicated"@en ;
    rdfs:comment "A lot of new interfaces and classes are introduced."@en ,
                 "A lot of new subclasses to implement the pattern."@en ,
                 "If you only have a couple of algorithms and they rarely change, there’s no real reason to overcomplicate the program with new classes and interfaces that come along with the pattern."@en ,
                 "Template methods tend to be harder to maintain the more steps they have."@en ,
                 "The Mediator pattern can introduce complexity into the system, as it requires a new object to be created and managed. This can make the system more difficult to understand and maintain. Vir: https://www.gofpattern.com/design-patterns"@en ,
                 "The code becomes much more complicated. New team members will always be wondering why the state of an entity was separated in such a way."@en ,
                 "The code may become more complicated since you need to introduce a lot of new classes."@en ,
                 "The code may become more complicated since you’re introducing a whole new layer between senders and receivers."@en ,
                 "We need to introduce a set of new interfaces and classes. Sometimes it’s simpler just to change the service class."@en ,
                 "You might make the code more complicated by applying the pattern to a highly cohesive class."@en .

:CodeMoreInflexibile rdf:type owl:NamedIndividual ,
                              :Aspect ;
    :hasPro :BehaviorExtension ;
    rdfs:label "Code more inflexible"@en , "Code more complicated"@en ;
    rdfs:comment "We need to update all visitors each time a class gets added to or removed from the element hierarchy."@en ,
                 "It’s hard to remove a specific wrapper from the wrappers stack."@en ,
                 "Some clients may be limited by the provided skeleton of an algorithm."@en .

:CodeMoreUgly rdf:type owl:NamedIndividual ,
                       :Aspect ;
    rdfs:label "Code more ugly"@en .

:CodeSimplification rdf:type owl:NamedIndividual ,
                             :Aspect ;
    rdfs:label "Code simplification"@en ;
    rdfs:comment "Can isolate your code from the complexity of a subsystem."@en ,
                 "Simplify the code of the context by eliminating bulky state machine conditionals."@en ,
                 "We can simplify the originator’s code by letting the caretaker maintain the history of the originator’s state."@en .

:CodeSlower rdf:type owl:NamedIndividual ,
                     :Aspect ;
    rdfs:label "Code slower"@en ;
    rdfs:comment "We might be trading RAM over CPU cycles when some of the context data needs to be recalculated each time somebody calls a flyweight method."@en .

:Command rdf:type owl:NamedIndividual ,
                  :BehavioralPattern ;
    :hasStructure :CommandStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLDDRzim3BthLn3R8H-D3Ip0W09hVPYt0RrkjzqKcKbKEw91oyxIRVzzaYtPIPC1lGZI8_N8fqVDn0noEXoaAJx13ykjiYsZc0dHbDhKakK1L2MR1duBW8rKvOwfDKLE5J4SzzgYnuaBv05x__7Rv_klkKCbCnq7S5Evc-BlEQiXYsyWLJssOtboq9QCpIVWWc-Y6QvObgPn8JHME3qp-89RRRJIpn9sbUoCtWFB5yQ2Ej06kWCsHfVKUV5vB_aTv9Lszzr6Dd7_y03pV7N2ggBZ0h9iIlwE2dM7FAIF9wynJLEt9adYrZkW6bbQJMOkLx1PWLfuAP7coNHKHfPuy2G9gC6fCwe6RR1l7eAB7iTVg5gBCTONU38MUIiLUc5382WB1oTDZpbPDXGDXGBX_ABLd8nY7CjyY7IlqA5v3W_I7thFcZF-c3oFQQkGitXp-VNDykiR1bomlPgDcZfyaM4AUiUJWeucoKP7HvprRczT89Wa-f7kGI03bJObk7AAwXCymd9fyBXSklRgKxG52ss9lS9DQosPzCBE-hGGw6pnjDwzOHB6gY5HN3rtsjRfd__6rrVnGKsQPbVEYMlofCAjFNiCkAawcfXEenxTd1JvX_yfQ-t-iF-09HrS7vAVjPZz0m00"^^xsd:anyURI ;
    :canBeTreatedAsSimplified :Visitor ;
    :canBeUsedWith :ChainOfResponsibility ,
                   :Memento ,
                   :Prototype ;
    :differsInAspectsFrom :Strategy ;
    :encapsulatesOperation :CommandObject ;
    :hasCon :CodeMoreComplicated ;
    :hasPro :OpenClosedPrinciple ,
            :SingleResponsibilityPrinciple ,
            :SupportsComposition ,
            :SupportsDeferredCodeExecution ,
            :SupportsRollbackSystem ;
    :hasSimilarStructure :Strategy ;
    :isSimilarTo :ChainOfResponsibility ,
                 :Mediator ,
                 :Observer ,
                 :Visitor ;
    :usesUnidirectionalConnection :SendersReceivers ;
    skos:related :ChainOfResponsibility ,
                 :Mediator ,
                 :Observer ;
    :intent "Command is a behavioral design pattern that turns a request into a stand-alone object that contains all information about the request. This transformation lets you pass requests as a method arguments, delay or queue a request’s execution, and support undoable operations."@en ;
    rdfs:comment "Command is a behavioral design pattern that turns a request into a stand-alone object that contains all information about the request. This information includes the method name, the object that owns the method and values for the method parameters. This transformation lets us pass requests as a method arguments, delay or queue a request’s execution. It also allows for the support of undoable operations. Using command objects makes it easier to construct general components that need to delegate, sequence or execute method calls at a time of their choosing without the need to know the class of the method or the method parameters."@en ,
                 "Ukaz je načrtovalski vzorec, ki spremeni zahtevo v samostojen objekt, ki vsebuje vse informacije o zahtevi. Informacije zahteve zajemajo ime metode, izvorni objekt metode, in vrednosti parametrov metode. Ta transformacija nam omogoča, da zahteve posredujemo kot argumente metod, odložimo ali postavimo v čakalno vrsto za izvajanje zahtev. Omogoča tudi podporo razveljavljanju operacij. Uporaba ukaznih objektov olajša konstruiranje splošnih komponent, ki morajo delegirati ali izvajati klice metod ob času, ki ga izberejo sami, brez poznavanja razreda ali parametrov metode."@sl ;
    rdfs:label "Command"@en ,
               "Transaction"@en ,
               "Action"@en ,
               "Ukaz"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/command"^^xsd:anyURI ;
    skos:prefLabel "Command"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :ChainOfResponsibility ;
    rdfs:comment "Handlers in Chain of Responsibility can be implemented as Commands. In this case, you can execute a lot of different operations over the same context object, represented by a request. However, there’s another approach, where the request itself is a Command object. In this case, you can execute the same operation in a series of different contexts linked into a chain."@en ,
                 "Upravljalce (angl. handlers) v ChainOfResponsibility lahko implementiramo kot ukaze (z vzorcem Command). V tem primeru lahko izvedemo veliko različnih operacij v okviru istega objekta, ki ga predstavlja zahteva. (Rečeno drugače, v objektu 'zahteva' definiramo več operacij; pri ChainOfResponsibility pa smo poslali eno zahtevo, kjer je vsak prejemnik naredil svoj del). Obstaja še en pristop, pri katerem je zahteva v ChainOfResponsibility objekt tipa Command. V tem primeru lahko izvedemo isto operacijo v nizu različnih kontekstov v verigi (poslanih dolzina-verige zahtev tipa command za vsako operacijo eno)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Memento ;
    rdfs:comment "Pri implementaciji ukaza 'razveljavi' lahko skupaj uporabimo vzorca Command in Memento. V tem primeru so ukazi ('Concrete Commands') odgovorni za izvajanje različnih operacij nad ciljnim objektom. (cmd 'Receiver', mem 'Concrete Originator'), medtem ko objekti tipa spominek ('Concrete Memento') shranijo stanje ciljnega objekta (cmd 'Receiver', mem 'Concrete Originator') tik pred izvedbo ukaza ('Concrete Command')."@sl ,
                 "You can use Command and Memento together when implementing 'undo'. In this case, commands are responsible for performing various operations over a target object, while mementos save the state of that object just before a command gets executed."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Prototype ;
    rdfs:comment "Prototype can help when you need to save copies of Commands into history."@en ,
                 "Vzorec Prototype lahko uporabimo, ko želimo shraniti kopije ukazov (vzorec Command) in tako hraniti zgodovino ukazov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Command and Strategy have very different intents. 1) We can use Command to convert any operation into an object. The operation’s parameters become fields of that object. The conversion lets you defer execution of the operation, queue it, store the history of commands, send commands to remote services, etc. 2) On the other hand, Strategy usually describes different ways of doing the same thing, letting you swap these algorithms within a single context class."@en ,
                 "Vzorca Command in Strategy imata oba zelo različen namen. 1) Vzorec Command lahko uporabimo za prevedbo katere koli operacije v objekt ('Concrete Command'). Parametri operacije  postanejo atributi objekta. Prevedba omogoča, da odložimo izvedbo operacije, jo postavimo v  čakalno vrsto, shranimo zgodovino ukazov, pošljemo ukaze oddaljenim storitvam, ipd. 2) Po drugi strani pa vzorec Strategy določa različne načine izvajanja iste stvari (da lahko nalogo stvar izvedemo na drugačen način), kar nam omogoča zamenjavo algoritmov ('Concrete Strategy') v okviru kontekstnega razreda (razred 'Context')."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :encapsulatesOperation ;
    owl:annotatedTarget :CommandObject ;
    rdfs:comment "Vzorec Command lahko uporabimo za prevedbo katere koli operacije v objekt ('Concrete Command'). Parametri operacije  postanejo atributi objekta. Prevedba omogoča, da odložimo izvedbo operacije, jo postavimo v  čakalno vrsto, shranimo zgodovino ukazov, pošljemo ukaze oddaljenim storitvam, ipd."@sl ,
                 "You can use Command to convert any operation into an object. The operation’s parameters become fields of that object. The conversion lets you defer execution of the operation, queue it, store the history of commands, send commands to remote services, etc."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Command and Strategy may look similar because you can use both to parameterize an object with some action. However, they have very different intents."@en ,
                 "Vzorca Command in Strategy sta si morda videti podobna, ker pri obeh lahko parametriziramo objekt z določenimi ukazi. Vendar imata oba zelo različen namen."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :ChainOfResponsibility ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Observer ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Command ;
    owl:annotatedProperty :usesUnidirectionalConnection ;
    owl:annotatedTarget :SendersReceivers ;
    rdfs:comment "Command establishes unidirectional connections between senders and receivers."@en ,
                 "Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki."@sl
] .

:CommandObject rdf:type owl:NamedIndividual ,
                        :Aspect ;
    rdfs:comment "A Command object represents a command that encapsulates a request, allowing actions to be parameterized, queued, or undone by decoupling the invoker from the receiver."@en ,
                 "Objekt ukaza predstavlja ukaz, ki enkapsulira zahtevo ter omogoča, da so dejanja parametrična, uvrščena v čakalno vrsto ali razveljavljena, pri čemer ločuje klicatelja od izvajalca."@sl ;
    rdfs:label "Command Object"@en ,
               "Ukazni objekt"@sl .

:ComplexObjects rdf:type owl:NamedIndividual ,
                         :Aspect ;
    rdfs:comment "Complex objects are composed of other objects - often called composite objects or aggregates."@en ,
                 "Kompleksni objekti so sestavljeni iz drugih objektov – pogosto jih imenujemo sestavljeni objekti ali agregati."@sl ;
    rdfs:label "Complex objects"@en ,
               "Kompleksni objekti"@sl .

:Composite rdf:type owl:NamedIndividual ,
                    :StructuralPattern ;
    :hasStructure :CompositeStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLB1ZjD03BtFLrXmQ2j8RaW8LZcG1Gd1ZIFYu4wSTBQJSJIP9co1J-2l-30yaxP9j1ouH9DdlsVxsHkrWPBRZdiJw2ry2VwamycJsYZL7uthq6CBscBVmmy5i4TzR3oVN5MoPG_ZGNWHPr-Hdx3dhpwyU_s-51Izvt42zrQOwjT2r76W_z3K2MiyFWfKimlb32pbPfM94JowNaBaWf9fDd1FjN56cmU4nkBWp04ydZrLF81nCBJKEtFa8OvUfe6VGMcDyEM1_VLzTmVRykKZMSlZ3ef2gOykaAzHa-J1vAQBcN3XtG2XcbjkKQJXiooJxmkWxwHFWROx6KgQ_KnOYqCLWMaxIwtGbqet6QKldIP2gfTUKJhFyxd0IlzAkcr-qMdwZNHzCBOI--3DNFZhjqNBM5LRlOpk4kofvO7-5Maeb1VHxMuj2siJ8BaGboQx_FDRMXgW4zKpNjQJLf5LFBgic7NKmkkVkJVD8UJ9ZtKWql9vMZNF3Pojz58FdpZQZ_x1n3ivOsVawc8RwOBt70AtmFLalCnnpz0B1KRsnroHgzAfFqcVwmk5B3KeORGsyI0mN7S0-jfFFwlz1G00"^^xsd:anyURI ;
    :canBeUsedWith :Builder ,
                   :ChainOfResponsibility ,
                   :Decorator ,
                   :Flyweight ,
                   :Iterator ,
                   :Prototype ,
                   :Visitor ;
    :canBenefitFrom :Prototype ;
    :differsInAspectsFrom :Decorator ;
    :hasCon :ImpactsEfficiency ,
            :RequiresCommonInterface ;
    :hasPro :OpenClosedPrinciple ,
            :PromoteCodeReuse ,
            :SimplifiesHierarchicalStructure ,
            :SupportsComplexTreeStructures ;
    :hasSimilarStructure :Decorator ;
    :intent "Composite is a structural design pattern that lets you compose objects into tree structures and then work with these structures as if they were individual objects."@en ;
    rdfs:comment "Composite is a structural design pattern that lets us compose objects into tree structures and then work with these structures as if they were individual objects. The intent of a composite is to 'compose' objects into tree structures to represent part-whole hierarchies. Implementing the composite pattern lets clients treat individual objects and compositions uniformly."@en ,
                 "Kompozicija (zloženka / kompozit) je načrtovalski vzorec, ki omogoča sestavljanje objektov v drevesne strukture in nato delo s temi strukturami, kot da bi bile te posamezni objekti. Namen vzorca Kompozicija je 'sestaviti' objekte v drevesne strukture, ki predstavljajo hierarhije delov in celot. Uporaba vzorca Kompozicija omogoča odjemalcem, da posamezne objekte in kompozicije (drevesne strukture) obravnavajo na enak način."@sl ;
    rdfs:label "Composite"@en ,
               "Object Tree"@en ,
               "Kompozicija"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/composite"^^xsd:anyURI ;
    skos:prefLabel "Composite"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Builder ;
    rdfs:comment "Vzorec Builder lahko uporabimo skupaj z vzorcem Composite, kar nam omogoče kreiranje zapletenih dreves; posamneze korake gradnje (vmesnika Builder) lahko zgradimo rekurzivno."@sl ,
                 "You can use Builder when creating complex Composite trees because you can program its construction steps to work recursively."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :ChainOfResponsibility ;
    rdfs:comment "Chain of Responsibility is often used in conjunction with Composite. In this case, when a leaf component gets a request, it may pass it through the chain of all of the parent components down to the root of the object tree."@en ,
                 "Vzorec ChainOfResponsibility lahko pogosto uporabljamo skupaj z vzorcem Composite. V tem primeru, ko list drevesa (class Leaf) dobi zahtevo, jo lahko posreduje navzgor po verigi starševskih komponent do korena drevesa."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "However, the patterns can also cooperate: you can use Decorator to extend the behavior of a specific object in the Composite tree."@en ,
                 "Vzorca pa uporabljamo tudi skupaj. Z vzorcem Decorator lahko razširimo obnašanje določenega objekta v drevesu Composite."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Flyweight ;
    rdfs:comment "We can implement shared leaf nodes of the Composite tree as Flyweights to save some RAM."@en ,
                 "Za skupne liste drevesa pri vzorcu Composite lahko uporabimo vzorec Flyweight in s tem prihranimo nekaj delovnega pomnilnika (angl. RAM)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Iterator ;
    rdfs:comment "We can use Iterators to traverse Composite trees."@en ,
                 "Za sprehod po drevesu vzorca Composite lahko uporabimo iteratorje."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Prototype ;
    rdfs:comment "Designs that make heavy use of Composite and Decorator can often benefit from using Prototype. Applying the pattern lets you clone complex structures instead of re-constructing them from scratch."@en ,
                 "Načrti, ki intenzivno uporabljajo vzorca Composite ali Decorator, imajo lahko pogosto koristi od uporabe vzorca Prototype. Uporaba vzorca Prototype nam omogoča kloniranje zapletenih struktur, namesto da bi jih ponovno zgradili iz nič."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Visitor ;
    rdfs:comment "Vzorec Visitor lahko uporabimo za izvedbo operacij nad celotnim drevesom Composite."@sl ,
                 "We can use Visitor to execute an operation over an entire Composite tree."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :canBenefitFrom ;
    owl:annotatedTarget :Prototype ;
    rdfs:comment "Designs that make heavy use of Composite and Decorator can often benefit from using Prototype. Applying the pattern lets you clone complex structures instead of re-constructing them from scratch."@en ,
                 "Načrti, ki intenzivno uporabljajo vzorca Composite ali Decorator, imajo lahko pogosto koristi od uporabe vzorca Prototype. Uporaba vzorca Prototype nam omogoča kloniranje zapletenih struktur, namesto da bi jih ponovno zgradili iz nič."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "A Decorator is like a Composite but only has one child component. There’s another significant difference: Decorator adds additional responsibilities to the wrapped object, while Composite just 'sums up' its children's results."@en ,
                 "Vzorec Decorator je kot vzorec Composite, vendar ima samo enega naslednika/otroka. Pomembna razlika je tudi, da vzorec Decorator dodaja dodatne odgovornosti ovojnemu objektu, medtem ko vzorec Composite samo povzame/združi rezultate svojih naslednikov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Composite ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "Composite and Decorator have similar structure diagrams since both rely on recursive composition to organize an open-ended number of objects. A Decorator is like a Composite but only has one child component. "@en ,
                 "Vzorca Composite in Decorator imata podobna strukturna diagrama, saj se oba zanašata na rekurzivno kompozicijo za organizacijo neomejenega števila objektov. Vzorec Decorator je kot vzorec Composite, vendar ima samo enega naslednika/otroka."@sl
] .

:Composition rdf:type owl:NamedIndividual ,
                      :OOConcept ;
    rdfs:comment "Fundamental concept in OOP. It describes a class that references one or more objects of other classes in instance variables. Class contains objects that bring in the functionality you need."@en ,
                 "Temeljni koncept v OOP. Opisuje razred, ki se sklicuje na enega ali več objektov drugih razredov v spremenljivkah primerka. Razred vsebuje objekte, ki prinašajo funkcionalnost, ki jo uporabnik potrebuje."@sl ;
    rdfs:label "Composition"@en ,
               "Sestava"@sl .

:CompositionOverInheritance rdf:type owl:NamedIndividual ,
                                     :Aspect ;
    rdfs:comment "/ SupportsCompositionOverInheritance / ; We can replace inheritance with composition."@en .

:ContextClass rdf:type owl:NamedIndividual ,
                       :Aspect ;
    rdfs:comment "Context classes define templates for contexts with with specific attributes. They are used to restrict a set of objects according to specific attributes. Context attributes are, for example, language, release, format, topic, and status."@en ,
                 "Kontekstni razredi definirajo predloge za kontekste s posebnimi atributi. Uporabljajo se za omejevanje nabora objektov glede na določene atribute. Atributi konteksta so na primer jezik, izdaja, oblika, tema in status."@sl ;
    rdfs:label "Context Class"@en ,
               "Kontekstni razred"@sl .

:Decorator rdf:type owl:NamedIndividual ,
                    :StructuralPattern ;
    :hasStructure :DecoratorStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dLJBRjim4BppAnREmRPQAMY10eNhw10r0NfjRqKkDBMM6SkaG55IazR_Nf9wKRPZ58K1GnpD3cU7Iyt97BuYaufggRx03wqgfYk5P4v8kUUYe8eUWEMqBE4t0TXGji-Kh4IQo5mgQ7PSeyMbIb6rsCsdn_lF3ub1gLAoQS5DRYh9qLSLKkC_Y3A7POg-66WhXKv6OA9N61cQNPQyUKpCx-4_dOvghHcjg2ZDAnIQcAHiX5ikEEFF5BASreBlGD5NXQciWGke3rWAlfUrZJLnOSuWoRcfDm-qx9_NQrWaxrympsMpX3Wcv9lGgBQKeU419F9GI66PqDKDW2db0pUENGXX69h_Tu2_a5KQ5qjo1F0CIC4KQXn5EirJs6f5KNHPSTIxfoKEizHgJI7d2Hf52qHOZUOzuKd1WdcavVd6XFH7FkjDFucXkfosu-7hzNTaceeinowfleLpDhoXuihwM7h_KuVzsaoBMnsjvvDfAMIDhxIR2pS3OIeR4SPUEkS74aKvRdKK_V5fqwoZghZsMePLSN6JaH9QYf6O5BOD_AG5DxV3ZlPU7amvLS_Szk2kjEBPJeFSTbDjRnVSGH08R8BWVBnSDfiBZ67J3mjgEUmQv-DYupZHcBzPtjw2rr0yNOpDeqZTr-YiWTDTZ6GGb5M1AWXMA_-e-sD-IsgIucerkpBeCoFNNP8xOAUAzkGl2FfUsc8lYK7YBm00"^^xsd:anyURI ;
    :canBeUsedWith :Composite ,
                   :Prototype ;
    :canBenefitFrom :Prototype ;
    :differsInAspectsFrom :Adapter ,
                          :ChainOfResponsibility ,
                          :Composite ,
                          :Proxy ,
                          :Strategy ;
    :hasCon :CodeMoreInflexibile ,
            :CodeMoreUgly ,
            :ImpactsEfficiency ;
    :hasPro :SingleResponsibilityPrinciple ;
    :hasSimilarStructure :ChainOfResponsibility ,
                         :Composite ,
                         :Proxy ;
    :isBasedOn :Composition ;
    :preserves :Interface ,
               :WrappeeObject ;
    :uses :RecursiveComposition ;
    :intent "The decorator pattern can be used to extend (decorate) the functionality of a certain object statically, or in some cases at run-time, independently of other instances of the same class, provided some groundwork is done at design time."@en ;
    rdfs:comment "Decorator is a structural design pattern that lets us attach new behaviors to objects by placing these objects inside special wrapper objects that contain the behaviors. Decorator allows for additional responsibilities to an object dynamically keeping the same interface. It allows behavior to be added to an individual object dynamically, without affecting the behavior of other instances of the same class. Decorators provide a flexible alternative to subclassing for extending functionality."@en ,
                 "Dekorater je načrtovalski vzorec, ki omogoča dodajanje novih vedenj objektom tako, da te objekte postavi v posebne ovojne objekte, ki vsebujejo ta vedenja. Dekorater omogoča dinamično dodajanje dodatnih odgovornosti objektu, pri čemer ohranja enak vmesnik. Omogoča dinamično dodajanje vedenja posameznemu objektu, ne da bi to vplivalo na vedenje drugih primerkov tega razreda. Dekoraterji predstavljajo prilagodljivo alternativo podrazredom za razširitev funkcionalnosti."@sl ;
    rdfs:label "Decorator"@en ,
               "Wrapper"@en ,
               "Dekorater"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/decorator"^^xsd:anyURI ;
    skos:prefLabel "Decorator"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "However, the patterns can also cooperate: you can use Decorator to extend the behavior of a specific object in the Composite tree."@en ,
                 "Vzorca pa uporabljamo tudi skupaj. Z vzorcem Decorator lahko razširimo obnašanje določenega objekta v drevesu Composite."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Prototype ;
    rdfs:comment "Designs that make heavy use of Composite and Decorator can often benefit from using Prototype. Applying the pattern lets you clone complex structures instead of re-constructing them from scratch."@en ,
                 "Načrti, ki intenzivno uporabljajo vzorca Composite ali Decorator, imajo lahko pogosto koristi od uporabe vzorca Prototype. Uporaba vzorca Prototype nam omogoča kloniranje zapletenih struktur, namesto da bi jih ponovno zgradili iz nič."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :canBenefitFrom ;
    owl:annotatedTarget :Prototype ;
    rdfs:comment "Designs that make heavy use of Composite and Decorator can often benefit from using Prototype. Applying the pattern lets you clone complex structures instead of re-constructing them from scratch."@en ,
                 "Načrti, ki intenzivno uporabljajo vzorca Composite ali Decorator, imajo lahko pogosto koristi od uporabe vzorca Prototype. Uporaba vzorca Prototype nam omogoča kloniranje zapletenih struktur, namesto da bi jih ponovno zgradili iz nič."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Adapter ;
    rdfs:comment "Adapter provides a completely different interface for accessing an existing object. On the other hand, with the Decorator pattern the interface either stays the same or gets extended. In addition, Decorator supports recursive composition, which isn’t possible when you use Adapter."@en ,
                 "Vzorec Adapter ponuja popolnoma drugačen vmesnik za dostop do objektov obstoječega razreda. Po drugi strani pa vzorec Decorator ohrani vmesnik oz. ga razširi. Poleg tega vzorec Decorator podpira rekurzivno kompozicijo, česar uporaba vmesnika Adapter ne omogoča."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :ChainOfResponsibility ;
    rdfs:comment "Med vzorcema Decorator in ChainOfResponsibility obstaja več bistvenih razlik. 1) Pri vzorcu ChainOfResponsibility lahko upravljalci izvajajo poljubne operacije neodvisno drug od drugega. Prav tako lahko kadar koli prekinejo nadaljnje posredovanje zahteve. 2) Po drugi strani pa lahko različni Decoratorji razširijo vedenje objekta, hkrati pa ohranijo skladnost s prvotnim vmesnikom. Poleg tega dekoraterji ne smejo prekiniti toka zahteve."@sl ,
                 "There are several crucial differences between ChainOfResponsibility pattern and Decorator pattern. The CoR handlers can execute arbitrary operations independently of each other. They can also stop passing the request further at any point. On the other hand, various Decorators can extend the object’s behavior while keeping it consistent with the base interface. In addition, decorators aren’t allowed to break the flow of the request."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "A Decorator is like a Composite but only has one child component. There’s another significant difference: Decorator adds additional responsibilities to the wrapped object, while Composite just 'sums up' its children's results."@en ,
                 "Vzorec Decorator je kot vzorec Composite, vendar ima samo enega naslednika/otroka. Pomembna razlika je tudi, da vzorec Decorator dodaja dodatne odgovornosti ovojnemu objektu, medtem ko vzorec Composite samo povzame/združi rezultate svojih naslednikov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Proxy ;
    rdfs:comment "Decorator and Proxy have similar structures, but very different intents. Both patterns are built on the composition principle, where one object is supposed to delegate some of the work to another. The difference is that a Proxy usually manages the life cycle of its service object on its own, whereas the composition of Decorators is always controlled by the client."@en ,
                 "Vzorca Decorator in Proxy imata podobno strukturo, a zelo različen namen. Oba vzporca uporabljata mehanizem kompozicije, kjer naj bi en objekt del dela prenesel na drugega. Razlika je v tem, da vzorec Proxy običajno sam upravlja življenjski cikel svojega storitvenega objekta (service class), medtem ko uporabo in sestavo objektov Decorator vedno nadzoruje odjemalec."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Decorator lets you change the skin of an object, while Strategy lets you change the guts."@en ,
                 "Vzorec Decorator omogoča spremembo zunanjosti objekta, medtem ko vzorec Strategy omogoča notranjo spremembo objekta."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :ChainOfResponsibility ;
    rdfs:comment "Chain of Responsibility and Decorator have very similar class structures. Both patterns rely on recursive composition to pass the execution through a series of objects. However, there are several crucial differences."@en ,
                 "Vzorca Decorator in ChainOfResponsibility imata zelo podobni strukturi razredov. Oba vzorca se zanašata na rekurzivno zgradbo, kjer se izvedba prenaša preko niza objektov. Vendar obstaja več bistvenih razlik."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "Composite and Decorator have similar structure diagrams since both rely on recursive composition to organize an open-ended number of objects. A Decorator is like a Composite but only has one child component. "@en ,
                 "Vzorca Composite in Decorator imata podobna strukturna diagrama, saj se oba zanašata na rekurzivno kompozicijo za organizacijo neomejenega števila objektov. Vzorec Decorator je kot vzorec Composite, vendar ima samo enega naslednika/otroka."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :Proxy ;
    rdfs:comment "Decorator and Proxy have similar structures, but very different intents. Both patterns are built on the composition principle, where one object is supposed to delegate some of the work to another."@en ,
                 "Vzorca Decorator in Proxy imata podobno strukturo, a zelo različen namen. Oba vzporca uporabljata mehanizem kompozicije, kjer naj bi en objekt del dela prenesel na drugega."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :Composition ;
    rdfs:comment "Decorator and Proxy patterns are built on the composition principle, where one object is supposed to delegate some of the work to another."@en ,
                 "Oba vzorca, Decorator and Proxy, uporabljata mehanizem kompozicije, kjer naj bi en objekt del dela prenesel na drugega."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :preserves ;
    owl:annotatedTarget :Interface ;
    rdfs:comment "Decorator pattern preserves the interface; it either stays the same or gets extended. In addition, Decorator supports recursive composition. With Decorator you access the object via an enhanced interface."@en ,
                 "Vzorec Decorator ohrani vmesnik oz. ga razširi. Poleg tega vzorec Decorator podpira rekurzivno kompozicijo. Pri uporabi vzorca Decorator dostopamo do objekta (Wrapee) prek razširjenega vmesnika."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :preserves ;
    owl:annotatedTarget :WrappeeObject ;
    rdfs:comment "The decorator pattern allows responsibilities to be added (and removed from) an object dynamically at run-time. It is achieved by defining Decorator objects that: 1) implement the interface of the extended (decorated) object (Component) transparently by forwarding all requests to it. 2) perform additional functionality before or after forwarding a request."@en ,
                 "Vzorec Dekorator omogoča dinamično dodajanje (in odstranjevanje odgovornosti) objektu med izvajanjem. To dosežemo z definiranjem objektov Decorator, ki: 1) implementirajo vmesnik razširjenega (okrašenega) objekta (komponente), tako da mu posredujejo vse zahteve. 2) izvede dodatne funkcije pred ali po posredovanju zahteve."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Decorator ;
    owl:annotatedProperty :uses ;
    owl:annotatedTarget :RecursiveComposition ;
    rdfs:comment "Chain of Responsibility and Decorator have very similar class structures. Both patterns rely on recursive composition to pass the execution through a series of objects."@en ,
                 "Vzorca ChainOfResponsibility in Decorator imata zelo podobni strukturi razredov. Oba vzorca se zanašata na rekurzivno zgradbo, kjer se izvedba prenaša preko niza objektov."@sl
] .

:Decoupling rdf:type owl:NamedIndividual ,
                     :Aspect ;
    rdfs:label "Decoupling"@en ;
    rdfs:comment "The pattern decouples the sender of a request from its receiver, allowing you to change the handling of the request without affecting the rest of the system."@en ,
                 "We can reduce coupling between various components of a program."@en .

:DejanLavbic rdf:type owl:NamedIndividual ,
                      foaf:Person ;
    foaf:mbox <mailto:dejan@lavbic.net> ;
    foaf:name "Dejan Lavbič" ;
    rdfs:label "Dejan Lavbič" .

:Encapsulation rdf:type owl:NamedIndividual ,
                        :OOConcept ;
    rdfs:comment "Encapsulation is bundling data (attributes) and behavior (methods) that operate on that data into a single unit — typically a class — and restricting direct access to some of the object's components."@en ,
                 "Enkapsulacija je združevanje podatkov (atributov) in vedenja (metod), ki delujejo na teh podatkih, v en sam sklop - običajno razred - in omejevanje neposrednega dostopa do nekaterih komponent objekta."@sl ;
    rdfs:label "Encapsulation"@en ,
               "Enkapsulacija"@sl .

:Facade rdf:type owl:NamedIndividual ,
                 :StructuralPattern ;
    :hasStructure :FacadeStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/fLBBRjim4BppAmZde0IDT2jGe860cB9ppC6zDJsiIKPcH942ISbrYlvxIUgHH4g3j840WvYTNS_EJe8Il0KAZ7_5EsTQwbh3KOAGhOHgm42DgGHhyI-4yHveLHhTAaQqr0OV3yBnW6l3kEcniy_RzPSDyIWOeuyzk9U-4_r-FbLfnzynb4QiD73oqBrMhYSnC5K4Nyni_2WeNnzxjYN-s_odsgTflI1dG5bVuieXxrQ22tulbA3Y0N0feLFYW0qy6ivqXuN2NSsj4fNkWhKa6hh2H0hVxnzWn_VL5JudboSkfJvUu3n_8lT7wid3EwoPOYbKzKtlshqzMSVhs_q3fyx6acwSq0haDMEYV_MTePYc_lSJjbDVmmq4qlb5M7tystbhBs211YbPbZqR3Fx01svcOnDyurriCDMA6kuJ8Ef6yjgl7aasU0NZ7H4Q3xeYEl1-tgbfppkrycuHgLkMv_wwc_157QFqYJeaE2gVmCYwZeRlBhMX1y6YuV_Kl_vWF_bWVx7izoOlbao_-ohZwaUAvmkWkQ2_Suj5qXlTyKSOCXtpcnfH7boQ3n55GpmcU974WP0nVLHPFbV-TddzThb0YvY-JYJl9HRe3m00"^^xsd:anyURI ;
    :canBeImplementedAs :Singleton ;
    :canBeSimplifiedTo :Singleton ;
    :differsInAspectsFrom :Adapter ,
                          :Flyweight ,
                          :Mediator ;
    :hasAspect :ClassSubsystem ;
    :hasCon :GodObject ;
    :isSimilarTo :Mediator ,
                 :Proxy ;
    :offersNewInterface :ClassSubsystem ,
                        :ServiceClass ;
    :organizesCollaboration :ClassSubsystem ;
    :intent "Facade is a structural design pattern that provides a simplified interface to a library, a framework, or any other complex set of classes."@en ;
    rdfs:comment "Facade is a structural design pattern that provides a simplified interface to a library, a framework, or any other complex set of classes. Facade defines a higher-level interface that makes the subsystem easier to use. It is an object that serves as a front-facing interface masking more complex underlying or structural code. Facade is often used when a system is very complex or difficult to understand because the system has many interdependent classes or because its source code is unavailable."@en ,
                 "Fasada je načrtovalski vzorec, ki zagotavlja poenostavljen vmesnik za knjižnico, ogrodje ali katero koli drugo zapleteno množico razredov. Fada definira višjenivojski vmesnik, ki olajša uporabo podsistema. Je objekt, ki služi kot čelni vmesnik, in zakriva bolj zapleteno kodo v ozadju. Fasada se pogosto uporablja, kadar imamo opravka z zelo zapletenim ali težko razumljivim sistemom, zaradi velike medsebojne odvisnosti razredov ali neobstoječe izvorna kode sistema."@sl ;
    rdfs:label "Facade"@en ,
               "Fasada"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/facade"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :canBeImplementedAs ;
    owl:annotatedTarget :Singleton ;
    rdfs:comment "A Facade class can often be transformed into a Singleton since a single facade object is sufficient in most cases."@en ,
                 "Razred Facade pogosto lahko implementiramo v skladu z vzorcem Singleton, saj v večini primerov zadostuje en sam objekt razreda Facade."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Adapter ;
    rdfs:comment "Facade defines a new interface for existing objects, whereas Adapter tries to make the existing interface usable. Adapter usually wraps just one object, while Facade works with an entire subsystem of objects."@en ,
                 "Vzorec Facade definira nov vmesnik za obstoječe razrede, medtem ko vzorec Adapter poskuša povezati nezdružljive vmesnike. Vzorec Adapter se osredotoča samo na en razred (service class), medtem ko se vzorec Facade ukvarja s celotnim kompleksnim podsistemom razredov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Flyweight ;
    rdfs:comment "Flyweight shows how to make lots of little objects, whereas Facade shows how to make a single object that represents an entire subsystem."@en ,
                 "Vzorec Flyweight demonstrira, kako narediti veliko majhnih objektov (z intrinzičnim stanjem), medtem ko vzorec Facade demonstrira, kako narediti en sam objekt, ki predstavlja celoten podsistem."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Facade and Mediator have similar jobs: they try to organize collaboration between lots of tightly coupled classes. However, Facade defines a simplified interface to a subsystem of objects, but it doesn’t introduce any new functionality. The subsystem itself is unaware of the facade. Objects within the subsystem can communicate directly. On the other hand, Mediator centralizes communication between components of the system. The components only know about the mediator object and don’t communicate directly."@en ,
                 "Vzorca Facade in Mediator imata podobno nalogo: organizirati sodelovanje med številnimi tesno povezanimi razredi. Razlika med tema dvema vzorcema je, da vzorec Facade definira poenostavljen vmesnik za podsistem razredov, vendar ne uvaja novih funkcionalnosti. Sam podsistem razredov se ne zaveda fasade. Objekti znotraj podsistema lahko neposredno komunicirajo. Po drugi strani vzorec Mediator centralizira komunikacijo med komponentami sistema. Komponente sistema poznajo le razred Mediator in med seboj ne komunicirajo neposredno."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :hasAspect ;
    owl:annotatedTarget :ClassSubsystem ;
    rdfs:comment "Facade defines simplified interface. Facade defines a simplified interface to a subsystem of objects, but it doesn’t introduce any new functionality. The facade only exposes the existing functionality from a different perspective."@en ,
                 "Vzorec Facade ponudi poenostavljen vmesnik. Facade definira poenostavljen vmesnik za podsistem objektov, vendar ne uvaja novih funkcionalnosti. Vzorec Fasada izpostavi obstoječo funkcionalnost iz druge perspektive."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Facade and Mediator have similar jobs: they try to organize collaboration between lots of tightly coupled classes."@en ,
                 "Vzorca Facade in Mediator imata podobno nalogo: organizirati sodelovanje med številnimi tesno povezanimi razredi."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Proxy ;
    rdfs:comment "Facade is similar to Proxy in that both buffer a complex entity and initialize it on its own. Unlike Facade, Proxy has the same interface as its service object, which makes them interchangeable."@en ,
                 "Vzorec Facade je podoben vzorcu Proxy, saj oba medpomnita kompleksno entiteto in jo inicializirata sama."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :offersNewInterface ;
    owl:annotatedTarget :ClassSubsystem ;
    rdfs:comment "Facade provides a simplified interface to a library, a framework, or any other complex set of classes that makes it easier to use."@en ,
                 "Vzorec Facade predstavi nov vmesnik do podsistema, knjižnice, ogrodja ali druge zapletene množice razredov, kar omogoča enostavnejšo rabo podsistema."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :offersNewInterface ;
    owl:annotatedTarget :ServiceClass ;
    rdfs:comment "Facade works with an entire subsystem of objects. Facade defines a new interface for existing objects (masking more complex underlying or structural code)."@en ,
                 "Vzorec Facade se ukvarja s celotnim kompleksnim podsistemom razredov. Vzorec Facade definira nov vmesnik za obstoječe razrede (z namenom prikrivanje bolj zapletene osnovne ali strukturne kode)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Facade ;
    owl:annotatedProperty :organizesCollaboration ;
    owl:annotatedTarget :ClassSubsystem ;
    rdfs:comment "Facade try to organize collaboration between lots of tightly coupled classes."@en ,
                 "Vzorec Fasada poskuša organizirati sodelovanje med številnimi tesno povezanimi razredi."@sl
] .

:FactoryMethod rdf:type owl:NamedIndividual ,
                        :CreationalPattern ;
    :hasStructure :FactoryMethodStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dLF1Rjim3BthAmZlq1Q3THim15s0EDk0dJPWjs4NngOJrJPbqBA3PTs_JvRj98rJhDt5i1uV7vz8gYaCroXOGLfYqy1l1R31jDYARJbRsz8Ax7V6KOzRoKW6xCsxpydxJskFeeZT3-2cz9dgZrBDKPMjenU8fW7R2lxoK6xP3QGCfGZW4ysJr93c1Bdn8MAdr8swWO-K6pQfUK3ObjYnsO7WGIYp7HY6hgA6JM4xJrPVs97ac1940F1DRDQcplz5WCtnU7_lyoRUSXak5CUn_xw5p7vtRPxVtlKcrw694QmjfqAEVlAPw6fKdO8Zllf7Md8zBJbB4qBd6p7GnaFlKMjzvhIn5NsjIT0PozvlZwKzUvAylLjCLQzTPbHUFRLpHES5_qCykIgUl5ByOWbgsz41mxYdxcWjPhjpMY-FURCBnN5Rnu_BgQDgPkevmZHONwMjzUEyn3J26I4u_u47ngem_QuMVcRiK1vCxpwyferrpbPWyza8V5_yiHN7mBIVXVt8YRFm94Ufad8NX0R6OX5Tx4YaJdjOmuVBfljehKyFuAIkr5y0"^^xsd:anyURI ;
    :canBeStartingPointFor :AbstractFactory ,
                           :Builder ,
                           :Prototype ;
    :canBeUsedWith :Iterator ;
    :hasCon :CodeMoreComplicated ;
    :hasPro :LooseCoupling ,
            :OpenClosedPrinciple ,
            :SingleResponsibilityPrinciple ;
    :isBasedOn :Inheritance ;
    :isPatternSpecialization :TemplateMethod ;
    :intent "Factory Method is a creational design pattern that provides an interface for creating objects in a superclass, but allows subclasses to alter the type of objects that will be created."@en ;
    rdfs:comment "Factory Method defines an interface for creating a single object in a superclass, but let subclasses decide which class to instantiate. Factory Method lets a class defer instantiation to subclasses. This pattern uses factory methods to deal with the problem of creating objects without having to specify their exact classes. Rather than by calling a constructor, this is accomplished by invoking a factory method to create an object."@en ,
                 "Tovarniška metoda definira vmesnik za ustvarjanje enega samega objekta v nadrazredu, vendar podrazredom omogoča, da se sami odločijo, kateri razred bodo ustvarili. Tovarniška metoda razredu omogoča, da odloži ustvarjanje instanc podrazredov. Ta načrtovalski vzorec uporablja tovarniške metode za reševanje problema ustvarjanja objektov, ne da bi bilo treba določiti njihove natančne razrede. Namesto s klicem konstruktorja se to doseže s klicem tovarniške metode za ustvarjanje objekta."@sl ;
    rdfs:label "Factory Method"@en ,
               "Virtual Constructor"@en ,
               "Tovarniška metoda"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/factory-method"^^xsd:anyURI ;
    skos:prefLabel "Factory Method"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :FactoryMethod ;
    owl:annotatedProperty :canBeStartingPointFor ;
    owl:annotatedTarget :AbstractFactory ;
    rdfs:comment "Factory Method is less complicated and more customizable via subclasses; while AbstractFactory is more flexible, but more complicated."@en ,
                 "Veliko načrtov začnemo z vzorcem FactoryMethod. Factory Method je manj zapletena in bolj prilagodljiv prek podrazredov, medtem ko je vzorec AbstractFactory bolj prilagodljiv, vendar bolj zapleten."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :FactoryMethod ;
    owl:annotatedProperty :canBeStartingPointFor ;
    owl:annotatedTarget :Builder ;
    rdfs:comment "Factory Method is less complicated and more customizable via subclasses; while Builder is more flexible, but more complicated."@en ,
                 "Veliko načrtov začnemo z vzorcem FactoryMethod. Factory Method je manj zapletena in bolj prilagodljiv prek podrazredov, medtem ko je vzorec Builder bolj prilagodljiv, vendar bolj zapleten."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :FactoryMethod ;
    owl:annotatedProperty :canBeStartingPointFor ;
    owl:annotatedTarget :Prototype ;
    rdfs:comment "Factory Method is less complicated and more customizable via subclasses; while Prototype is more flexible, but more complicated."@en ,
                 "Veliko načrtov začnemo z vzorcem FactoryMethod. Factory Method je manj zapletena in bolj prilagodljiv prek podrazredov, medtem ko je vzorec Prototype bolj prilagodljiv, vendar bolj zapleten."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :FactoryMethod ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Iterator ;
    rdfs:comment "Vzorec tovarniška metoda lahko uporabimo skupaj z vzorcem iterator, da omogočimo podrazredom zbirk vračanje različnih vrst iteratorjev, ki so združljivi z zbirkami."@sl ,
                 "You can use Factory Method along with Iterator to let collection subclasses return different type of iterators that are compatible with the collections."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :FactoryMethod ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :Inheritance ;
    rdfs:comment "Factory Method doesn’t require a complicated initialization step."@en ,
                 "Vzorec FactoryMethod temelji na dedovanju, vendar ne potrebuje zapletenega koraka inicializacije pri kreiranju objekta."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :FactoryMethod ;
    owl:annotatedProperty :isPatternSpecialization ;
    owl:annotatedTarget :TemplateMethod ;
    rdfs:comment "A Factory Method may serve as a step in a large Template Method."@en ,
                 "Obenem vzorec FactoryMethod lahko služi kot korak pri implementaciji obsežnega vzorca TemplateMethod."@sl
] .

:FamiliesOfObjects rdf:type owl:NamedIndividual ,
                            :Aspect ;
    rdfs:comment "Družina objektov se nanaša na skupek med seboj povezanih objektov, ki so zasnovani tako, da delujejo skupaj in imajo skupen namen, pogosto pa sledijo enotnemu vmesniku ali zasnovi."@sl ,
                 "Family of objects refers to a set of related objects that are designed to work together and share a common purpose, often following a consistent interface or design."@en ;
    rdfs:label "Družine objektov"@sl ,
               "Families of objects"@en .

:Flexibility rdf:type owl:NamedIndividual ,
                      :Aspect ;
    rdfs:label "Flexibility"@en , "Code change flexibility"@en ;
    rdfs:comment "We can swap algorithms used inside an object at runtime."@en .

:Flyweight rdf:type owl:NamedIndividual ,
                    :StructuralPattern ;
    :hasStructure :FlyweightStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLFBafim4Bpp5LFEmJPPV4jLohls8IJ-WRrbomSP1j1QrX0X8DwK_psIUDlUP3bGC8-UxjPexirX9yuryZJJZ_2iLHdfKg4tzxpYo6NE53j195XHm1yFuC2YOwgeb758WXJK6TTeuwHYL4tiqvVTjwy_GXDbIb7T10_2T7gNCQeaZHy0ZLmiLUniGWb97Gw12Tu0qxHenMHXKYYrP_JCuJicNFA8lp981Qiapq2nDuKnLS0bL2Si93zIPSM7Jl8CGi5Dl_bWHVVzz0IByE6CGb2zXErsL6pOuU-kklsn2WCe9VzLuhDcJba0IMUw_Gi2y_xSTImKviWqbwahVnZtBbqXvQXC0Sd5qbhGZUyFSiSYJUhSyBY9DeGY5cMu7h8l-n6J57MVkA9pV-BLg7R6j7E4FmYOQBlSd5DE5RwnzaIS-tuGKos3RUUMr_aSA3lP9Au5UpSEK8VHPmQKITJH-SboRhRChiYHJeO3Kw_SCd8BV22jwGIKtCu5y7sU-3uidDalKpjWip5vMGhX-_kbSmpWNk4UDk2IzZ4TM1l8zuy7uE8cApGNMPhIkvWUojZTm5Q6m4HR4QqFw_Ni8ziuSvDqnWlVNuqIXl5quVkYVky7KKbZr-gVI_TVkgCxOLdrSrRlx5e7-1S0"^^xsd:anyURI ;
    :canBeUsedWith :Composite ;
    :differsInAspectsFrom :Facade ,
                          :Singleton ;
    :hasCon :CodeMoreComplicated ;
    :hasPro :MemorySaver ;
    :isSimilarTo :Singleton ;
    skos:related :Singleton ;
    :intent "Flyweight is a structural design pattern that lets you fit more objects into the available amount of RAM by sharing common parts of state between multiple objects instead of keeping all of the data in each object."@en ;
    rdfs:comment "Flyweight design pattern refers to an object that minimizes memory usage by sharing some of its data with other similar objects. The flyweight pattern is useful when dealing with a large number of objects that share simple repeated elements which would use a large amount of memory if they were individually embedded. It is common to hold shared data in external data structures and pass it to the objects temporarily when they are used."@en ,
                 "Načrtovalski vzorec 'Lahki objekt' se nanaša na objekt, ki zmanjša porabo pomnilnika tako, da nekatere svoje podatke deli z drugimi podobnimi objekti. Načrtovalski vzorec 'Lahki objekt' je uporaben pri delu z velikim številom objektov, ki si delijo preproste ponavljajoče se elemente, ki bi porabili veliko pomnilnika, če bi bili zapisani v vsakem objektu. Običajno se skupni podatki hranijo v zunanjih podatkovnih strukturah in se začasno posredujejo objektom, ko so ti potrebni."@sl ;
    rdfs:label "Flyweight"@en ,
               "Cache"@en,
               "Lahki objekt"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/flyweight"^^xsd:anyURI ;
    skos:prefLabel "Flyweight"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Flyweight ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "Vzorec Flyweight lahko uporabimo skupaj z vzorcem Composite. Pri tem skupne liste drevesa implementiramo kot objekte tipa Flyweights in s tem prihranimo nekaj pomnilnika (angl. RAM)."@sl ,
                 "You can implement shared leaf nodes of the Composite tree as Flyweights to save some RAM."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Flyweight ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Facade ;
    rdfs:comment "Flyweight shows how to make lots of little objects, whereas Facade shows how to make a single object that represents an entire subsystem."@en ,
                 "Vzorec Flyweight demonstrira, kako narediti veliko majhnih objektov (z intrinzičnim stanjem), medtem ko vzorec Facade demonstrira, kako narediti en sam objekt, ki predstavlja celoten podsistem."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Flyweight ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Singleton ;
    rdfs:comment "Med vzorcema Flyweight in Singleton sta dve temeljni razliki: 1) razred Singleton (v vzorcu Singleton) ima lahko samo eno instanco, medtem, ko ima razred Flyweight (v vzorcu Flyweight) več instanc / primerkov z različnimi intrinzičnimi stanji. 2) razred Singleton (v vzorcu Singleton) je lahko mutable, objekti Flyweight (v vzorcu Flyweight) pa so immutable."@sl ,
                 "There are two fundamental differences between Flyweight and Singleton patterns: 1) There should be only one Singleton instance, whereas a Flyweight class can have multiple instances with different intrinsic states. 2) The Singleton object can be mutable. Flyweight objects are immutable."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Flyweight ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Singleton ;
    rdfs:comment "Flyweight would resemble Singleton if you somehow managed to reduce all shared states of the objects to just one flyweight object."@en ,
                 "Vzorec Flyweight bi lahko bil podoben vzorcu Singleton, če bi vsa deljena stanja (objekte Flyweights) zreducirali na eno samo stanje (en sam objekt razreda Flyweight)."@sl
] .

:GodObject rdf:type owl:NamedIndividual ,
                    :Aspect ;
    rdfs:label "God object"@en ;
    rdfs:comment "/ Coupling / Over time a mediator can evolve into a God Object. The Mediator pattern can introduce coupling between objects, as they all need to know about the Mediator object. This can make it difficult to add new objects to the system, as they will need to be updated to know about the Mediator object."@en ,
                 "A facade can become a god object coupled to all classes of an app."@en ;
    rdfs:seeAlso "https://www.gofpattern.com/design-patterns/" .

:HighLevelAbstraction rdf:type owl:NamedIndividual ,
                               :Aspect ;
    rdfs:label "High level abstraction"@en ;
    rdfs:comment "The client code works with high-level abstractions. It isn’t exposed to the platform details."@en .

:ImpactsEfficiency rdf:type owl:NamedIndividual ,
                            :Aspect ;
    owl:sameAs :PotentiallySlow ;
    rdfs:label "Impacts efficiency"@en ;
    rdfs:comment "May impact efficiency in very large structures."@en ,
                 "The code may become more complicated since you need to introduce a lot of new classes."@en ,
                 "The repeat nesting of many decorators causes repeated JMPs in the generated assembly, which can have a severe performance impact."@en ,
                 "Using an iterator may be less efficient than going through elements of some specialized collections directly."@en .

:ImprovedMaintainability rdf:type owl:NamedIndividual ,
                                  :Aspect ;
    rdfs:label "Improved maintainability"@en ;
    rdfs:comment "You can manage the lifecycle of the service object when clients don’t care about it."@en .

:ImprovedPerformance rdf:type owl:NamedIndividual ,
                              :Aspect ;
    rdfs:label "Improved performance"@en ;
    rdfs:comment "A visitor object can accumulate some useful information while working with various objects. This might be handy when you want to traverse some complex object structure, such as an object tree, and apply the visitor to each object of this structure."@en .

:InconsistentNotification rdf:type owl:NamedIndividual ,
                                   :Aspect ;
    rdfs:label "Inconsistent notification"@en ;
    rdfs:comment "Subscribers are notified in random order."@en .

:InconsistentState rdf:type owl:NamedIndividual ,
                            :Aspect ;
    rdfs:label "Inconsistent state"@en ;
    rdfs:comment "Most dynamic programming languages, such as PHP, Python and JavaScript, can’t guarantee that the state within the memento stays untouched."@en .

:IncrementalObjectCreation rdf:type owl:NamedIndividual ,
                                    :Aspect ;
    rdfs:label "Incremental object creation"@en ;
    rdfs:comment "Construct objects step-by-step, defer construction steps or run steps recursively."@en .

:Inheritance rdf:type owl:NamedIndividual ,
                      :OOConcept ;
    rdfs:label "Dedovanje"@sl ,
               "Inheritance"@en .

:Interface rdf:type owl:NamedIndividual ,
                    :OOConcept ;
    rdfs:comment "Interface in OOP acts as a contract or blueprint."@en ,
                 "Interface is a datatype that acts as an abstraction of a class. It describes a set of method signatures."@en ,
                 "Vmesnik je podatkovni tip, ki deluje kot abstrakcija razreda. Opisuje niz podpisov metod."@sl ;
    rdfs:label "Interface"@en ,
               "Vmesnik"@sl .

:Iterator rdf:type owl:NamedIndividual ,
                   :BehavioralPattern ;
    :hasStructure :IteratorStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLF1Rjim3BthAuZja0IhTHimT84FzJQWX-tIsswCp2Ig5IcW5MVjjdyVBTTEudXRBmRrJ3xoFKepDOFxI8mny4TuY7mmyS2aPahLbVLxPDo1SLZNy5C1hD1K6mu7NnR11ORZraPgyS0bSOUzVV_bxiFdGb1a3iSEN3cfLB_FMNs8z0fIax0DuvD0w-1ZbrGYLmcyu3nHTMMHqTVoYtnKeca6dsXjlJNs4M7ZiF5s2upFJ6Lem7feTbHxMuMcDQ18ijz0uQpKIu1r7o-NC2zkdiYvS5n0dYjrxyN5DHgIlDxGhcGuIP4Til8yQS-oJBxlO4Fn6_s8yqKwRR7-6fZcYrin8RXMunN_of4uuSX46_nPfqlyNpqD4qRgnskRzN7RS50Vl2IUybvy6AE96CpG-NP8EKsJKcogaDD3nBJcVfmnvLnG03D5j7YTPsC9Oxycy5Q6rdeOgul_vzNePkr3Gy_uSeVIVSdASFHPVYgQmYysfoQMgRMZTTJwdETQWZxizQz9ogkbdQV-XGsMMTjKPXnNgqxtTznRUO3jwwd2JaGXFzfMkle3"^^xsd:anyURI ;
    :canBeUsedWith :Composite ,
                   :FactoryMethod ,
                   :Memento ,
                   :Visitor ;
    :hasCon :ImpactsEfficiency ,
            :Overhead ;
    :hasPro :OpenClosedPrinciple ,
            :SingleResponsibilityPrinciple ,
            :SupportsDeferredCodeExecution ,
            :ThreadSafe ;
    :intent "Iterator is a behavioral design pattern that lets you traverse elements of a collection without exposing its underlying representation (list, stack, tree, etc.)."@en ;
    rdfs:comment "Iterator is a design pattern that provides a way to access the elements of an aggregate object sequentially without exposing its underlying representation. Iterator pattern is a design pattern in which an iterator (object) is used to traverse a container and access the container's elements. The iterator pattern decouples algorithms from containers; in some cases, algorithms are necessarily container-specific and thus cannot be decoupled."@en ,
                 "Iterator je vedenjski načrtovalski vzorec, ki omogoča dostop do elementov nekega vsebovalnika (zbirke) in njihov pregled, ne da bi razkril, kako so ti elementi med seboj povezani. Pri načrtovalskem vzorecu 'Iterator' se (objekt) iterator uporablja za sprehod po vsebniku in dostop do elementov vsebovalnika. Načrtovalski vzorec 'Iterator' ločuje algoritme od vsebovalnikov; v nekaterih primerih so algoritmi nujno specifični za vsebovalnik in jih zato ni mogoče ločiti."@sl ;
    rdfs:label "Iterator"@en ,
               "Iterator"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/iterator"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Iterator ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "We can use Iterators to traverse Composite trees."@en ,
                 "Za sprehod po drevesu vzorca Composite lahko uporabimo iteratorje."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Iterator ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :FactoryMethod ;
    rdfs:comment "Vzorec FactoryMethod lahko uporabimo skupaj z vzorcem Iterator. Na ta način lahko vrnemo različne iteratorje glede na vrsto zbirke (vsebovalnika)."@sl ,
                 "We can use Factory Method along with Iterator to let collection subclasses return different types of iterators that are compatible with the collections."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Iterator ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Memento ;
    rdfs:comment "Vzorec Memento lahko uporabljamo z vzorcem Iterator za zajem trenutnega stanja iteracije (iterator position) in zmožnosti poznejše ponovne vrnitve v to stanje."@sl ,
                 "We can use Memento along with Iterator to capture the current iteration state and roll it back if necessary."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Iterator ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Visitor ;
    rdfs:comment "Vzorec Visitor lahko uporabimo skupaj z vzorcem Iterator za sprehod po zapleteni podatkovni strukturi in nad elementi katere izvajamo operacije, tudi če elementi pripadajo različnim razredom."@sl ,
                 "We can use Visitor along with Iterator to traverse a complex data structure and execute some operation over its elements, even if they all have different classes."@en
] .

:LooseCoupling rdf:type owl:NamedIndividual ,
                        :Aspect ;
    rdfs:label "Loose coupling"@en .

:ManageMultithreadedEnvironment rdf:type owl:NamedIndividual ,
                                         :Aspect ;
    owl:differentFrom :ThreadSafe ;
    rdfs:label "Manage multithreaded environment"@en ;
    rdfs:comment "Requires special treatment in a multithreaded environment so that multiple threads won’t create a singleton object several times."@en .

:MarkoPozenel rdf:type owl:NamedIndividual ,
                       foaf:Person ;
    foaf:mbox <mailto:marko.pozenel@fri.uni-lj.si> ;
    foaf:name "Marko Poženel" ;
    rdfs:label "Marko Poženel" .

:Mediator rdf:type owl:NamedIndividual ,
                   :BehavioralPattern ;
    :hasStructure :MediatorStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dLHDRzf04BtxLup80UB4A9T65IL8yRf8FLGzzDQgXuazXWtshZLUY4BR_zvT6_07K24kbkRDxBpvU9wXDuIlb4WqcZ_1TyFhsAoPlA7dbIkf2cJC8SwmBE6t1_22yMh1UgqIeJFDyBQKXXokEI6kiPiFy_3ZPs5HPDPlDVYIsPVUttPMfGrTa3Iki0NZkuLIhOneW4w-9atzn32gqhf86S_sCuI8KgbaB5yH5Xbkb5m2uvOfqHkG2ZOvbKgkzCOr_qKPuXHZWW4S1WJMmB8nfrFxRXytcrND145WltUkEvc-ZqfIjeTRLwcefZW0eVD2ArlLSvskPK-d8t4FDu-Fy_d3m-qX9UIJ0scBGXV4QAHMpwFJ166F8BoM83n387e4ube2SOOWwX54rn94VG8LCnawh797qqFhrF5XGLqpx9gYQqRdnU0W9epDjsfrBJFicg9hxfheQRdG6zfYfTgZ1iRhOlndraocfRM0vM9fWbFEy7zE0K56wMbVTEmxhidVnpJ5N18aJWNjosnAloWgiaE4SiNspkp7Hx15oAWe9UIeS46vZNDN9aKOTkRsSocJXDIle5jRCxiJ0L6zjHzOI7kmtBLPQKU0_2hTugfRw3e6dHx9S38PT0KqiABmVPdwFkmWU7fgoTI91jeAip7LkTqHLVEecVRrMOxsl-8Oyl6ErVVDKfQ-t-Jv1m00"^^xsd:anyURI ;
    :canBeUsedWith :Observer ;
    :differsInAspectsFrom :Facade ,
                          :Observer ;
    :encapsulatesOperation :SystemComponents ;
    :hasAspect :ClassSubsystem ,
               :SystemComponents ;
    :hasCon :CodeMoreComplicated ,
            :GodObject ,
            :SinglePointOfFailure ;
    :hasPro :Decoupling ,
            :OpenClosedPrinciple ,
            :PromoteCodeReuse ,
            :SingleResponsibilityPrinciple ;
    :isSimilarTo :ChainOfResponsibility ,
                 :Command ,
                 :Facade ,
                 :Observer ;
    :usesIndirectConnection :SendersReceivers ;
    skos:related :ChainOfResponsibility ,
                 :Command ,
                 :Observer ;
    :centralizesCommunication :ClassSubsystem ;
    :intent "Mediator is a behavioral design pattern that lets you reduce chaotic dependencies between objects. The pattern restricts direct communications between the objects and forces them to collaborate only via a mediator object."@en ;
    rdfs:comment "Mediator pattern defines an object that encapsulates how a set of objects interact. Program complexity may increase, especially during repeated maintenance and/or refactoring, and the problem of communication between these classes may become more complex. This makes the program harder to read and maintain. With the Mediator pattern, communication between objects is encapsulated within a mediator object. Objects no longer communicate directly with each other, but instead communicate through the Mediator (object). This reduces the dependencies between communicating objects, thereby reducing coupling."@en ,
                 "Načrtovalski vzorec Mediator definira objekt, ki določa, kako objekti sistema med seboj komunicirajo. Zlasti med ponavljajočim se vzdrževanjem in/ali refaktoriranjem se zapletenost programa se lahko poveča, pojavi se problem bolj zapletene komunikacije med objekti. Zaradi tega je program težje berljiv in težji za vzdrževanje."@sl ;
    rdfs:label "Mediator"@en ,
               "Intermediary"@en ,
               "Controller"@en ,
               "Posrednik"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/mediator"^^xsd:anyURI ;
    skos:prefLabel "Mediator"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Observer ;
    rdfs:comment "Glavni cilj vzorca Mediator je odpraviti medsebojne odvisnosti med množico komponent sistema. Namesto medsebojne odvisnosti, te komponente postanejo odvisne od enega samega razreda ('Concrete Mediator'), ki poveze podatke in metode (encapsulate relations) med različnimi komponentami (various components that are not aware of other components). Glavni cilj vzorca Observer je vzpostaviti dinamične enosmerne povezave med razredi, kjer nekateri razredi ('Concrete Subscribers', Observers) delujejo kot podrejeni drugim (Publisher, Subject). Glavni cilj vzorca Observer je vzpostaviti dinamične enosmerne povezave med razredi, kjer nekateri razredi ('Concrete Subscribers', Observers) delujejo kot podrejeni drugim (Publisher, Subject). Ko smo v dvomih, se spomnimo, da lahko vzorec Mediator implementiramo na druge načine. Na primer, vse komponente (razreda 'Component') lahko trajno povežemo z istim objektom posrednika (razred Mediator). Taka izvedba ni podobna vzorcu Observer, vendar je še vedno primerek vzorca Mediator. Predstavljajmo si program, kjer so vse komponente ('Component') postale tudi založniki (Publisher, Subject), kar omogoča dinamično medsebojno povezovanje. V tem primeru nimamo centraliziranega osrednega razreda (Mediator), ampak samo porazdeljeno množico opazovalcev (Observers). Vzorec Observer porazdeli komunikacijo z uvedbo objektov Observer in Subject, medtem ko objekt Mediator enkapsulira komunikacijo med drugimi objekti. V vzorcu Observer ni nobenega posameznega objekta, ki bi zajemal omejitev."@sl ,
                 "The primary goal of Mediator is to eliminate mutual dependencies among a set of system components. Instead, these components become dependent on a single mediator object. The goal of Observer is to establish dynamic one-way connections between objects, where some objects act as subordinates of others. When you’re confused, remember that you can implement the Mediator pattern in other ways. For example, you can permanently link all the components to the same mediator object. This implementation won’t resemble Observer but will still be an instance of the Mediator pattern. Now imagine a program where all components have become publishers, allowing dynamic connections between each other. There won’t be a centralized mediator object, only a distributed set of observers. Observer distributes communication by introducing Observer and Subject objects, whereas a Mediator object encapsulates the communication between other objects. In the Observer pattern, there is no single object that encapsulates a constraint."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :encapsulatesOperation ;
    owl:annotatedTarget :SystemComponents ;
    rdfs:comment "Mediator enkapsulira, kako nabor objektov medsebojno rokuje."@sl ,
                 "Mediator object encapsulates how a set of objects interact."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :hasAspect ;
    owl:annotatedTarget :SystemComponents ;
    rdfs:comment "Glavni cilj vzorca Mediator je odpraviti medsebojne odvisnosti med množico komponent sistema. Namesto medsebojne odvisnosti, te komponente postanejo odvisne od enega samega razreda ('Concrete Mediator'), ki poveže podatke in metode (encapsulate relations) med različnimi komponentami (various components that are not aware of other components)."@sl ,
                 "The primary goal of Mediator is to eliminate mutual dependencies among a set of system components. Instead, these components become dependent on a single mediator object."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :ChainOfResponsibility ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Facade ;
    rdfs:comment "Facade and Mediator have similar jobs: they try to organize collaboration between lots of tightly coupled classes."@en ,
                 "Vzorca Facade in Mediator imata podobno nalogo: organizirati sodelovanje med številnimi tesno povezanimi razredi."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Observer ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Observer ;
    rdfs:comment "Razliko med vzorcema Mediator in Observer je včasih težko opredeliti (diff is elusive, difficult to obtain). Večinoma lahko implementiramo enega od teh dveh vzorcev; včasih pa lahko uporabimo oba istočasno. Oba vzorca se uporabljata za zagotavljanje sklopljenega načina komunikacije komponent, vendar je način uporabe različen."@sl ,
                 "The difference between Mediator and Observer is often elusive. In most cases, you can implement either of these patterns; but sometimes you can apply both simultaneously. Both patterns are used to provide decoupled way for component communication, but usage is different."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :usesIndirectConnection ;
    owl:annotatedTarget :SendersReceivers ;
    rdfs:comment "Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object."@en ,
                 "Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :centralizesCommunication ;
    owl:annotatedTarget :ClassSubsystem ;
    rdfs:comment "Mediator organizes collaboration between system components by centralizing communication. Mediator centralizes communication between components of the system. The components only know about the Mediator object and don’t communicate directly. The mediator 'adds' functionality because it combines different existing functionality to create a new one."@en ,
                 "Mediator organizira sodelovanje med komponentami sistema tako, da centralizira komunikacijo. Mediator centralizira komunikacijo med komponentami sistema. Komponente sistema poznajo le razred Mediator in med seboj ne komunicirajo neposredno. Mediator 'doda' funkcionalnost, ker združuje različne obstoječe funkcionalnosti, da ustvari novo."@sl ;
    rdfs:label "centralizes communication"@en ,
               "centralizira komunikacijo"@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Observer ;
    rdfs:comment "Obstaja priljubljena izvedba vzorca Mediator, ki se opira na vzorec Observer. Razred Mediator igra vlogo založnika, ki izdaja dogodke (tj. Publisher, Subject; vodi seznam svojih vzdrževanih članov, imenovanih 'Observers'). Medtem pa komponente (različni razredi 'Components', ki vsebujejo neko poslovno logiko) delujejo kot naročniki, ki se naročajo na dogodke mediatorja (razred Mediator, Publisher, Subject) in od njih odjavljajo. Ko vzorec Mediator implementiramo na ta način, je lahko videti zelo podoben vzorcu Observer."@sl ,
                 "There’s a popular implementation of the Mediator pattern that relies on Observer. The mediator object plays the role of publisher, and the components act as subscribers which subscribe to and unsubscribe from the mediator’s events. When Mediator is implemented this way, it may look very similar to Observer."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Mediator ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Facade ;
    rdfs:comment "Facade and Mediator have similar jobs: they try to organize collaboration between lots of tightly coupled classes. However, Facade defines a simplified interface to a subsystem of objects, but it doesn’t introduce any new functionality. The subsystem itself is unaware of the facade. Objects within the subsystem can communicate directly. On the other hand, Mediator centralizes communication between components of the system. The components only know about the mediator object and don’t communicate directly."@en ,
                 "Vzorca Facade in Mediator imata podobno nalogo: organizirati sodelovanje med številnimi tesno povezanimi razredi. Razlika med tema dvema vzorcema je, da vzorec Facade definira poenostavljen vmesnik za podsistem razredov, vendar ne uvaja novih funkcionalnosti. Sam podsistem razredov se ne zaveda fasade. Objekti znotraj podsistema lahko neposredno komunicirajo. Po drugi strani vzorec Mediator centralizira komunikacijo med komponentami sistema. Komponente sistema poznajo le razred Mediator in med seboj ne komunicirajo neposredno."@sl
] .

:Memento rdf:type owl:NamedIndividual ,
                  :BehavioralPattern ;
    :hasStructure :MementoStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLF1Rjim3BthAuZiu1Ih4-mmO1WC7vPsG0_R3hrjwu6ncKIDBHaIuw3Tzk-ZvJXsdI3jnR2UnFV8Hp9I4NoZaWpRQxXdjyjuvmYcTsLL11XPMmDBz9I3_A01RPXSIRb69jXhte1dfpC6CXbMVbU4a2iLAUMtsbJei8IiGE_XZmAXohPhPtScNzZ2EjXlD5E3MvUJQx5t7xz--NIx41ITi_iMN1OIgVuDMOsL55udpGAsTlWaqCeQNlJ02xwUfWrXXyRBbVYWr3nIhBaGshUQ4muhp2Ga-9Jez9nLoLodYamEBNqqL-9T13UqqaPd-X5XNM1jz0OSFZlARItCK9VaZTxQkZ7whbE22VnmUgqDikG_0VJ3SvBqEK6Q1klYE9RlU_1Oq_JgSpSDZJ53rWw7bhGxNM9qv4LKI1kkHHY02Ip4JSOj7PBhZo4IDhg9UJgcyUjXG2XziICsQp8Xe77DP_2MtqlFw4BL0IE-RvvDm-EpUbtvByGwi5MoH-cpmgEWQV_y6Www9nwEfgAoDJrZwF-WpfdyRdYM7algBRPnGIkE1rUdDirsrUnlEXWQDIxlyE82HnA774He5DkMy1ChBJlN3F7MXZLoZxgf8gppvAtRzTlqa_VQUeK-VV-Wr45aQPbj2NPraY4C6ZSRJqApf4sy-Wy0"^^xsd:anyURI ;
    :canBeUsedWith :Command ,
                   :Iterator ;
    :hasCon :InconsistentState ,
            :MemoryIntensive ,
            :RequiresCarefulManagement ;
    :hasPro :CodeSimplification ,
            :SupportsRollbackSystem ;
    :intent "Memento is a behavioral design pattern that lets you save and restore the previous state of an object without revealing the details of its implementation."@en ;
    rdfs:comment "Memento is a design pattern that exposes the private internal state of an object. One example of how this can be used is to restore an object to its previous state (undo via rollback), another is versioning, another is custom serialization."@en ,
                 "Memento je načrtovalski, ki razkrije zasebno notranje stanje objekta. En primer uporabe je obnovitev objekta v prejšnje stanje ('undo' z razveljavitvijo), drug primer je upravljanje različic, tretji pa je serializacija po meri."@sl ;
    rdfs:label "Memento"@en ,
               "Snapshot"@en ,
               "Spominek"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/memento"^^xsd:anyURI ;
    skos:prefLabel "Memento"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Memento ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Pri implementaciji ukaza 'razveljavi' lahko skupaj uporabimo vzorca Command in Memento. V tem primeru so ukazi ('Concrete Commands') odgovorni za izvajanje različnih operacij nad ciljnim objektom. (cmd 'Receiver', mem 'Concrete Originator'), medtem ko objekti tipa spominek ('Concrete Memento') shranijo stanje ciljnega objekta (cmd 'Receiver', mem 'Concrete Originator') tik pred izvedbo ukaza ('Concrete Command')."@sl ,
                 "You can use Command and Memento together when implementing 'undo'. In this case, commands are responsible for performing various operations over a target object, while mementos save the state of that object just before a command gets executed."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Memento ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Iterator ;
    rdfs:comment "Vzorec Memento lahko uporabljamo z vzorcem Iterator za zajem trenutnega stanja iteracije (iterator position) in zmožnosti poznejše ponovne vrnitve v to stanje."@sl ,
                 "We can use Memento along with Iterator to capture the current iteration state and roll it back if necessary."@en
] .

:MemoryIntensive rdf:type owl:NamedIndividual ,
                          :Aspect ;
    rdfs:label "Memory intensive"@en ;
    rdfs:comment "/ LimitedScalability / The app might consume lots of RAM if clients create mementos too often. The more states or objects that require state preservation, the more resource-intensive the system becomes, complicating implementation and potentially limiting scalability."@en .

:MemorySaver rdf:type owl:NamedIndividual ,
                      :Aspect ;
    rdfs:label "Memory save"@en ;
    rdfs:comment "Can save lots of RAM, assuming your program has tons of similar objects."@en .

:MinimizedInitialisationCode rdf:type owl:NamedIndividual ,
                                      :Aspect ;
    rdfs:label "Minimized initialisation code"@en ;
    rdfs:comment "Get rid of repeated initialization code in favor of cloning pre-built prototypes."@en .

:NonSeamless rdf:type owl:NamedIndividual ,
                      :Aspect ;
    rdfs:label "Non seamless"@en ;
    rdfs:comment "Clients must be aware of the differences between strategies to be able to select a proper one."@en .

:Observer rdf:type owl:NamedIndividual ,
                   :BehavioralPattern ;
    :hasStructure :ObserverStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLB1ZjCm4BtxAqPmQ1f8RaXeMNBO018I4aYzmN9mt4apszIEnavA5_RVSPnDaq9OaKDal_6RcVTcLc85dmkBt26_WOtZLhcMKQo4i7lIZMHv05LBQ-6d02Yask_Oj7gRczem72josEE6jyW3zlpLXvlNxtEFIcPp7C2YzapnCC-gZSF_IAe2jcDvyb1fjCidu2BVb6QWE9RQ-X1g9xoU5Rp3aZGfkfEmgsMdgGAMzunRqm5fw0veDUrDrulFW-HdaDVa-VuWxNY-leOeVtd2kZR7DMIP41-rGowbGlzkqnPMCHN80sbszqGwlyooe3r94lz_0MspbGuZvVNX3xVkbOqjV6cBccmr9fokWG_sNC1UpQfz-nwY1qbwusJmSwnrPaGNZFNGY7uox8T6vMb2RJJWVPsRrf96Qp-P7QdeGaDkj69qUAi1_h9e3CxmNbgQfayRzCTC6zFXlNoSNfXKqZP9DXacmiOP3JNflKzguIt4iSPZ72_q48Gr8pUTkR86WNeRzlTSAcNQLIxD5XA91Nsfx-nNDdD2J6CrISYLN8G7jLzbGtxX-stTcuElA_cEUi51MOsb0rDEWg-kbiSLnwLXbAhomYFhhwJzQRP8wp20_hFfe_5nx2goSTpp7sRw_rLvQI5WMaTllJT-tCobDiSIlm40"^^xsd:anyURI ;
    :canBeUsedWith :Mediator ;
    :differsInAspectsFrom :Mediator ;
    :hasCon :InconsistentNotification ;
    :hasPro :OpenClosedPrinciple ,
            :RuntimeResponsibilityManagement ;
    :isBasedOn :SystemComponents ;
    :isSimilarTo :ChainOfResponsibility ,
                 :Command ,
                 :Mediator ;
    :usesSubscriptionModel :SendersReceivers ;
    :usesUnidirectionalConnection :SystemComponents ;
    skos:related :ChainOfResponsibility ,
                 :Command ,
                 :Mediator ;
    :intent "Observer is a behavioral design pattern that lets you define a subscription mechanism to notify multiple objects about any events that happen to the object they’re observing."@en ;
    rdfs:comment "Observer is a behavioral design pattern that lets us define a subscription mechanism. It is a software design pattern in which an object, called the subject (also known as event source or event stream), maintains a list of its dependents, called observers (also known as event sinks), and automatically notifies them of any state changes, typically by calling one of their methods. The subject knows its observers through a standardized interface and manages the subscription list directly. Unlike the publish-subscribe pattern, there is no intermediary broker; the subject and observers have direct references to each other."@en ,
                 "Opazovalec je načrtovalski vzorec, ki nam omogoča vpeljavo mehanizma naročnine. Gre za vzorec načrtovanja programske opreme, v katerem objekt, imenovan subjekt (znan tudi kot vir dogodkov ali tok dogodkov), vzdržuje seznam svojih odvisnikov, imenovanih opazovalci (znani tudi kot ponori dogodkov), in jih samodejno obvešča o vseh spremembah stanja, običajno s klicem ene od njihovih metod. Subjekt pozna svoje opazovalce prek standardiziranega vmesnika in neposredno upravlja seznam naročnin. Za razliko od vzorca publish-subscribe tukaj ni posrednika; subjekt in opazovalci imajo neposredne reference drug na drugega."@sl ;
    rdfs:label "Observer"@en ,
               "Event-Subscriber"@en ,
               "Listener"@en ,
               "Opazovalec"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/observer"^^xsd:anyURI ;
    skos:prefLabel "Observer"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Obstaja priljubljena izvedba vzorca Mediator, ki se opira na vzorec Observer. Razred Mediator igra vlogo založnika, ki izdaja dogodke (tj. Publisher, Subject; vodi seznam svojih vzdrževanih članov, imenovanih 'Observers'). Medtem pa komponente (različni razredi 'Components', ki vsebujejo neko poslovno logiko) delujejo kot naročniki, ki se naročajo na dogodke mediatorja (razred Mediator, Publisher, Subject) in od njih odjavljajo. Ko vzorec Mediator implementiramo na ta način, je lahko videti zelo podoben vzorcu Observer."@sl ,
                 "There’s a popular implementation of the Mediator pattern that relies on Observer. The mediator object plays the role of publisher, and the components act as subscribers which subscribe to and unsubscribe from the mediator’s events. When Mediator is implemented this way, it may look very similar to Observer."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Glavni cilj vzorca Mediator je odpraviti medsebojne odvisnosti med množico komponent sistema. Namesto medsebojne odvisnosti, te komponente postanejo odvisne od enega samega razreda ('Concrete Mediator'), ki poveze podatke in metode (encapsulate relations) med različnimi komponentami (various components that are not aware of other components). Glavni cilj vzorca Observer je vzpostaviti dinamične enosmerne povezave med razredi, kjer nekateri razredi ('Concrete Subscribers', Observers) delujejo kot podrejeni drugim (Publisher, Subject). Glavni cilj vzorca Observer je vzpostaviti dinamične enosmerne povezave med razredi, kjer nekateri razredi ('Concrete Subscribers', Observers) delujejo kot podrejeni drugim (Publisher, Subject). Ko smo v dvomih, se spomnimo, da lahko vzorec Mediator implementiramo na druge načine. Na primer, vse komponente (razreda 'Component') lahko trajno povežemo z istim objektom posrednika (razred Mediator). Taka izvedba ni podobna vzorcu Observer, vendar je še vedno primerek vzorca Mediator. Predstavljajmo si program, kjer so vse komponente ('Component') postale tudi založniki (Publisher, Subject), kar omogoča dinamično medsebojno povezovanje. V tem primeru nimamo centraliziranega osrednega razreda (Mediator), ampak samo porazdeljeno množico opazovalcev (Observers). Vzorec Observer porazdeli komunikacijo z uvedbo objektov Observer in Subject, medtem ko objekt Mediator enkapsulira komunikacijo med drugimi objekti. V vzorcu Observer ni nobenega posameznega objekta, ki bi zajemal omejitev."@sl ,
                 "The primary goal of Mediator is to eliminate mutual dependencies among a set of system components. Instead, these components become dependent on a single mediator object. The goal of Observer is to establish dynamic one-way connections between objects, where some objects act as subordinates of others. When you’re confused, remember that you can implement the Mediator pattern in other ways. For example, you can permanently link all the components to the same mediator object. This implementation won’t resemble Observer but will still be an instance of the Mediator pattern. Now imagine a program where all components have become publishers, allowing dynamic connections between each other. There won’t be a centralized mediator object, only a distributed set of observers. Observer distributes communication by introducing Observer and Subject objects, whereas a Mediator object encapsulates the communication between other objects. In the Observer pattern, there is no single object that encapsulates a constraint."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :SystemComponents ;
    rdfs:comment "Observer defines a subscription mechanism to notify multiple objects about the state changes that happen to the certain object."@en ,
                 "Observer definira mehanizem naročnine za obveščanje objektov o spremembah stanja, ki se zgodijo na točno določenem objektu."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :ChainOfResponsibility ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Chain of Responsibility, Command, Mediator and Observer address various ways of connecting senders and receivers of requests: 1) Chain of Responsibility passes a request sequentially along a dynamic chain of potential receivers until one of them handles it. 2) Command establishes unidirectional connections between senders and receivers. 3) Mediator eliminates direct connections between senders and receivers, forcing them to communicate indirectly via a mediator object. 4) Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorci ChainOfResponsibility, Command, Mediator in Observer ponujajo različne načine, kako lahko med sabo povežemo pošiljatelje in prejemnike zahtev. 1) ChainOfResponsibility pošilje zahtevo zaporedno po dinamično povezani verigi potencialnih prejemnikov, dokler jo eden od njih ne poservisira. ; Podobno lahko pri CoR vsak prejemnik v dinamično povezani verigi obdela zahtevo, dokler jo eden od njih ne izloči. 2) Vzorec Command vzpostavi enosmerno povezavo med pošiljatelji in prejemniki. 3) Vzorec Mediator odpravi neposredno povezavo med pošiljatelji in prejemniki ter jih prisili, da komunicirajo preko posrednika (razreda Mediator). 4) Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Mediator ;
    rdfs:comment "Razliko med vzorcema Mediator in Observer je včasih težko opredeliti (diff is elusive, difficult to obtain). Večinoma lahko implementiramo enega od teh dveh vzorcev; včasih pa lahko uporabimo oba istočasno. Oba vzorca se uporabljata za zagotavljanje sklopljenega načina komunikacije komponent, vendar je način uporabe različen."@sl ,
                 "The difference between Mediator and Observer is often elusive. In most cases, you can implement either of these patterns; but sometimes you can apply both simultaneously. Both patterns are used to provide decoupled way for component communication, but usage is different."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :usesSubscriptionModel ;
    owl:annotatedTarget :SendersReceivers ;
    rdfs:comment "Observer lets receivers dynamically subscribe to and unsubscribe from receiving requests."@en ,
                 "Vzorec Observer omogoča prejemnikom, da se lahko dinamično naročajo in odjavljajo od prejemanja zahtev."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Observer ;
    owl:annotatedProperty :usesUnidirectionalConnection ;
    owl:annotatedTarget :SystemComponents ;
    rdfs:comment "Glavni cilj vzorca Observer je vzpostaviti dinamične enosmerne povezave med razredi, kjer nekateri razredi ('Concrete Subscribers', Observers) delujejo kot podrejeni drugim (Publisher, Subject)."@sl ,
                 "The goal of Observer is to establish dynamic one-way connections between objects, where some objects act as subordinates of others."@en
] .

:Obsolescence rdf:type owl:NamedIndividual ,
                       :Aspect ;
    rdfs:label "Obsolescence"@en ;
    rdfs:comment "A lot of modern programming languages have functional type support that lets you implement different versions of an algorithm inside a set of anonymous functions. Then you could use these functions exactly as you’d have used the strategy objects, but without bloating your code with extra classes and interfaces."@en .

:OpenClosedPrinciple rdf:type owl:NamedIndividual ,
                              :Principle ;
    rdfs:label "Open/Closed principle"@en ;
    rdfs:comment "Introduce new states without changing existing state classes or the context."@en ,
                 "We can implement new types of collections and iterators and pass them to existing code without breaking anything."@en ,
                 "We can introduce a new behavior that can work with objects of different classes without changing these classes."@en ,
                 "We can introduce new commands into the app without breaking existing client code."@en ,
                 "We can introduce new mediators without having to change the actual components."@en ,
                 "We can introduce new strategies without having to change the context."@en ,
                 "We can introduce new subscriber classes without having to change the publisher’s code (and vice versa if there’s a publisher interface)."@en ,
                 "We can introduce new types of adapters into the program without breaking the existing client code."@en ,
                 "We can introduce new abstractions and implementations independently from each other." .

:Overhead rdf:type owl:NamedIndividual ,
                   :Aspect ;
    rdfs:label "Overhead"@en ;
    rdfs:comment "Applying the pattern can be an overkill if your app only works with simple collections. // There's an extra cost in creating and managing iterators, which may not be efficient for small collections."@en ,
                 "Applying the pattern can be overkill if a state machine has only a few states or rarely changes."@en .

:PlatformIndependent rdf:type owl:NamedIndividual ,
                              :Aspect ;
    rdfs:label "Platform independent"@en ;
    rdfs:comment "You can create platform-independent classes and apps."@en .

:Polymorphism rdf:type owl:NamedIndividual ,
                       :OOConcept ;
    rdfs:comment "Polimorfizem je zmožnost različnih tipov objektov, da na isto sporočilo (klic metode) odgovorijo na svoj način."@sl ,
                 "Polymorphism describes the concept that you can access objects of different types through the same interface"@en ,
                 "Polymorphism is the ability of different object types to respond to the same message (method call) in their own way."@en ;
    rdfs:label "Polimorfizem"@sl ,
               "Polymorphism"@en .

:PotentiallySlow rdf:type owl:NamedIndividual ,
                          :Aspect ;
    rdfs:label "Potentially slow"@en .

:ProductsCompatibility rdf:type owl:NamedIndividual ,
                                :Aspect ;
    rdfs:label "Products compatibility"@en .

:PromoteCodeReuse rdf:type owl:NamedIndividual ,
                           :Aspect ;
    rdfs:label "Promote code reuse"@en ;
    rdfs:comment "We can pull the duplicate code into a superclass."@en ,
                 "We can reuse individual components more easily."@en ,
                 "Objects in the chain can be reused in other chains or other parts of the system, reducing development time on subsequent projects."@en ,
                 "Reuse the same construction code when building various representations of products."@en .

:Prototype rdf:type owl:NamedIndividual ,
                    :CreationalPattern ;
    :hasStructure :PrototypeStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/bLFBRjim4BppAnRkmRPQ2MY00eMRwb0r1NgAqUJItcXf9JEck0H9sNNQ_difoG_5pCEv2DHeTcU7EngpCSn_NDzUt_wSNts26sUQt3K68OO5jo87KMk9DIh7dI35nepPbL2Q6rv3Bhcry8U1v-Qhob2ZYema6TWiXSCM9rEWwR4t7xvz-NYLUPGRGviUN4XVoVuDkofoU4RJlCCgmxSUAacvx0Wyw7TiqvSumvNrdxmdvlsCuIkMGebSt76e95yhiGJ3xmqMj0QXO5sZLM95wzPyrbaUGIQ5h_S7RlVdoqkOPE-sA2Ljff2cZ7rN3at9S_IykI57Rgknhpc--Z9nuALfvpoEO_zywo-O54wcioEzjNQOWLHkqE59wn3kMa8fK1Rl1zq3uaJlJzCpv6-QHHU04_aG7iXV3EG3uddo9nlJjCPxljjDjuVOY6hfudHG5bv9aZGw-JlaX7F7SQDZpmcg-o5-SIryojg8hAZxGyoTQEVe0hmWvwW6AlVny9Poqblu3FXRM2TKbUmCCbH5b_fTgSJITOMdkhFPwBcTZRn45Bcbi56KzDVjrGxVarq0Ng4MRg3NyBp6A52uYQ97OhGVuabdmLrxhUVYqAlQHgE9eeSnUT7mnMk6ECjmEEbZXXdx3m00"^^xsd:anyURI ;
    :canBeDevelopedFrom :FactoryMethod ;
    :canBeImplementedAs :Singleton ;
    :canBeStartingPointFor :AbstractFactory ;
    :canBeTreatedAsSimplified :Memento ;
    :canBeUsedWith :Command ;
    :hasCon :CircularReferencesCodeComplicated ;
    :hasPro :AlternativeToInheritance ,
            :SimplifiedObjectCreation ;
    :isNotBasedOn :Inheritance ;
    :intent "Prototype is a creational design pattern that lets you copy existing objects without making your code dependent on their classes."@en ;
    rdfs:comment "Prototype is a creational design pattern that lets us copy existing objects without making your code dependent on their classes. It is used when the types of objects to create is determined by a prototypical instance, which is cloned to produce new objects. This pattern is used to avoid subclasses of an object creator in the client application, like the factory method pattern does, and to avoid the inherent cost of creating a new object in the standard way (e.g., using the 'new' keyword) when it is prohibitively expensive for a given application."@en ,
                 "Prototip je načrtovalski vzorec, ki omogoča kopiranje obstoječih objektov, ne da bi bila koda odvisna od njihovih razredov. Uporablja se, kadar vrste objektov, ki jih želite ustvariti, določa prototipni primerek, ki se klonira za ustvarjanje novih objektov. Ta vzorec se uporablja za izogibanje podrazredom ustvarjalca objektov v odjemalski aplikaciji, kot to počne vzorec 'Factory Method', in za izogibanje inherentnim stroškom ustvarjanja novega objekta na standardni način (npr. z uporabo ključne besede 'new'), ko je to za dano aplikacijo pretirano drago."@sl ;
    rdfs:label "Prototype"@en ,
               "Clone"@en ,
               "Prototip"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/prototype"^^xsd:anyURI ;
    skos:prefLabel "Prototype"@en .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Prototype ;
    owl:annotatedProperty :canBeDevelopedFrom ;
    owl:annotatedTarget :FactoryMethod ;
    rdfs:comment "Factory Method is less complicated and more customizable via subclasses; while Prototype is more flexible, but more complicated."@en ,
                 "Veliko načrtov programske kode lahko začnemo z vzorcem FactoryMethod (preprosto, prilagodljivost preko podrazredov) --> evolucija v vzorec Prototype."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Prototype ;
    owl:annotatedProperty :canBeImplementedAs ;
    owl:annotatedTarget :Singleton ;
    rdfs:comment "Objekt Singleton nima stanja, ker je običajno v skupni rabi. Torej ne sme vsebovati stanja za katerokoli drugo komponento. Prototipni objekt (Concrete Prototype) ima stanje, ker ima običajno lahko vsaka komponenta svojo prototipno kopijo objekta (razreda Concrete Prototype). Torej lahko eno kopijo prototipnega objekta uporabi ena komponenta in shrani nekaj stanj za to komponento. Prototip, implementiran kot Singleton, bi lahko ustvaril eno samo kopijo prototipnega objekta."@sl ,
                 "Singleton object is stateless because it is shared . So, it should not contain any state for any other component. Prototype object (Concrete Prototype) is stateful because usually each component can have its own prototype copy of the object (Concrete Prototype). So, one copy of the prototype object can be used by one component and save some states for that component. Prototype implemented as a Singleton could create a single copy of the prototype object."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Prototype ;
    owl:annotatedProperty :canBeStartingPointFor ;
    owl:annotatedTarget :AbstractFactory ;
    rdfs:comment "Prototype pattern can also be used to compose the methods on Abstract Factory classes."@en ,
                 "Vzorec Prototype lahko uporabimo tudi za implementacijo metod v razredih AbstractFactory."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Prototype ;
    owl:annotatedProperty :canBeTreatedAsSimplified ;
    owl:annotatedTarget :Memento ;
    rdfs:comment "Sometimes Prototype can be a simpler alternative to Memento. This works if the object, the state of which you want to store in the history, is fairly straightforward and doesn’t have links to external resources, or the links are easy to re-establish."@en ,
                 "Včasih lahko vzorec Prototype predstavlja preprostejšo različico vzorca 'Memento'. To deluje, če je objekt, katerega stanje želimo shraniti v zgodovino (ConcreteOriginator), dokaj enostaven in nima povezav do zunanjih virov ali pa je povezave enostavno znova vzpostaviti."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Prototype ;
    owl:annotatedProperty :canBeTreatedAsSimplified ;
    owl:annotatedTarget :Memento ;
    rdfs:comment "Sometimes Prototype can be a simpler alternative to Memento. This works if the object, the state of which you want to store in the history, is fairly straightforward and doesn’t have links to external resources, or the links are easy to re-establish."@en ,
                 "Včasih lahko vzorec Prototype predstavlja preprostejšo različico vzorca Memento. To deluje, če je objekt, katerega stanje želimo shraniti v zgodovino (ConcreteOriginator), dokaj enostaven in nima povezav do zunanjih virov ali pa je povezave enostavno znova vzpostaviti."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Prototype ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Prototype can help when you need to save copies of Commands into history."@en ,
                 "Vzorec Prototype lahko uporabimo, ko želimo shraniti kopije ukazov (vzorec Command) in tako hraniti zgodovino ukazov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Prototype ;
    owl:annotatedProperty :isNotBasedOn ;
    owl:annotatedTarget :Inheritance ;
    rdfs:comment "Prototype doesn’t have drawbacks of Inheritance, however it requires a complicated initialization of the cloned object."@en ,
                 "Vzorec Prototype ne temelji na dedovanju in zato nima pomanjklivosti dedovanja, vendar pa zahteva zapleteno inicializacijo kloniranega objekta."@sl
] .

:Proxy rdf:type owl:NamedIndividual ,
                :StructuralPattern ;
    :hasStructure :ProxyStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLB1ZjCm4BtxAqRbqAIGt91GMI9108aRqjwupJgJrXlNhiPkIWlxxpZsXgIK8YwHysRUcpVFNeebV6Nx_VGMxZqVf3ymYQKGhbDcZumxa1gTWny2u05bjs5xC4rjjMKuRfMd0RVS42VinUlF7zvygWEApFQOm0STcE9fhcgif_yGbH7RC9u2r5hZKrE3t4NmGdEIIZJFQ5meaV4YxBI4ZzGgewHwHDXex8tQ0kEPgR4zA0FzZfnHdUs70EguzW9ghG8_7D2DvxixoEfN9zBQ7dEeAY6-64_SegJG1_V4lP8qOOby1GSPzVkdgc8QHL64xqkmUsBqofei7tOSpSIRIdBf63d0XFfP7jRZe9bQxCtSLCiZBBSak_TIadDP_g-ne_PyZpYwBClRflz8V6zxEkDpjZ77WjLcwulgAXgHbYiF-_BdNwgZWrlrnBP5eQdrnTIHB7t3iy5TfuORx-mk645-L8Ej-2QZ9x1j2cszNbo7jmZRpYD_1qwGQUARlgKoosQWhrQgNQqWkxY2F6PweLtECmLuckRy0W00"^^xsd:anyURI ;
    :differsInAspectsFrom :Adapter ,
                          :Decorator ;
    :hasCon :CodeMoreComplicated ,
            :ImpactsEfficiency ;
    :hasPro :CodeChangeFlexibility ,
            :ImprovedMaintainability ,
            :OpenClosedPrinciple ;
    :hasSimilarStructure :Decorator ;
    :isBasedOn :Composition ,
               :ServiceObject ;
    :isSimilarTo :Facade ;
    :keepsOriginalInterface :ServiceObject ;
    :organizesCollaboration :ClassSubsystem ;
    :intent "Proxy is a structural design pattern that lets you provide a substitute or placeholder for another object. A proxy controls access to the original object, allowing you to perform something either before or after the request gets through to the original object."@en ;
    rdfs:comment "Proxy provides a surrogate or placeholder for another object to control access to the original object. Proxy allows to perform something either before or after the request gets through to the original object. A proxy, in its most general form, is a class functioning as an interface to something else. The proxy could interface to anything: a network connection, a large object in memory, a file, or some other resource that is expensive or impossible to duplicate. In short, a proxy is a wrapper or agent object that is being called by the client to access the real serving object behind the scenes."@en ,
                 "Pooblaščenec (nadomestni objekt) zagotavlja nadomestek ali rezervirano mesto za drug objekt za nadzor dostopa do izvirnega objekta. Pooblaščenec omogoča, da nekaj izvedemo, preden ali po tem, ko zahteva pride do izvirnega objekta. Proxy je v svoji najsplošnejši obliki razred, ki deluje kot vmesnik do nečesa drugega. Pooblaščenec je lahko vmesnik do česarkoli: omrežne povezave, velikega objekta v pomnilniku, datoteke ali drugega vira, ki ga je drago ali nemogoče podvojiti. Skratka, proxy je ovojni objekt, ki ga odjemalec kliče za dostop do pravega strežnega objekta v ozadju."@sl ;
    rdfs:label "Proxy"@en ,
               "Pooblaščenec"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/proxy"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Proxy ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Adapter ;
    rdfs:comment "S pomočjo vzorca Adapter lahko dostopamo do obstoječega objekta (tipa Service) preko drugačnega vmesnika. Pri vzorcu Proxy vmesnik ostane enak. Pri uporabi vzorca Decorator dostopamo do objekta (Wrapee) prek razširjenega vmesnika."@sl ,
                 "With Adapter you access an existing object via different interface. With Proxy, the interface stays the same. With Decorator you access the object via an enhanced interface."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Proxy ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "Decorator and Proxy have similar structures, but very different intents. Both patterns are built on the composition principle, where one object is supposed to delegate some of the work to another. The difference is that a Proxy usually manages the life cycle of its service object on its own, whereas the composition of Decorators is always controlled by the client."@en ,
                 "Vzorca Decorator in Proxy imata podobno strukturo, a zelo različen namen. Oba vzporca uporabljata mehanizem kompozicije, kjer naj bi en objekt del dela prenesel na drugega. Razlika je v tem, da vzorec Proxy običajno sam upravlja življenjski cikel svojega storitvenega objekta (service class), medtem ko uporabo in sestavo objektov Decorator vedno nadzoruje odjemalec."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Proxy ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "Decorator and Proxy have similar structures, but very different intents. Both patterns are built on the composition principle, where one object is supposed to delegate some of the work to another."@en ,
                 "Vzorca Decorator in Proxy imata podobno strukturo, a zelo različen namen. Oba vzporca uporabljata mehanizem kompozicije, kjer naj bi en objekt del dela prenesel na drugega."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Proxy ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :Composition ;
    rdfs:comment "Decorator and Proxy patterns are built on the composition principle, where one object is supposed to delegate some of the work to another."@en ,
                 "Oba vzorca, Decorator and Proxy, uporabljata mehanizem kompozicije, kjer naj bi en objekt del dela prenesel na drugega."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Proxy ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :ServiceObject ;
    rdfs:comment "Design pattern manages the life cycle of its service object on its own. It takes care of an object, the object's lifetime, initialization, etc. Proxy usually manages the life cycle of its service object on its own, whereas the composition of Decorators is always controlled by the client."@en ,
                 "Načrtovalski vzorec sam upravlja življenjski cikel svojega storitvenega objekta. Skrbi za nek objekt, življensko dobo objekta, initcializacijo, ipd. Proxy običajno sam upravlja življenjski cikel svojega storitvenega objekta, medtem ko sestavo dekoraterjev vedno nadzoruje odjemalec."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Proxy ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Facade ;
    rdfs:comment "Facade is similar to Proxy in that both buffer a complex entity and initialize it on its own. Unlike Facade, Proxy has the same interface as its service object, which makes them interchangeable."@en ,
                 "Vzorec Facade je podoben vzorcu Proxy, saj oba medpomnita kompleksno entiteto in jo inicializirata sama."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Proxy ;
    owl:annotatedProperty :keepsOriginalInterface ;
    owl:annotatedTarget :ServiceObject ;
    rdfs:comment "S pomočjo vzorca Adapter lahko dostopamo do obstoječega objekta (tipa Service) preko drugačnega vmesnika. Pri vzorcu Proxy vmesnik ostane enak. Pri uporabi vzorca Decorator dostopamo do objekta (Wrapee) prek razširjenega vmesnika. Za razliko od vzorca Facade ima vzorec Proxy isti vmesnik kot njegov storitveni razred (service class), kar ju naredi med seboj zamenljiva"@sl ,
                 "With Adapter you access an existing object via different interface. With Proxy, the interface stays the same. With Decorator you access the object via an enhanced interface. Unlike Facade, Proxy has the same interface as its service object, which makes them interchangeable."@en
] .

:RecursiveComposition rdf:type owl:NamedIndividual ,
                               :OOConcept ;
    :narrower :Composition ;
    rdfs:comment "Kadar je vrsta/tip posameznega dela enaka vrsti celote. Objekti so lahko sestavljeni rekurzivno, njihov tip pa se imenuje rekurzivni tip."@sl ,
                 "When the type of a part is identical to the type of the whole then the relationship must be looped around to renter the top after leaving the bottom. Objects can be composed recursively, and their type is then called recursive type."@en ;
    rdfs:label "Recursive Composition"@en ,
               "Rekurzivna sestava"@sl .

:RequiresCarefulManagement rdf:type owl:NamedIndividual ,
                                    :Aspect ;
    rdfs:label "Requires careful management"@en ;
    rdfs:comment "Caretakers should track the originator’s lifecycle to be able to destroy obsolete mementos."@en .

:RequiresCommonInterface rdf:type owl:NamedIndividual ,
                                  :Aspect ;
    rdfs:label "Requires common interface"@en ;
    rdfs:comment "Groups of elements are treated similarly."@en ,
                 "It might be difficult to provide a common interface for classes whose functionality differs too much."@en ,
                 "Requires a well-defined common interface."@en .

:RuntimeResponsibilityManagement rdf:type owl:NamedIndividual ,
                                          :Aspect ;
    rdfs:label "Runtime responsibility management"@en ;
    rdfs:comment "Can add or remove responsibilities from an object at runtime."@en ,
                 "We can establish relations between objects at runtime."@en .

:SendersReceivers rdf:type owl:NamedIndividual ,
                           :Aspect ;
    rdfs:comment "Pošiljatelji in prejemniki so razredi, ki se uporabljajo za pošiljanje in prejemanje sporočil."@sl ,
                 "Senders and receivers are classes that are used to send and receive messages."@en ;
    rdfs:label "Pošiljatelji/prejemniki"@sl ,
               "Senders/receivers"@en .

:SeparationOfConcerns rdf:type owl:NamedIndividual ,
                               :Principle ;
    rdfs:label "Separation of concerns"@en ;
    rdfs:comment "We can isolate the implementation details of an algorithm from the code that uses it."@en .

:ServiceClass rdf:type owl:NamedIndividual ,
                       :Aspect ;
    skos:related :ServiceObject ;
    rdfs:comment "Razredi storitev so razredi, ki drugim razredom ponujajo neko storitev. Uporabljajo se za inkapsulacijo funkcionalnosti, ki jo je mogoče ponovno uporabiti v različnih delih aplikacije."@sl ,
                 "Service classes are classes that provide a service to other classes. They are used to encapsulate functionality that can be reused across different parts of the application."@en ;
    rdfs:label "Service Classes"@en ,
               "Storitveni razredi"@sl .

:ServiceObject rdf:type owl:NamedIndividual ,
                        :Aspect ;
    rdfs:label "Objekt storitve"@sl ,
               "Service Object"@en .

:SimplifiedObjectCreation rdf:type owl:NamedIndividual ,
                                   :Aspect ;
    rdfs:comment "You can produce complex objects more conveniently."@en ;
    rdfs:label "Convenient creation of complex objects"@en ,
               "Simplified object creation"@en .

:SimplifiesHierarchicalStructure rdf:type owl:NamedIndividual ,
                                          :Aspect ;
    rdfs:label "Simplifies hierarchical structure"@en .

:SingleInstanceClass rdf:type owl:NamedIndividual ,
                              :Aspect ;
    rdfs:label "Single instance class"@en ;
    rdfs:comment "Global access point to that instance."@en .

:SinglePointOfFailure rdf:type owl:NamedIndividual ,
                               :Aspect ;
    rdfs:label "Single point of failure"@en ;
    rdfs:comment "The Mediator object is a single point of failure in the system. If the Mediator object fails, then all other objects in the system will fail as well. Vir: https://www.gofpattern.com/design-patterns."@en .

:SingleResponsibilityPrinciple rdf:type owl:NamedIndividual ,
                                        :Principle ;
    rdfs:label "Single responsibility principle"@en ;
    rdfs:comment "Isolate complex construction code from the business logic of the product."@en ,
                 "Organize the code related to particular states into separate classes."@en ,
                 "We can clean up the client code and the collections by extracting bulky traversal algorithms into separate classes."@en ,
                 "We can extract the communications between various components into a single place, making it easier to comprehend and maintain."@en ,
                 "We can move multiple versions of the same behavior into the same class."@en ,
                 "We need to introduce a set of new interfaces and classes. Sometimes it’s simpler just to change the service class."@en ,
                 "You can decouple classes that invoke operations from classes that perform these operations."@en ,
                 "You can focus on high-level logic in the abstraction and on platform details in the implementation."@en .

:Singleton rdf:type owl:NamedIndividual ,
                    :CreationalPattern ;
    :hasStructure :SingletonStructure ;
    :hasCon :CanMaskBadDesign ,
            :ManageMultithreadedEnvironment ,
            :UnitTestsUnfriendly ;
    :hasPro :SingleInstanceClass ;
    :diagram "https://www.plantuml.com/plantuml/svg/ZLBBJiCm4BpxArPme0s4df1GfN8W0eaB5xx0JJQ9LTSRhJUAAjH_PvCqJNFZOdbdPsR7ZtXmeR5iZv1x6oFy6e2zpGyLKnkAZ3mnTBKJx77Y0dd4xby-try_CaKjCtKZkFUgD6TZujKraE0_JFC1gzYU52efI3O32x_PPfG8sn2rXK6CoOOZtC6F2vL7eQ1x6s_AFaZgGXGRSjpEZHvEqtwzGgkrbeyLojU5lbhV2ixpjCmxdJwE6lV6p2FJzEr6Tk6cxAfQ5XqptDIUHEW8L2wo9OahamHMKtBOxHGBhVT9iXuE1R3PmBSwRC6LSABsWH5oHYjg0pQ0RHhedDGJzzXwqL8PHS-8RTCGorClXLXJwuk9sUYZ8bWOoU0fFq2DZCy3OOxK9y9EOowly3paPvIMWpOdli5G39_3_040"^^xsd:anyURI ;
    :intent "Singleton is a creational design pattern that lets you ensure that a class has only one instance, while providing a global access point to this instance."@en ;
    rdfs:comment "Singleton design pattern ensures that a class has only one instance, and provide a global point of access to this instance. Singleton pattern is useful when exactly one object is needed to coordinate actions across a system. Singleton pattern allows classes to: i) Ensure they only have one instance, ii) provide easy access to that instance, iii) control their instantiation (for example, hiding the constructors of a class)."@en ,
                 "Načrtovalski vzorec Singleton zagotavlja, da ima razred samo en primerek in zagotavlja globalno dostopno točko do tega primerka. Vzorec Singleton je uporaben, kadar je za usklajevanje dejanj v sistemu potreben natanko en objekt. Vzorec Singleton razredom omogoča: i) zagotovitev, da imajo samo en primerek, ii) enostaven dostopa do tega primerka, iii) nadzor nad njihovim ustvarjanjem (na primer skrivanje konstruktorjev razreda)."@sl ;
    rdfs:label "Singleton"@en ,
               "Edinec"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/singleton"^^xsd:anyURI .

#:SourceCodeTBD rdf:type owl:NamedIndividual .

:State rdf:type owl:NamedIndividual ,
                :BehavioralPattern ;
    :hasStructure :StateStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dLHDRzD04BtxLupe8Qd1xWa9bM09J2jnGgASk6tiiRs9inljhXDIw7zdzYknqrGW4YdspiwyUVDc9hDa1W-66NnF3pLKPb2Op994hxdOCiKsKFLCQ_YL02nPjMwL74HTobugs7VSeBLBLQFojgktzv_UtPLaPKh9lJSkUufCdiQeGXhy1z3AsLh53cHgf33boJ31sn8CQoz3NjsNzBtxJwOdD4_6A2OqNQ4m2IarWy_OSC4hlcBGzcmdU0UAFIgivGwuWDq6jU1hkREobaxCLr3sdEBfXUdulbZ0l7npmBwN-sieYf4prOq_etSus48pqBPrzYtBwFTrl9qJ8SDP_y2CmMjtKtLCjEXQFNTHtbpBxntNyzE16JgG05y8I3MiGafhFoxIlJaQ_aYS-T6lA3ofGEL5v2I9pNAbLGe9oU7fOudE66oBnJUi3B7lCQGO2NDol13hdArCbPV5dnm_IqgZYNe5X-jmC-8-OG_mP2iuw_fMxl2H-Vw6xiWiKxpjJ9OLlhGaT3aRjcGARicKRJviyzzd_hc3oOjfOMU1sGZIaVl1jfmcs8xVMcu8XwaLj_pSsYsbCN83iWcZHsN5UN5m7o1D1UxJT9hKrH-4clfCHYxELl3CJTIIR3StK0xAhewVt0qxGCTsH0bHW7VmWrh3yd1CPhUkmt3l0a4kLpGKm8t6liaJ5BNxItbUuKGs1_0nGDZaNEi1mzdVklMcIgImwiKYB7bz9ivNugIUAPDVMBGpTZqs9d2p4RUtBsrjcXgIBatpc3gkktlce_cDdd_FDHfjZt8qnCW_"^^xsd:anyURI ;
    :differsInAspectsFrom :Adapter ,
                          :Strategy ;
    :hasCon :Overhead ;
    :hasPro :CodeSimplification ,
            :OpenClosedPrinciple ,
            :SingleResponsibilityPrinciple ;
    :isBasedOn :Composition ;
    :isExtensionOf :Strategy ;
    :solvesDifferentProblems :Strategy ;
    :intent "State is a behavioral design pattern that lets an object alter its behavior when its internal state changes. It appears as if the object changed its class."@en ;
    rdfs:comment "State design pattern allows an object to alter its behavior when its internal state changes. The object will appear to change its class. This pattern is close to the concept of finite-state machines. The state pattern can be interpreted as a Strategy pattern, which is able to switch a strategy through invocations of methods defined in the pattern's interface."@en ,
                 "Načrtovalski vzorec 'Stanje' omogoča objektu, da spremeni svoje vedenje, ko se spremeni njegovo notranje stanje. Zdi se, kot da je objekt spremenil svoj razred. Ta vzorec je blizu konceptu končnih avtomatov. Vzorec 'Stanje' lahko interpretiramo kot vzorec 'Strategija', ki lahko spremeni strategijo s klici metod, definiranih v vmesniku vzorca."@sl ;
    rdfs:label "State"@en ,
               "Stanje"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/state"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :State ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Adapter ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Stanje omogoča objektu, da spremeni svoje obnašanje, ko se spremeni njegovo notranje stanje."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. State allows an object to alter its behavior when its internal state changes."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :State ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Both patterns are based on composition: they change the behavior of the context by delegating some work to helper objects. Strategy makes these objects completely independent and unaware of each other. However, State doesn’t restrict dependencies between concrete states, letting them alter the state of the context at will."@en ,
                 "Oba vzorca temeljita na kompoziciji: oba spremenita obnašanje objekta 'Context' tako, da nekaj dela preneseta na pomožne objekte (ConcreteStates, ConcreteStrategies). Pri vzorcu Strategija so ti pomožni objekti popolnoma neodvisni in se drug drugega ne zavedajo. Po drugi strani vzorec State ne omejuje odvisnosti med konkretnimi stanji (objekti ConcreteStates), saj jim omogoča, da poljubno spremenijo stanje konteksta (object Context)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :State ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :Composition ;
    rdfs:comment "State pattern is based on composition, which is delegating work to other objects."@en ,
                 "Vzorec State temelji na kompoziciji, kar pomeni, da delegira delo drugim objektom."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :State ;
    owl:annotatedProperty :isExtensionOf ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "State can be considered as an extension of Strategy. Both patterns are based on composition. The State pattern can be interpreted as a Strategy pattern, which is able to switch a strategy through invocations of methods defined in the pattern's interface."@en ,
                 "Vzorec State (objekt 'kontekst' spremeni obnašanje, ko se spremeni notranje stanje objekta) lahko obravnavamo kot razširitev vzorca Strategy (implementacije različnih variacij algoritma, ki ga uporablja objekt 'kontekst'). Oba vzorca temeljita na kompoziciji. Vzorec State je mogoče interpretirati kot vzorec Strategy, ki lahko preklopi strategijo s klici metod, definiranih v vmesniku vzorca Strategy."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :State ;
    owl:annotatedProperty :solvesDifferentProblems ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Stanja shranijo sklic na kontekstni objekt, ki jih vsebuje. Strategije ne. Stanja se lahko zamenjajo (tj. spremenijo stanje kontekstnega objekta v nekaj drugega), medtem ko strategijam ni dovoljeno. Strategije se posredujejo kontekstualnemu objektu kot parametri, medtem ko stanja ustvari sam kontekstni objekt. Strategije obravnavajo samo eno, specifično nalogo, medtem ko stanja zagotavljajo osnovno izvedbo za vse (ali skoraj vse), kar počne objekt konteksta. Vzorec stanja obravnava stanje objekta in enkapsulira vedenje, odvisno od stanja, medtem ko se vzorec strategije ukvarja s tem, kako objekt izvaja določeno nalogo (tj. enkapsulira algoritem)."@sl ,
                 "States store a reference to the context object that contains them. Strategies do not. States are allowed to replace themselves (ie. to change the state of the context object to something else), while Strategies are not. Strategies are passed to the context object as parameters, while States are created by the context object itself. Strategies only handle a single, specific task, while States provide the underlying implementation for everything (or most everything) the context object does. State pattern deals with an object's state and encapsulates state dependent behavior, while the Strategy pattern deals with how an object performs a certain task (encapsulates an algorithm)."@en
] .

:Strategy rdf:type owl:NamedIndividual ,
                   :BehavioralPattern ;
    :hasStructure :StrategyStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dPDDRzim38Rl-XN4UiZ7PlSqOEXI0vkN0iKE6zQUTbDasbRZI8Oi9tMt_lTHikMwIOSLGm378iM7BpyyOpEuiOPRBBgFxgqLjZN8PemrMwbgRlWEHCMR1dunW0qNsyBeLcMfhhI1GoajEhis6PhUTlR-wlE7TKfMRem-zCPDHP7iSKfLsk8heCBR2iCxCkLQsVJ9y8nN4uONBoFFhbBwhVzJwHEj5qFzKWsvK5b6dPh15yobaaBUSIWglbUo1CCV36Pw3rB1VeUDabkzTsrDVJFVG5f9YgSNteJtrGhcwRiEgqeV5f0aayjKDzw7syF15Hf1CqpF7QA8dc-XGHjcEW_kXVTa-aRlq9PI5VE5A_AQK2Rd0WazBWBqUSOZwPBZlIJf4m-vy1v5Qt6USSizqVNZ-wUlwzjhLsqOYYz16BGuK2KsOpN7zjNg1mhBLL7Xa6tIX-dbxaL4vqC0uZZs_xtKKx40Zq7mP82rtkC37qRbnn95RHqbeUqij5z7HXQb9K_86m9YxuYJ4s7iH6dSrl7l2S6h-SbhITldLcTBurAMcplf1FbFfiASakT1pyN5yw72k15nA7V1K6N-UniG6ssjtdc8Lzm7mIKibmeFooKuuBX2ZYdwPF7HQarTnpBEpuS9Q5lY5FxDdVz9zr5_vGECDVq1"^^xsd:anyURI ;
    :differsInAspectsFrom :Adapter ,
                          :Command ,
                          :Decorator ,
                          :State ,
                          :TemplateMethod ;
    :hasCon :CodeMoreComplicated ,
            :NonSeamless ,
            :Obsolescence ;
    :hasPro :CompositionOverInheritance ,
            :Flexibility ,
            :OpenClosedPrinciple ,
            :SeparationOfConcerns ;
    :hasSimilarStructure :Command ;
    :isBasedOn :Composition ,
               :ContextClass ;
    :solvesDifferentProblems :Command ,
                             :State ;
    :intent "Strategy is a behavioral design pattern that lets you define a family of algorithms, put each of them into a separate class, and make their objects interchangeable."@en ;
    rdfs:comment "Strategy design pattern defines a family of algorithms, encapsulate each one, and make them interchangeable. It lets the algorithm vary independently from clients that use it. Strategy enables selecting an algorithm at runtime. Instead of implementing a single algorithm directly, code receives runtime instructions as to which in a family of algorithms to use. Typically, the strategy pattern stores a reference to code in a data structure and retrieves it."@en ,
                 "Načrtovalski vzorec 'Strategija' definira družino algoritmov, vsakega od njih enkapsulira in jih naredi zamenljive. Strategija omogoča, da se algoritem spreminja neodvisno od odjemalcev, ki ga uporabljajo. Strategija omogoča izbiro algoritma med izvajanjem. Namesto da se en sam algoritem implementira neposredno, koda prejme navodila med izvajanjem, katerega v družini algoritmov naj uporabi. Vzorec strategije običajno shrani sklic na kodo v podatkovni strukturi in ga nato ustrezno pridobi."@sl ;
    rdfs:label "Strategy"@en ,
               "Strategija"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/strategy"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Adapter ;
    rdfs:comment "Načrtovalska vzorca rešujeta različne probleme. Adapter omogoča uporabo vmesnika obstoječega razreda kot drugega vmesnika. Vzorec strategija omogoča izbiro algoritma med izvajanjem."@sl ,
                 "They solve different problems. Adapter allows the interface of an existing class to be used as another interface. Strategy enables selecting an algorithm at runtime."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Command and Strategy have very different intents. 1) We can use Command to convert any operation into an object. The operation’s parameters become fields of that object. The conversion lets you defer execution of the operation, queue it, store the history of commands, send commands to remote services, etc. 2) On the other hand, Strategy usually describes different ways of doing the same thing, letting you swap these algorithms within a single context class."@en ,
                 "Vzorca Command in Strategy imata oba zelo različen namen. 1) Vzorec Command lahko uporabimo za prevedbo katere koli operacije v objekt ('Concrete Command'). Parametri operacije  postanejo atributi objekta. Prevedba omogoča, da odložimo izvedbo operacije, jo postavimo v  čakalno vrsto, shranimo zgodovino ukazov, pošljemo ukaze oddaljenim storitvam, ipd. 2) Po drugi strani pa vzorec Strategy določa različne načine izvajanja iste stvari (da lahko nalogo stvar izvedemo na drugačen način), kar nam omogoča zamenjavo algoritmov ('Concrete Strategy') v okviru kontekstnega razreda (razred 'Context')."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Decorator ;
    rdfs:comment "Decorator lets you change the skin of an object, while Strategy lets you change the guts."@en ,
                 "Vzorec Decorator omogoča spremembo zunanjosti objekta, medtem ko vzorec Strategy omogoča notranjo spremembo objekta."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :State ;
    rdfs:comment "Both patterns are based on composition: they change the behavior of the context by delegating some work to helper objects. Strategy makes these objects completely independent and unaware of each other. However, State doesn’t restrict dependencies between concrete states, letting them alter the state of the context at will."@en ,
                 "Oba vzorca temeljita na kompoziciji: oba spremenita obnašanje objekta 'Context' tako, da nekaj dela preneseta na pomožne objekte (ConcreteStates, ConcreteStrategies). Pri vzorcu Strategija so ti pomožni objekti popolnoma neodvisni in se drug drugega ne zavedajo. Po drugi strani vzorec State ne omejuje odvisnosti med konkretnimi stanji (objekti ConcreteStates), saj jim omogoča, da poljubno spremenijo stanje konteksta (object Context)."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :TemplateMethod ;
    rdfs:comment "Template Method is based on inheritance: it lets you alter parts of an algorithm by extending those parts in subclasses. Strategy is based on composition: you can alter parts of the object’s behavior by supplying it with different strategies that correspond to that behavior. Template Method works at the class level, so it’s static. Strategy works on the object level, letting you switch behaviors at runtime."@en ,
                 "Vzorec TemplateMethod temelji na dedovanju: omogoča spreminjanje delov algoritma z razširitvojo teh delov v okviru podrazredov. Vzorec Strategy temelji na kompoziciji: obnašanje različnih delov objekta lahko spreminjamo tako, da mu zagotovimo različne strategije, ki ustrezajo temu vedenju. Vzorec TemplateMethod deluje na nivoju razredov, zato je statičen. Vzorec Strategy deluje na nivoju objektov in omogoča zamenjavo vedenja med izvajanjem."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Command and Strategy may look similar because you can use both to parameterize an object with some action. However, they have very different intents."@en ,
                 "Vzorca Command in Strategy sta si morda videti podobna, ker pri obeh lahko parametriziramo objekt z določenimi ukazi. Vendar imata oba zelo različen namen."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :Composition ;
    rdfs:comment "Strategy pattern is based on composition, which is delegating work to other objects. It changes the behavior of the context by delegating some work to helper objects. Strategy is based on composition: you can alter parts of the object’s behavior by supplying it with different strategies that correspond to that behavior."@en ,
                 "Vzorec Strategy temelji na kompoziciji, kar pomeni, da delegira delo drugim objektom. Vzorec Strategy spreminja vedenje konteksta tako, da nekaj dela prenese na pomožne objekte. Vzorec Strategy temelji na kompoziciji: obnašanje različnih delov objekta lahko spreminjamo tako, da mu zagotovimo različne strategije, ki ustrezajo temu vedenju."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :ContextClass ;
    rdfs:comment "Design pattern enables swapping algorithms within a context class. Strategy lets to swap algorithms within a single context class. Strategy usually describes different ways of doing the same thing, letting you swap these algorithms within a single context class. Strategy pattern enables selecting an algorithm at runtime. Strategy lets the algorithm vary independently from clients that use it."@en ,
                 "Načrtovalski vzorec omogoča zamenjavo algoritmov znotraj kontekstnega razreda. Vzorec Strategija omogoča zamenjavo algoritmov znotraj kontekstnega razreda. Po drugi strani pa vzorec Strategy določa različne načine izvajanja iste stvari (da lahko nalogo izvedemo na drugačen način), kar nam omogoča zamenjavo algoritmov ('Concrete Strategy') v okviru kontekstnega razreda (razred 'Context'). Vzorec Strategy omogoča izbiro algoritma med izvajanjem. Omogoča, da se algoritem spreminja neodvisno od odjemalcev, ki ga uporabljajo."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :solvesDifferentProblems ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Command and Strategy have very different intents. We can use Command to convert any operation into an object. The operation’s parameters become fields of that object. The conversion lets you defer execution of the operation, queue it, store the history of commands, send commands to remote services, etc. On the other hand, Strategy usually describes different ways of doing the same thing, letting you swap these algorithms within a single context class."@en ,
                 "Vzorca Command in Strategy imata zelo različen namen. Vzorec Command lahko uporabimo za prevedbo katere koli operacije v objekt. Parametri operacije postanejo atributi objekta. Prevedba omogoča, da odložimo izvedbo operacije, jo postavimo v  čakalno vrsto, shranimo zgodovino ukazov, pošljemo ukaze oddaljenim storitvam, ipd. Po drugi strani pa vzorec Strategy določa različne načine izvajanja iste stvari (da lahko nalogo stvar izvedemo na drugačen način), kar nam omogoča zamenjavo algoritmov v okviru kontekstnega razreda."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Strategy ;
    owl:annotatedProperty :solvesDifferentProblems ;
    owl:annotatedTarget :State ;
    rdfs:comment "Stanja shranijo sklic na kontekstni objekt, ki jih vsebuje. Strategije ne. Stanja se lahko zamenjajo (tj. spremenijo stanje kontekstnega objekta v nekaj drugega), medtem ko strategijam ni dovoljeno. Strategije se posredujejo kontekstualnemu objektu kot parametri, medtem ko stanja ustvari sam kontekstni objekt. Strategije obravnavajo samo eno, specifično nalogo, medtem ko stanja zagotavljajo osnovno izvedbo za vse (ali skoraj vse), kar počne objekt konteksta. Vzorec stanja obravnava stanje objekta in enkapsulira vedenje, odvisno od stanja, medtem ko se vzorec strategije ukvarja s tem, kako objekt izvaja določeno nalogo (tj. enkapsulira algoritem)."@sl ,
                 "States store a reference to the context object that contains them. Strategies do not. States are allowed to replace themselves (ie. to change the state of the context object to something else), while Strategies are not. Strategies are passed to the context object as parameters, while States are created by the context object itself. Strategies only handle a single, specific task, while States provide the underlying implementation for everything (or most everything) the context object does. State pattern deals with an object's state and encapsulates state dependent behavior, while the Strategy pattern deals with how an object performs a certain task (encapsulates an algorithm)."@en
] .

:SupportsComplexTreeStructures rdf:type owl:NamedIndividual ,
                                        :Aspect ;
    rdfs:label "Supports complex trees structures"@en ;
    rdfs:comment "We can work with complex tree structures more conveniently: use polymorphism and recursion to your advantage."@en .

:SupportsComposition rdf:type owl:NamedIndividual ,
                              :Aspect ;
    rdfs:label "Support composition"@en ;
    rdfs:comment "/ Flexibility / You can assemble a set of simple commands into a complex one."@en .

:SupportsDeferredCodeExecution rdf:type owl:NamedIndividual ,
                                        :Aspect ;
    rdfs:label "Support deffered code execution"@en ;
    rdfs:comment "For the same reason (because each iterator object contains its own iteration state), you can delay an iteration and continue it when needed."@en ,
                 "You can implement deferred execution of operations."@en .

:SupportsRollbackSystem rdf:type owl:NamedIndividual ,
                                 :Aspect ;
    rdfs:label "Supports rollback system"@en ;
    rdfs:comment "We can produce snapshots of the object’s state without violating its encapsulation."@en ,
                 "You can implement undo/redo."@en .

:SupportsUnitTests rdf:type owl:NamedIndividual ,
                            :Aspect ;
    owl:differentFrom :UnitTestsUnfriendly ;
    rdfs:label "Supports unit tests"@en .

:SystemComponents rdf:type owl:NamedIndividual ,
                           :Aspect ;
    rdfs:comment "Sistemske komponente so glavne logične enote sistema, pri čemer je vsaka odgovorna za določen vidik delovanja sistema. Te komponente so modelirane kot medsebojno delujoči objekti, razredi ali podsistemi, ki skupaj izpolnjujejo zahteve sistema."@sl ,
                 "System components are major logical parts of the system, each responsible for a specific aspect of the system’s functionality. These components are modeled as interacting objects, classes, or subsystems that collectively fulfill the system's requirements."@en ;
    rdfs:label "Komponente sistema"@sl ,
               "System Components"@en .

:SystemMoreRobust rdf:type owl:NamedIndividual ,
                           :Aspect ;
    rdfs:label "System more robust"@en ;
    rdfs:comment "The proxy works even if the service object isn’t ready or is not available."@en .

:TemplateMethod rdf:type owl:NamedIndividual ,
                         :BehavioralPattern ;
    :hasStructure :TemplateMethodStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/bLB1JiCm3BtdAomuT1lgf8qXeI4XGO4R9pXnorgtpTecbPDsOh1_9qqtjIj3Q9V8URQV_Mnxp8DtBCgS6uHNDAcAxk3DK1MQYf1vZEbCo98JBo3CkTRmnG1MFCmIKfMC0fKhWaqg33QueWYfnIvlNXvldmEBSYArQS5LRZFPhiygbQtyFsdei8JufuLY9KtG0KTy7KsROeXBRLqe3RDwF7Z2M4WHYZM79EUr52aGtn96gWOXeIvGIv6fkX7_iD8sFpGGEEqNS00EVwu7KADaEftQr_Tz-rw1sO-tdUvex41ji9prx7dFlkxP2sjRUOToWP8XeK7tdxNr1zZl1ixXd9_WdF_1UKR_WxcNgiOjTnCUTEzNfVzzVpnJDkZcP8mhyS5BOI-XMMEc2hjnJclHL757HY993QZuE7EvFB6WJjva8kB914PxaMCt2-ZftBaWp3NQiCwvs3jHHkx4Vm00"^^xsd:anyURI ;
    :differsInAspectsFrom :FactoryMethod ,
                          :Strategy ;
    :hasCon :CanViolateLSP ,
            :CodeMoreComplicated ,
            :CodeMoreInflexibile ;
    :hasPro :CodeChangeFlexibility ,
            :PromoteCodeReuse ;
    :hasSimilarStructure :FactoryMethod ;
    :isBasedOn :Inheritance ,
               :Interface ;
    :intent "Template Method is a behavioral design pattern that defines the skeleton of an algorithm in the superclass but lets subclasses override specific steps of the algorithm without changing its structure."@en ;
    rdfs:comment "Template Method is a design pattern that defines the skeleton of an algorithm in an operation, deferring some steps to subclasses. Template method lets subclasses redefine certain steps of an algorithm without changing the algorithm's structure. The intent of the template method is to define the overall structure of the operation, while allowing subclasses to refine, or redefine, certain steps. The template method is a method in a superclass, usually an abstract superclass, and defines the skeleton of an operation in terms of a number of high-level steps. These steps are themselves implemented by additional helper methods in the same class as the template method. The helper methods may be either abstract methods  or hook methods. Subclasses can (but are not required to) customize the operation by overriding the hook methods."@en ,
                 "Metoda predloge / šablone je načrtovalski vzorec, ki definira ogrodje algoritma v operaciji, pri čemer nekatere korake preloži na podrazrede. Metoda predloge omogoča podrazredom, da na novo definirajo določene korake algoritma, ne da bi spremenili strukturo algoritma. Namen metode predloge je definirati celotno strukturo operacije, hkrati pa podrazredom omogoča, da izboljšajo ali na novo definirajo določene korake. Metoda predloge je metoda v nadrazredu, običajno abstraktnem nadrazredu, in definira ogrodje operacije v smislu številnih korakov na visoki ravni. Te korake same izvajajo dodatne pomožne metode v istem razredu kot metoda predloge. Pomožne metode so lahko abstraktne metode ali 'hook methods'."@sl ;
    rdfs:label "Template Method"@en ,
               "Metoda šablone"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/template-method"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :TemplateMethod ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :FactoryMethod ;
    rdfs:comment "Both Factory method pattern and Template method pattern have similar design but they vary for their purpose. Factory Method is to creating objects as Template Method is to implementing an algorithm. In other words we can say Factory method pattern creates object in a similar way as Template method pattern executes the behaviour."@en ,
                 "Tako vzorec FactoryMethod kot vzorec TemplateMethod imata podobno zasnovo, vendar se razlikujeta glede na namen. Vzorec FactoryMethod je namenjen ustvarjanju predmetov, vzorec TemplateMethod pa implementaciji algoritma. Z drugimi besedami lahko rečemo, da vzorec FactoryMethod ustvari predmet na podoben način, kot vzorec TemplateMethod izvaja vedenje."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :TemplateMethod ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Strategy ;
    rdfs:comment "Template Method is based on inheritance: it lets you alter parts of an algorithm by extending those parts in subclasses. Strategy is based on composition: you can alter parts of the object’s behavior by supplying it with different strategies that correspond to that behavior. Template Method works at the class level, so it’s static. Strategy works on the object level, letting you switch behaviors at runtime."@en ,
                 "Vzorec TemplateMethod temelji na dedovanju: omogoča spreminjanje delov algoritma z razširitvojo teh delov v okviru podrazredov. Vzorec Strategy temelji na kompoziciji: obnašanje različnih delov objekta lahko spreminjamo tako, da mu zagotovimo različne strategije, ki ustrezajo temu vedenju. Vzorec TemplateMethod deluje na nivoju razredov, zato je statičen. Vzorec Strategy deluje na nivoju objektov in omogoča zamenjavo vedenja med izvajanjem."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :TemplateMethod ;
    owl:annotatedProperty :hasSimilarStructure ;
    owl:annotatedTarget :FactoryMethod ;
    rdfs:comment "Both Factory method pattern and Template method pattern have similar design but they vary for their purpose. Factory Method is a specialization of Template Method. At the same time, a Factory Method may serve as a step in a large Template Method."@en ,
                 "Tako vzorec FactoryMethod kot vzorec TemplateMethod imata podobno zasnovo, vendar se razlikujeta glede na namen. Vzorec FactoryMethod je specializacija (lahko rečemo bolj specifičen primer) vzorca TemplateMethod. Obenem vzorec FactoryMethod lahko služi kot korak pri implementaciji obsežnega vzorca TemplateMethod."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :TemplateMethod ;
    owl:annotatedProperty :isBasedOn ;
    owl:annotatedTarget :Inheritance ;
    rdfs:comment "Template Method is based on inheritance: it lets you alter parts of an algorithm by extending those parts in subclasses. The 'template method' is implemented as a method in a base class (usually an abstract class). Subclasses of the base class 'fill in' the empty or 'variant' parts of the template with specific algorithms that vary from one subclass to another. Subclasses do not override the template method itself."@en ,
                 "Vzorec TemplateMethod temelji na dedovanju: omogoča spreminjanje delov algoritma z razširitvojo teh delov v okviru podrazredov. Metoda 'template method' je implementirana kot metoda v osnovnem razredu (običajno abstraktnem razredu). Podrazredi osnovnega razreda 'zapolnijo' prazne ali 'variantne' dele predloge s posebnimi algoritmi, ki se razlikujejo od enega podrazreda do drugega. Podrazredi ne preglasijo same metode 'template method'."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :TemplateMethod ;
    owl:annotatedProperty :isPatternSpecialization ;
    owl:annotatedTarget :FactoryMethod ;
    rdfs:comment "A Factory Method may serve as a step in a large Template Method."@en ,
                 "Obenem vzorec FactoryMethod lahko služi kot korak pri implementaciji obsežnega vzorca TemplateMethod."@sl
] .

:ThreadSafe rdf:type owl:NamedIndividual ,
                     :Aspect ;
    rdfs:label "Thread safe"@en ;
    rdfs:comment "You can iterate over the same collection in parallel because each iterator object contains its own iteration state."@en .

:UnitTestsUnfriendly rdf:type owl:NamedIndividual ,
                              :Aspect ;
    rdfs:label "Unit tests unfriendly"@en ;
    rdfs:comment "Difficult to unit test the client code of the Singleton because many test frameworks rely on inheritance when producing mock objects."@en .

:Visitor rdf:type owl:NamedIndividual ,
                  :BehavioralPattern ;
    :hasStructure :VisitorStructure ;
    :diagram "https://www.plantuml.com/plantuml/svg/dLHTRvim57tthxXg7mBUGfycJLs4L5WgxNMJzh2f3mxS11TY8sD0wTR_FXimII2jkYfIPCxrFVVSBo_80dxoYckfli0FhUf4rmh9Wf0gvw9aYkqXALXLmHy2i659lbEo5cai2wcWpRX6YqkLekgnwq_tqUTrR52cb6nxS5COJ_9yoYganZUG9XssK-nWeAqKEZu2PtobeM6xovJNzx7vhT-fzCZMYz6AYSgOK6XYAhM0hxZbWYVyaS6kO8tW6IZsf32L3N01pHuhmNFPsBB6NJ6l82wuyJS7LhdpQWLU_F60HI5R7yAGa6z2ezgo1CqzS7qofyxBVHetFjuBmwu0o-NI_7-0njxny1RM1UvDZ3l_8XpvDkFpQ8F9HNEVhqLZIOAbzffRfwsZ7JEM8b6eqKaPSf-YbZ08WXFQBJ8xb7UU__zHeejHelT6SKDsZEFCrNcW4LsjlcEYcTWLE5HhgjJryP9_v-2KEgqlDlQ5rW8yM-tJKIrbWq_C3gNhRL3WLWUXIubCnGH1NGP_v_QnT-x2091PsQSNo94wd8t2QyR8ThpVeBh2Ax2y9t7dfaakPAvjMPU_CvwcA1wM5yHqvVl5IcuU1hlLkRGuKu_ShdNtccsard8FSkiskki9zWp1C56K2cmfdGhoV9-WIBjdSKutJHwW2VfEKwepNb7w1c-NEi3DpVXwx55dCgqW5x85dM5lJTnqwqE9bcEq3Da0rz1AbLVGSfq5n1WfnM1OeiZpAJqA-WS0"^^xsd:anyURI ;
    :canBeTreatedAsPowerful :Command ;
    :canBeUsedWith :Composite ,
                   :Iterator ;
    :differsInAspectsFrom :Command ;
    :hasCon :CanBeInvasive ,
            :CodeMoreInflexibile ;
    :hasPro :ImprovedPerformance ,
            :OpenClosedPrinciple ,
            :SingleResponsibilityPrinciple ;
    :isSimilarTo :Command ;
    :intent "Visitor is a behavioral design pattern that lets you separate algorithms from the objects on which they operate."@en ;
    rdfs:comment "Visitor is a behavioral design pattern that lets you separate algorithms from the objects on which they operate. A visitor pattern is a software design pattern that separates the algorithm from the object structure. In essence, the Visitor allows adding new virtual functions to a family of classes, without modifying the classes. Instead, a Visitor class is created that implements all of the appropriate specializations of the virtual function. The visitor takes the instance reference as input, and implements the goal through double dispatch."@en ,
                 "Obiskovalec je načrtovalski vzorec, ki omogoča ločevanje algoritmov od objektov, na katerih delujejo. Vzorec Obiskovalec ločuje algoritem od strukture objekta. V bistvu Obiskovalec omogoča dodajanje novih virtualnih funkcij družini razredov, ne da bi pri tem spreminjal razrede same. Namesto tega se ustvari razred Obiskovalec, ki implementira vse ustrezne specializacije virtualne funkcije. Obiskovalec vzame referenco primerka kot vhod in implementira cilj z dvojno odpremo."@sl ;
    rdfs:label "Visitor"@en ,
               "Obiskovalec"@sl;
    rdfs:seeAlso "https://refactoring.guru/design-patterns/visitor"^^xsd:anyURI .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Visitor ;
    owl:annotatedProperty :canBeTreatedAsPowerful ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Vzorec Visitor lahko obravnavamo kot zmogljivo različico vzorca Command. Objekti tipa Visotor ('Concrete Visitor') lahko izvajajo operacije nad različnimi objekti različnih razredov. Vsak objekt 'Concrete Visitor' namreč implementira različne različice istega vedenja ('visit(Element e)'), prilagojenih za različne razrede konkretnih elementov ('Concrete Element' implements 'Element')."@sl ,
                 "You can treat Visitor as a powerful version of the Command pattern. Its objects can execute operations over various objects of different classes."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Visitor ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Composite ;
    rdfs:comment "Vzorec Visitor lahko uporabimo za izvedbo operacij nad celotnim drevesom Composite."@sl ,
                 "We can use Visitor to execute an operation over an entire Composite tree."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Visitor ;
    owl:annotatedProperty :canBeUsedWith ;
    owl:annotatedTarget :Iterator ;
    rdfs:comment "Vzorec Visitor lahko uporabimo skupaj z vzorcem Iterator za sprehod po zapleteni podatkovni strukturi in nad elementi katere izvajamo operacije, tudi če elementi pripadajo različnim razredom."@sl ,
                 "We can use Visitor along with Iterator to traverse a complex data structure and execute some operation over its elements, even if they all have different classes."@en
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Visitor ;
    owl:annotatedProperty :differsInAspectsFrom ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Distinction: While Command focuses on encapsulating requests as objects, Visitor extends this concept by executing operations over diverse classes of objects."@en ,
                 "Medtem ko se vzorec Command osredotoča na enkapsulacijo zahtev kot objektov, vzorec Visitor ta koncept razširja z izvajanjem operacij nad različnimi razredi objektov."@sl
] .

[ rdf:type owl:Axiom ;
    owl:annotatedSource :Visitor ;
    owl:annotatedProperty :isSimilarTo ;
    owl:annotatedTarget :Command ;
    rdfs:comment "Similarity: Treat Visitor as a potent version of the Command pattern. Both enable objects to execute operations over various objects of different classes."@en ,
                 "Vzorec Visitor obravnavajte kot zmogljivo različico vzorca Command. Oba omogočata objektom izvajanje operacij nad različnimi objekti različnih razredov."@sl
] .

:WrappeeObject rdf:type owl:NamedIndividual ,
                        :Aspect ;
    rdfs:comment "Oviti objekt je izvorni objekt, ki ga obda drug objekt."@sl ,
                 "Wrappee is the original object being wrapped by another object"@en ;
    rdfs:label "Oviti objekt"@sl ,
               "Wrapee object"@en .


