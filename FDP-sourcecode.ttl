###  http://www.lavbic.net/onto/FDP/ChainOfResponsibilityJavaRG
:ChainOfResponsibilityJavaRG rdf:type owl:NamedIndividual ,
                                      :SourceCode ;
                             rdfs:label "Chain of Responsibility Java source code"@en ;
                             :language "Java" ;
                             :programcode """
/* Chain of Responsibility - Java Code Example */

import java.util.HashMap;
import java.util.Map;
import java.util.Scanner;


/**
 * [Handler] interface.
 *
 * The Handler declares the interface, common for all concrete handlers. It usually 
 * contains just a single method for handling requests - handle(request), but sometimes 
 * it may also have  another method for setting the next handler on the chain.
 */

interface Handler {
	// handle() method
	boolean check(String email, String password);
}


/**
 * [BaseHandler] class.
 *
 * Base Handler is an optional class where you can put the boilerplate code that’s  
 * common to all handler classes.
 *
 * Usually, this class defines a field for storing a reference to the <next> handler.  
 * The clients can build a chain by passing a handler to the constructor or setter of 
 * the previous handler. The class may also implement the default handling behavior: 
 * it can pass execution to the next handler after checking for its existence. 
 */

abstract class Middleware implements Handler {
	
	private Middleware next;
	
	/**
	 * Builds chains of middleware objects.
	 */
	 
	public static Middleware link(Middleware start, Middleware... chain) {
		Middleware head = start;
		for (Middleware nextInChain: chain) {
			head.next = nextInChain;
			head = nextInChain;
		}
		return start;
	}
	
	/**
	 * Subclasses will implement this method with concrete checks.
	 */
	
	public abstract boolean check(String email, String password);
	
	/**
	 * Run checks and returns "true" if we're in the last object in chain.
	 */
	
	protected boolean checkNext(String email, String password) {
		if (this.next == null)
			return true;
		return next.check(email, password);
	}
}


/** 
 * [Concrete Handlers] 
 */


/**
 * [ConcreteHandler] class 1. 
 *
 * Concrete Handlers contain the actual code for processing requests. Upon receiving 
 * a request, each handler must decide whether to process it and, additionally, whether 
 * to pass it along the chain.
 *
 * Handlers are usually self-contained (samostojni) and immutable (nespremenljivi), 
 * accepting  all necessary data just once via the constructor.
 * 
 * This Concrete Handler (1) checks whether there are too many failed login requests.
 */

class ThrottlingMiddleware extends Middleware {
	
	private int requestPerMinute;
	private int requestNum;
	private long currentTime;

	public ThrottlingMiddleware(int requestPerMinute) {
		this.requestPerMinute = requestPerMinute;
		this.requestNum = 0;
		this.currentTime = System.currentTimeMillis();
	}
	
	/**
	 * Please, note that checkNext() call can be inserted both in the beginning
     * of this method and in the end.
     *
     * This gives much more flexibility than a simple loop over all middleware
     * objects. For instance, an element of a chain can change the order of
     * checks by running its check after all other checks.
	 */
	
	@Override
	public boolean check(String email, String password) {
		if (System.currentTimeMillis() > currentTime + 60_000) {
			this.requestNum = 0;
			this.currentTime = System.currentTimeMillis();
		}
		
		// canHandleRequest
		// do some processing in the Concrete handler
		requestNum++;
		
		if (requestNum > requestPerMinute) {
			System.out.println("Request limit exceeded!");
			Thread.currentThread().stop();
		}
		
		// parent::handle(data)
		return checkNext(email, password);
	}
}

/**
 * [ConcreteHandler] class 2.
 * 
 * Checks whether a user with the given credentials exists.
 */

class UserExistsMiddleware extends Middleware {
	
	private Server server;
	
	public UserExistsMiddleware(Server server) {
		this.server = server;
	}
	
	// handle() method
	
	@Override
	public boolean check(String email, String password) {
		if (!this.server.hasEmail(email)) {
			System.out.println("This email is not registered!");
			return false;
		}
		if (!this.server.isValidPassword(email, password)) {
			System.out.println("Wrong password!");
			return false;
		}
		return checkNext(email, password);
	}
	
}

/**
 * [ConcreteHandler] class 3. 
 *
 * Checks a user's role.
 */

class RoleCheckMiddleware extends Middleware {
	
	// handle() method
	
	@Override
	public boolean check(String email, String password) {
		if (email.equals("admin@example.com")) {
			System.out.println("Hello, admin!");
			return true;
		}
		System.out.println("Hello, user!");
		return checkNext(email, password);
	}
}


/**
 * Server class.
 */

class Server {

	private Map<String, String> users;
	private Middleware middleware;

	public Server() {
		this.users = new HashMap<>();
	}

	/**
	 * Client passes a chain of object to server. This improves flexibility and
	 * makes testing the server class easier.
	 */

	public void setMiddleware(Middleware middleware) {
		this.middleware = middleware;
	}

	/**
	 * Server gets email and password from client and sends the authorization
	 * request to the chain.
	 */
	
	public boolean logIn(String email, String password) {
		if (middleware.check(email, password)) {
			System.out.println("[Status]: Authorization has been successful!");

			// <useful code> for authorized users.

			return true;
		}
		return false;
	}

	public void register(String email, String password) {
		users.put(email, password);
	}
	
	/** pomozne metode, ki jih klicejo [ConcreteHandlers] */

	public boolean hasEmail(String email) {
		return users.containsKey(email);
	}

	public boolean isValidPassword(String email, String password) {
		return users.get(email).equals(password);
	}
}

/**
 * [Client]
 *
 * The Client may compose chains just once or compose them dynamically, depending 
 * on the application’s logic. Note that a request can be sent to any handler in 
 * the chain—it doesn’t have to be the first one.
 */

public class MiddlewareTest {
	
	private static Server init() {
		Server server = new Server();
		server.register("admin@fri.si", "admin_geslo");
		server.register("user@fri.si", "user_geslo");
		
		// 1. All checks are linked. 
		//    Client can build various chains using the same components.
		Middleware middleware = Middleware.link(
			new ThrottlingMiddleware(2),
			new UserExistsMiddleware(server),
			new RoleCheckMiddleware()
		);
		
		// 2. Server gets a chain from client code.
		server.setMiddleware(middleware);
		
		return server;
	}
	
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		
		Server server = init();
		
		boolean success = false;
		while (!success) {	
			System.out.print("Enter email: ");
			String email = sc.next();
			System.out.print("Input password: ");
			String password = sc.next();
			success = server.logIn(email, password);
		}
	}
}
				 """ .


