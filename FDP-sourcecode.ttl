###  http://www.lavbic.net/onto/FDP/FactoryMethodJavaRG
:FactoryMethodJavaRG rdf:type owl:NamedIndividual ,
                              :SourceCode ;
					 rdfs:label "Factory Method Java source code"@en ;
                     :language "Java" ;
                     :programcode """
/**
 * FactoryMethod - Java Code Example 
 * Source: https://nitin-code.medium.com/factory-pattern-c0c284530d40
 */


import java.util.List;
import java.util.ArrayList;

// Dependency Inversion Principle <-- PizzaStore and all concrete Products depend on Product Abstraction (Pizza)

/** 
 * [PRODUCT class], abstraction
 *
 * -- Factories produce products, and in the PizzaStore, our product is a Pizza.
 */

abstract class Pizza {
	
	private String name;
	private String dough;
	private String sauce;
	private List<String> toppings;

	public Pizza(String name, String dough, String sauce) {
		this.name = name;
		this.dough = dough;
		this.sauce = sauce;
		this.toppings = new ArrayList<String>();
	}

	public String getName() {
		return name;
	}
	
	public void addToppings(String[] tops) {
		for (String topping : tops)
			this.toppings.add(topping);
	}

	public String prepare() {
		return String.format("preparing");
	}

	public String bake() {
		return String.format("baking");
	}

	public String cut() {
		return String.format("cutting");
	}

	public String box() {
		return String.format("boxing");
	}

	@Override
	public String toString() {
		StringBuilder sb = new StringBuilder();
		sb.append(String.format("+---- %s ----+%n", name));
		sb.append(String.format("| %s%n", dough));
		sb.append(String.format("| %s%n", sauce));
		sb.append(String.format("| %s...%n", " ".repeat(9)));
		for (String topping : toppings)
			sb.append(String.format("| %s%n", topping));
		sb.append(String.format("+%s+", "-".repeat(22)));
		return sb.toString();
	}
}


/** [CONCRETE PRODUCT classes] */


class CheesePizza extends Pizza {
	
	public CheesePizza() {
		super("Cheese Pizza", "Regular Crust", "Marinara Pizza Sauce");
		addToppings(new String[] { "Fresh Mozzarella", "Parmesan" });
	}
}

class ClamPizza extends Pizza {
	
	public ClamPizza() {
		super("Clam Pizza", "Thin crust", "White garlic sauce");
		addToppings(new String[] { "Clams", "Grated parmesan cheese" });
	}
}

class PepperoniPizza extends Pizza {
	
	public PepperoniPizza() {
		super("Pepperoni Pizza", "Crust", "Marinara sauce");
		addToppings(new String[] { "Sliced Pepperoni", "Sliced Onion", "Grated parmesan cheese" });
	}
}

class VeggiePizza extends Pizza {
	
	public VeggiePizza() {
		super("Veggie Pizza", "Crust", "Marinara sauce");
		addToppings(new String[] { 
			"Shredded mozzarella", "Grated parmesan", "Diced onion", 
			"Sliced mushrooms", "Sliced red pepper", "Sliced black olives"
		});
	}
}



/**
 * [CREATOR] classes
 *
 * -- declares the factory method
 * -- This is abstract creator class. It defines an <abstract factory method> 
 *    that the subclasses implement to produce <products>.
 */


/* [Base factory class] --> [BASE FACTORY] */

abstract interface PizzaFactory {
	
	/**
	 * abstract Product factoryMethod(String type)
	 * 
	 * -- Concrete Creators override the base factory method so it returns 
	 *    a different type of product.
	 * -- superclass does not know, what kind of Product is actually created
	 */
	 
	abstract Pizza createPizza(String type);
}


/**
 * [Concrete creators] --> [CONCRETE FACTORY]
 *
 * -- menu at Tonys pizzerija includes mouth watering pizzas listed below...
 */

class TonysPizzaFactory implements PizzaFactory {

	/** 
	 * [FACTORY METHOD]
	 *
	 * A factory method handles object creation and encapsulates it in a subclass.
	 * abstract Product factoryMethod(String type)
	 */

	public Pizza createPizza(String type) {
		switch (type) {
			case "cheese":
				return new CheesePizza();
			case "pepperoni":
				return new PepperoniPizza();
			case "clam":
				return new ClamPizza();
			case "veggie":
				return new VeggiePizza();
		}
		return null;
	}
}



/** 
 * [Client] 
 *
 * This is the client of the factory. PizzaStore orders pizazs at Tonys Pizzerija.
 */


class PizzaStore {

	private PizzaFactory factory;

	public PizzaStore(PizzaFactory factory) { 
		this.factory = factory;
	}
	
	public Pizza orderPizza(String type) {
		// the creator never really knows which concrete product was produced.
		// Product product = factory.factoryMethod()
		Pizza pizza = factory.createPizza(type);

		String prepared = pizza.prepare();
		String baked = pizza.bake();
		String cut = pizza.cut();
		String boxed = pizza.box();
		
		System.out.printf("%s: %s, %s, %s, %s...%n", pizza.getName(), prepared, baked, cut, boxed);
		return pizza;
	}
}

public class PizzaFactoryTest {

	public static void main(String[] args) {
		
		PizzaFactory factory = new TonysPizzaFactory();
		PizzaStore store = new PizzaStore(factory);
		
		System.out.println();
		Pizza pizza = store.orderPizza("cheese");
		System.out.printf("We ordered a %s%n%n", pizza.getName());
		System.out.println(pizza);

		System.out.println();
		Pizza veggiePizza = store.orderPizza("veggie");
		System.out.printf("We ordered a %s%n%n", veggiePizza.getName());
		System.out.println(veggiePizza);
	}
}
				 """ .


###  http://www.lavbic.net/onto/FDP/FactoryMethodPseudocodeRG
:FactoryMethodPseudocodeRG rdf:type owl:NamedIndividual ,
                                    :SourceCode ;
						   rdfs:label "Factory Method Pseudocode"@en ;
                           :programcode """
// The creator class declares the factory method that must
// return an object of a product class. The creator's subclasses
// usually provide the implementation of this method.

class Dialog is
    // The creator may also provide some default implementation
    // of the factory method.
    abstract method createButton():Button

    // Note that, despite its name, the creator's primary
    // responsibility isn't creating products. It usually
    // contains some core business logic that relies on product
    // objects returned by the factory method. Subclasses can
    // indirectly change that business logic by overriding the
    // factory method and returning a different type of product
    // from it.
    method render() is
        // Call the factory method to create a product object.
        Button okButton = createButton()
        // Now use the product.
        okButton.onClick(closeDialog)
        okButton.render()


// Concrete creators override the factory method to change the
// resulting product's type.

class WindowsDialog extends Dialog is
    method createButton():Button is
        return new WindowsButton()

class WebDialog extends Dialog is
    method createButton():Button is
        return new HTMLButton()


// The product interface declares the operations that all
// concrete products must implement.

interface Button is
    method render()
    method onClick(f)

// Concrete products provide various implementations of the
// product interface.

class WindowsButton implements Button is
    method render(a, b) is
        // Render a button in Windows style.
    method onClick(f) is
        // Bind a native OS click event.

class HTMLButton implements Button is
    method render(a, b) is
        // Return an HTML representation of a button.
    method onClick(f) is
        // Bind a web browser click event.


class Application is
    field dialog: Dialog

    // The application picks a creator's type depending on the
    // current configuration or environment settings.
    method initialize() is
        config = readApplicationConfigFile()

        if (config.OS == \"Windows\") then
            dialog = new WindowsDialog()
        else if (config.OS == \"Web\") then
            dialog = new WebDialog()
        else
            throw new Exception(\"Error! Unknown operating system.\")

    // The client code works with an instance of a concrete
    // creator, albeit through its base interface. As long as
    // the client keeps working with the creator via the base
    // interface, you can pass it any creator's subclass.
    method main() is
        this.initialize()
        dialog.render() """ ;
                           rdfs:seeAlso "https://refactoring.guru/design-patterns/factory-method"^^xsd:anyURI .



