###  http://www.lavbic.net/onto/FDP/TemplateMethodJavaRG
:TemplateMethodJavaRG rdf:type owl:NamedIndividual ,
                               :SourceCode ;
					  rdfs:label "Template Method Java source code"@en ;
                      :language "Java" ;
                      :programcode """
/* Template Method - Java Code Example */


/**
 * Eliminates the problem, where multiple classes have a lot of similar code.
 * 
 * The Template Method pattern suggests that you break down an algorithm into a series of steps, 
 * turn these steps into methods, and put a series of calls to these methods inside a single 
 * template method. 
 * 
 * The Template Method defines the steps of an algorithm and allows
 * subclasses to provide the implementation for one or more steps.
 *
 * Real world use: Use with code generators. If the generated code follows the template method pattern, 
 * the generated code will all be an abstract superclass. Provided that hand-written customizations are 
 * confined to a subclass, the code generator can be run again without risk of over-writing these 
 * modifications.
 *
 * <Factory Method> is a specialization of Template Method. 
 */
 
 
/** Sample: Overriding standard steps of an algorithm */


import java.util.Scanner;

/**
 * Base class of social network.
 */
 
// [Abstract class]
 
abstract class Network {
	
	private String userName;
	private String password;
	
	public Network() {}
	
	public Network(String username, String password) {
		this.userName = username;
		this.password = password;
	}
	
	// shares data on arbitrary social network
	
	/*
	 * post() is our template method
	 *
	 * -- it serves as template for an algorithm - in this case an algorithm
	 *    for posting a message to whatever social network
	 * -- steps in algorithm are represented by a method (below)
	 * -- some are handled by this class (regular methods) and some by the 
	 *    subclass (abstract)
	 */
	
	public boolean post(String message) {
		// authentication before posting. Every network uses a different auth. method.
		if (logIn(this.userName, this.password)) {
			boolean result = sendData(message.getBytes());
			logOut();
			return result;
		}
		return false;
	}
	
	abstract boolean logIn(String userName, String password);
	abstract boolean sendData(byte[] data);
	abstract void logOut();
	
	public static void simulateNetworkLatency() {
		try {
			int i = 0;
			System.out.println();
			while (i < 10) {
				System.out.print(".");
				Thread.sleep(500);
				i++;
			}
		} catch (InterruptedException ex) {
			ex.printStackTrace();
		}
	}	
	
	public String getUserName() {
		return this.userName;
	}
	
	public String getPassword() {
		return this.password;
	}
}


/**
 * Class of social network
 */

// [Subclass]es

class Facebook extends Network {
	
	public Facebook(String userName, String password) {
		super(userName, password);
	}
	
	@Override
	public boolean logIn(String userName, String password) {
		System.out.printf("%nChecking user's parameters%n");
		System.out.printf("Name: %s%n", getUserName());
		System.out.printf("Password: ");
		for (int i = 0; i < this.getPassword().length(); i++) {
			System.out.print("*");
		}
		Network.simulateNetworkLatency();
		System.out.printf("%n%nYou are successfully logged in on Facebook%n");
		return true;
	}
	
	@Override
	public boolean sendData(byte[] data) {
		boolean messagePosted = true;
		if (messagePosted)
			System.out.printf("Message: '%s' was posted on Facebook%n", new String(data));
		return messagePosted;
	}	
	
	@Override
	public void logOut() {
		System.out.printf("User: '%s' was logged out from Facebook.%n", getUserName());
	}
}


/**
 * Class of social network
 */

class Twitter extends Network {

	public Twitter(String userName, String password) {
		super(userName, password);
	}
	
	@Override
	public boolean logIn(String userName, String password) {
		System.out.printf("\nChecking user's parameters%n");
		System.out.printf("Name: %n", this.getUserName());
		System.out.printf("Password: ");
		for (int i = 0; i < this.getPassword().length(); i++)
			System.out.print("*");
		Network.simulateNetworkLatency();
		System.out.printf("%n%nYou are successfully logged in on Twitter%n");
		return true;
	}
	
	@Override
	public boolean sendData(byte[] data) {
		boolean messagePosted = true;
		if (messagePosted)
			System.out.printf("Message: '%s' was posted on Twitter%n", new String(data));
		return messagePosted;
	}

	@Override
	public void logOut() {
		System.out.printf("User: '%s' was logged out from Twitter%n", getUserName());
	}
}



/**
 * [Client]
 */
 
public class TemplateMethodTest {
	
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		
		System.out.printf("%nUser name: ");
		String userName = sc.nextLine();
		System.out.printf("Password: ");
		String password = sc.nextLine();
		
		System.out.printf("Comment on post: ");
		String message = sc.nextLine();
		
		System.out.printf("%nChoose social network.%n%s%n%s%n", "1 - Facebook", "2 - Twitter");
		int choice = sc.nextInt();
		
		Network network = (choice == 1) ? new Facebook(userName, password) : new Twitter(userName, password);
		network.post(message);
		
	}
}

				      """ .


###  http://www.lavbic.net/onto/FDP/TemplateMethodPseudocodeRG
:TemplateMethodPseudocodeRG rdf:type owl:NamedIndividual ,
                                     :SourceCode ;
							rdfs:label "TemplateMethod Pseudocode"@en ;
                            :programcode """// The abstract class defines a template method that contains a
// skeleton of some algorithm composed of calls, usually to
// abstract primitive operations. Concrete subclasses implement
// these operations, but leave the template method itself
// intact.

class GameAI is
    // The template method defines the skeleton of an algorithm.
    method turn() is
        collectResources()
        buildStructures()
        buildUnits()
        attack()

    // Some of the steps may be implemented right in a base
    // class.
    method collectResources() is
        foreach (s in this.builtStructures) do
            s.collect()

    // And some of them may be defined as abstract.
    abstract method buildStructures()
    abstract method buildUnits()

    // A class can have several template methods.
    method attack() is
        enemy = closestEnemy()
        if (enemy == null)
            sendScouts(map.center)
        else
            sendWarriors(enemy.position)

    abstract method sendScouts(position)
    abstract method sendWarriors(position)

// Concrete classes have to implement all abstract operations of
// the base class but they must not override the template method
// itself.

class OrcsAI extends GameAI is
    method buildStructures() is
        if (there are some resources) then
            // Build farms, then barracks, then stronghold.

    method buildUnits() is
        if (there are plenty of resources) then
            if (there are no scouts)
                // Build peon, add it to scouts group.
            else
                // Build grunt, add it to warriors group.

    // ...

    method sendScouts(position) is
        if (scouts.length > 0) then
            // Send scouts to position.

    method sendWarriors(position) is
        if (warriors.length > 5) then
            // Send warriors to position.

// Subclasses can also override some operations with a default
// implementation.

class MonstersAI extends GameAI is
    method collectResources() is
        // Monsters don't collect resources.

    method buildStructures() is
        // Monsters don't build structures.

    method buildUnits() is
        // Monsters don't build units. """ ;
                            rdfs:seeAlso "https://refactoring.guru/design-patterns/template-method"^^xsd:anyURI .




