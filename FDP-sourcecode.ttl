###  http://www.lavbic.net/onto/FDP/FacadeJavaRG
:FacadeJavaRG rdf:type owl:NamedIndividual ,
                       :SourceCode ;
			  rdfs:label "Facade Java source code"@en ;
              :language "Java" ;
              :programcode """
/* Facade - Java Code Example */


/**
 * Demo: the Facade simplifies communication with a complex video conversion framework.
 */
 
import java.io.File;

/**
 * These are some of the classes of a complex 3rd-party video
 * conversion framework. We don't control that code, therefore
 * can't simplify it.
 */

class VideoFile {

	private String name;
	private String codecType;
	
	public VideoFile(String name) {
		this.name = name;
		this.codecType = name.substring(name.indexOf(".") + 1);
	}
	
	public String getCodecType() {
		return codecType;
	}

	public String getName() {
		return name;
	}	
}

// [Codec]

interface Codec { 
	String getType();
}

class MPEG4CompressionCodec implements Codec {
	@Override
	public String getType() {
		return "mp4";
	}
}

class OggCompressionCodec implements Codec {
	@Override
	public String getType() {
		return "ogg";
	}	
}

// [Codec Factory]

class CodecFactory {
	
	public static Codec extract(VideoFile file) {
		String type = file.getCodecType();
		if (type.equals("mp4")) {
			System.out.printf("CodecFactory: extracting <mpeg> audio...%n");
			return new MPEG4CompressionCodec();
		} else if (type.equals("ogg")) {
			System.out.printf("CodecFactory: extracting <%s> audio...%n", type);
			return new OggCompressionCodec();
		}
		return null;
	}
}

// [BitrateReader]

class BitrateReader {
	
	public static VideoFile read(VideoFile file, Codec codec) {
		System.out.printf("BitrateReader: reading file...%n");
		return file;
	}

	public static VideoFile convert(VideoFile buffer, Codec codec) {
		String convertName = String.format("%s.%s", buffer.getName().split("\\.")[0], codec.getType());
		System.out.printf("BitrateReader: writing file <%s>...%n", convertName);
		return new VideoFile(convertName);
	}
}

// [AudioMixer]

class AudioMixer {
	private static final String EXTENSION = ".tmp";
	
	public static File fix(VideoFile result) {
		System.out.printf("AudioMixer: fixing audio...%n");
		String fixedFile = String.format("%s%s", result.getName().split("\\.")[0], EXTENSION);  
		return new File(fixedFile);
	}
}




/**
 * We create a [FACADE CLASS] to hide the framework's complexity
 * behind a simple interface. It's a <trade-off> between
 * <functionality> and <simplicity>.
 */

// VideoConverter --> isolating multiple dependencies within a single facade class.

class VideoConversionFacade {
	public File convertVideo(String fileName, String format) {
		
		System.out.println("VideoConversionFacade: conversion started.");
		VideoFile file = new VideoFile(fileName);
		System.out.printf(" ".repeat(4));
		Codec sourceCodec = CodecFactory.extract(file);
		
		Codec destinationCodec = null;
		if (format.equals("mp4"))
			destinationCodec = new MPEG4CompressionCodec();
		else if (format.equals("ogg"))
			destinationCodec = new OggCompressionCodec();
		
		System.out.printf(" ".repeat(4));
		VideoFile buffer = BitrateReader.read(file, sourceCodec);
		System.out.printf(" ".repeat(4));
		VideoFile intermediateResult = BitrateReader.convert(buffer, destinationCodec);
		
		System.out.printf(" ".repeat(4));
		File result = AudioMixer.fix(intermediateResult);
		System.out.println("VideoConversionFacade: conversion completed.");
		return result;
	}
}



/**
 * Application classes don't depend on a billion classes
 * provided by the complex framework. Also, if you decide to
 * switch frameworks, you only need to rewrite the facade class.
 */

// Application

public class FacadeDemo {
	
	public static void main(String[] args) {
		System.out.println();
		
		VideoConversionFacade converter = new VideoConversionFacade();
		File mp4Video = converter.convertVideo("tiktokvideo.ogg", "mp4");
		
		System.out.printf("%nR: %s%n", mp4Video);
	}
}
				 """ .


###  http://www.lavbic.net/onto/FDP/FacadePseudocodeRG
:FacadePseudocodeRG rdf:type owl:NamedIndividual ,
                             :SourceCode ;
					rdfs:label "Facade Pseudocode"@en ;
                    :programcode """// These are some of the classes of a complex 3rd-party video
// conversion framework. We don't control that code, therefore
// can't simplify it.

class VideoFile
// ...

class OggCompressionCodec
// ...

class MPEG4CompressionCodec
// ...

class CodecFactory
// ...

class BitrateReader
// ...

class AudioMixer
// ...


// We create a facade class to hide the framework's complexity
// behind a simple interface. It's a trade-off between
// functionality and simplicity.

class VideoConverter is
    method convert(filename, format):File is
        file = new VideoFile(filename)
        sourceCodec = (new CodecFactory).extract(file)
        if (format == \"mp4\")
            destinationCodec = new MPEG4CompressionCodec()
        else
            destinationCodec = new OggCompressionCodec()
        buffer = BitrateReader.read(filename, sourceCodec)
        result = BitrateReader.convert(buffer, destinationCodec)
        result = (new AudioMixer()).fix(result)
        return new File(result)

// Application classes don't depend on a billion classes
// provided by the complex framework. Also, if you decide to
// switch frameworks, you only need to rewrite the facade class.

class Application is
    method main() is
        convertor = new VideoConverter()
        mp4 = convertor.convert(\"funny-cats-video.ogg\", \"mp4\")
        mp4.save() """ ;
                    rdfs:seeAlso "https://refactoring.guru/design-patterns/facade"^^xsd:anyURI .




