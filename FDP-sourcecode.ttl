###  http://www.lavbic.net/onto/FDP/MementoJavaRG
:MementoJavaRG rdf:type owl:NamedIndividual ,
                        :SourceCode ;
			   rdfs:label "Memento Java source code"@en ;
               :language "Java" ;
               :programcode """
/* Memento - Java Code Example */

/**
 * Memento: implementacija s striktno enkapsulacijo.
 */


import java.util.List;
import java.util.ArrayList;


interface State {
	 
 }
 
interface Memento {
	public void restore();
}


interface Originator {
	public Memento save();
	public void setState(State state);
}


class ConcreteOriginator implements Originator {
	
	// 1.1 naslov ni del shranjevanja stanja
	
	private String naslov;
	
	// 1.2 attributes that are part of the saved state
	
	private String upravnik;
	private String barvaFasade;
	
	/**
	 * [Concrete State]
	 */	
	public static class ConcreteState implements State {
		
		// accessible by outer class only
		
		private final String upravnik;
		private final String barvaFasade;
		
		public ConcreteState(String upravnik, String barvaFasade) {
			this.upravnik = upravnik;
			this.barvaFasade = barvaFasade;
		}
	}
	
	public ConcreteOriginator(String naslov, String upravnik, String barvaFasade) {
		this.naslov = naslov;
		this.upravnik = upravnik;
		this.barvaFasade = barvaFasade;
	}
	
	public void setUpravnik(String upravnik) {
		System.out.printf("[Originator]: changing state; %s --> %s%n", this.upravnik, upravnik);
		this.upravnik = upravnik;
	}
	
	public Memento save() {
		System.out.println("[Originator]: save to Memento.");
		return new ConcreteMemento(this, new ConcreteState(this.upravnik, this.barvaFasade));
	}
	
	public void setState(State state) {
		ConcreteState cs = (ConcreteState) state;
		this.upravnik = cs.upravnik;
		this.barvaFasade = cs.barvaFasade;
		System.out.printf("[Originator]: after restoring from Memento: %s, %s%n", this.upravnik, this.barvaFasade);
	}
	
	public String toString() {
		return String.format("%s, %s barve; upravnik: %s", this.naslov, this.barvaFasade, this.upravnik);
	}
}


class ConcreteMemento implements Memento {
	
	private Originator originator;
	private State state;
	
	public ConcreteMemento(Originator originator, State state) {
		this.originator = originator;
		this.state = state;
	}
	
	public void restore() {
		this.originator.setState(state);
	}
}


public class Caretaker {
	
	private List<Memento> history;
	
	public Caretaker() {
		this.history = new ArrayList<>();
	}

	public void saveHistory(Memento memento) {
		this.history.add(memento);
	}
	
	public void undo() {
		if (this.history.isEmpty())
			return;
		Memento memento = this.history.get(this.history.size() - 1);
		memento.restore();
	}
	
	public static void main(String[] args) {
		Caretaker caretaker = new Caretaker();
		ConcreteOriginator originator = new ConcreteOriginator("Lepi pot 4", "SPL d.o.o.", "Bela");
		
		originator.setUpravnik("PUN");
		originator.setUpravnik("Prima Plus");
		caretaker.saveHistory(originator.save());
		
		originator.setUpravnik("DOMO");
		caretaker.saveHistory(originator.save());
		originator.setUpravnik("Upravnik d.o.o.");
		
		caretaker.undo();
		System.out.println(originator);
	}
	
}

				 """ .


###  http://www.lavbic.net/onto/FDP/MementoPseudocodeRG
:MementoPseudocodeRG rdf:type owl:NamedIndividual ,
                              :SourceCode ;
					 rdfs:label "Memento Pseudocode"@en ;
                     :programcode """// The originator holds some important data that may change over
// time. It also defines a method for saving its state inside a
// memento and another method for restoring the state from it.

class Editor is
    private field text, curX, curY, selectionWidth

    method setText(text) is
        this.text = text

    method setCursor(x, y) is
        this.curX = x
        this.curY = y

    method setSelectionWidth(width) is
        this.selectionWidth = width

    // Saves the current state inside a memento.
    method createSnapshot():Snapshot is
        // Memento is an immutable object; that's why the
        // originator passes its state to the memento's
        // constructor parameters.
        return new Snapshot(this, text, curX, curY, selectionWidth)

// The memento class stores the past state of the editor.

class Snapshot is
    private field editor: Editor
    private field text, curX, curY, selectionWidth

    constructor Snapshot(editor, text, curX, curY, selectionWidth) is
        this.editor = editor
        this.text = text
        this.curX = x
        this.curY = y
        this.selectionWidth = selectionWidth

    // At some point, a previous state of the editor can be
    // restored using a memento object.
    method restore() is
        editor.setText(text)
        editor.setCursor(curX, curY)
        editor.setSelectionWidth(selectionWidth)

// A command object can act as a caretaker. In that case, the
// command gets a memento just before it changes the
// originator's state. When undo is requested, it restores the
// originator's state from a memento.

class Command is
    private field backup: Snapshot

    method makeBackup() is
        backup = editor.createSnapshot()

    method undo() is
        if (backup != null)
            backup.restore()
    // ... """ ;
                     rdfs:seeAlso "https://refactoring.guru/design-patterns/memento"^^xsd:anyURI .





